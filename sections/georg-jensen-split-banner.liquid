{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .promo-cards__grid {
    column-gap: var(--grid-desktop-horizontal-spacing);
    row-gap: var(--grid-desktop-vertical-spacing);
  }

  .promo-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    /* Override global border radius if needed to match the sharp edges in the reference */
    border-radius: 0; 
    overflow: hidden;
  }

  .promo-card__image-wrapper {
    position: relative;
    width: 100%;
    /* 1:1 Square aspect ratio matching the reference */
    padding-bottom: 100%; 
    background-color: rgb(var(--color-background));
  }

  .promo-card__image-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .promo-card__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
    flex-grow: 1;
  }

  .promo-card__heading {
    margin-top: 0;
    margin-bottom: 1.5rem;
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 2.4rem);
    font-weight: 400;
  }

  .promo-card__text {
    font-size: 1.3rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.75);
    margin-bottom: 3.5rem;
    max-width: 400px;
  }

  .promo-card__text p {
    margin: 0;
  }

  .promo-card__button {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1.2rem 3rem;
    border: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    margin-top: auto;
  }

  .promo-card__button:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

{%- endstyle -%}

<div class="color-{{ section.settings.section_color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="grid grid--1-col grid--2-col-desktop promo-cards__grid">
      
      {%- for block in section.blocks -%}
        <div class="grid__item" {{ block.shopify_attributes }}>
          <div class="promo-card color-{{ block.settings.card_color_scheme }}">
            
            <div class="promo-card__image-wrapper global-media-settings">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1000 | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 50vw, 100vw',
                  widths: '375, 550, 750, 1000',
                  alt: block.settings.image.alt | escape
                }}
              {%- else -%}
                {{ 'image_d16962.jpg' | asset_url | img_tag: 'Placeholder', 'placeholder-svg' }}
              {%- endif -%}
            </div>

            <div class="promo-card__content">
              {%- if block.settings.heading != blank -%}
                <h3 class="promo-card__heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <div class="promo-card__text rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                <a {% if block.settings.button_link == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.button_link }}"{% endif %} 
                   class="promo-card__button"
                   style="background-color: {{ block.settings.button_bg_color }}; color: {{ block.settings.button_text_color }};">
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}
            </div>

          </div>
        </div>
      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Promo Cards",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "color_scheme",
      "id": "section_color_scheme",
      "label": "Section background color scheme",
      "default": "background-2",
      "info": "Set to a slightly off-white color to make the white cards pop, as seen in the reference."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "color_scheme",
          "id": "card_color_scheme",
          "label": "Card color scheme",
          "default": "background-1",
          "info": "Use a white background to match the reference."
        },
        {
          "type": "text",
          "id": "heading",
          "default": "Gift Ideas",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Gifting is one of life's great pleasures. Explore our world of unique Scandinavian gift ideas and find the perfect gift whether celebrating a special occasion or simply saying I love you.</p>",
          "label": "Description"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Explore Gift Ideas",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button background color",
          "default": "#A8DDF7"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Gift Ideas",
            "button_label": "EXPLORE GIFT IDEAS"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Silver Cutlery",
            "text": "<p>Sets of silver knives, forks, spoons, napkin rings and chopsticks make every meal a celebration.</p>",
            "button_label": "EXPLORE NOW"
          }
        }
      ]
    }
  ]
}
{% endschema %}