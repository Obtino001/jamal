{% comment %}
  Georg Jensen Split Banner Section (2-Column Banners) - Fully Theme Customizer Editable
{% endcomment %}

<div class="georg-split-banner-section section-{{ section.id }}">
  <div class="georg-container">
    <div class="georg-split-grid" style="grid-template-columns: repeat({{ section.blocks.size | default: 2 }}, 1fr);">
      {%- for block in section.blocks -%}
        <div class="georg-split-col" {{ block.shopify_attributes }}>
          <div class="georg-split-media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1000 }}" alt="{{ block.settings.title | escape }}" class="georg-split-img">
            {%- elsif forloop.index == 1 -%}
              <img src="{{ 'GJ_AW25_ALL_SEASON_GIFTING_200x200190_190_190.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="georg-split-img">
            {%- else -%}
              <img src="{{ 'GJ_SS26_HOME_SEASONAL_BERNADOTTE_COLLECTION_200x200190_190_190.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="georg-split-img">
            {%- endif -%}
          </div>

          <div class="georg-split-content">
            {%- if block.settings.title != blank -%}
              <h3 class="georg-split-title georg-serif">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="georg-split-desc georg-sans">{{ block.settings.text }}</p>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <div class="georg-split-cta">
                <a href="{{ block.settings.button_link | default: '#' }}" class="{% if block.settings.button_style == 'black' %}button-georg-black{% else %}button-georg-blue{% endif %}">
                  {{ block.settings.button_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .georg-split-banner-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color }};
  }

  .georg-split-grid {
    display: grid;
    gap: 32px;
  }

  .georg-split-col {
    display: flex;
    flex-direction: column;
    background: #ffffff;
  }

  .georg-split-media {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: #1b263b;
  }

  .georg-split-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .georg-split-col:hover .georg-split-img {
    transform: scale(1.03);
  }

  .georg-split-content {
    padding: 28px 0 0 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .georg-split-title {
    font-size: 26px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 10px 0;
    line-height: 1.25;
  }

  .georg-split-desc {
    font-size: 13px;
    line-height: 1.6;
    color: #555555;
    margin: 0 0 20px 0;
    max-width: 90%;
  }

  .georg-split-cta {
    margin-top: 5px;
  }

  @media screen and (max-width: 749px) {
    .georg-split-grid {
      grid-template-columns: 1fr !important;
      gap: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Split Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 70,
      "label": "Padding Top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 70,
      "label": "Padding Bottom (px)"
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Gaveidéer"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description Text",
          "default": "Find den perfekte gave til en du holder af iblandt vores udvalg af tidløst skandinavisk design."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Udforsk gaveidéer"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button Style",
          "options": [
            { "value": "blue", "label": "Navy Blue Solid" },
            { "value": "black", "label": "Black Solid" }
          ],
          "default": "blue"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Split Banner",
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "title": "Gaveidéer",
            "text": "Find den perfekte gave til enhver anledning iblandt klassisk dansk design.",
            "button_label": "UDFORSK GAVEIDÉER",
            "button_style": "blue"
          }
        },
        {
          "type": "banner",
          "settings": {
            "title": "Sølvbestik",
            "text": "Se vores smukke sølvbestikserier skabt med fokus på håndværk og elegance.",
            "button_label": "UDFORSK SØLVBESTIK",
            "button_style": "black"
          }
        }
      ]
    }
  ]
}
{% endschema %}
