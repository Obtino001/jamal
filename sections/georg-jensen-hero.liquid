{% comment %}
  Georg Jensen Hero Banner Section - 1-to-1 Replica
{% endcomment %}

<div class="georg-hero-section">
  <div class="georg-hero-media-wrap">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" class="georg-hero-img">
    {%- else -%}
      <div class="georg-hero-placeholder">
        <svg viewBox="0 0 1600 650" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
          <defs>
            <linearGradient id="heroGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#2a2e33"/>
              <stop offset="50%" stop-color="#191c20"/>
              <stop offset="100%" stop-color="#0e1013"/>
            </linearGradient>
          </defs>
          <rect width="100%" height="100%" fill="url(#heroGrad)"/>
          <circle cx="800" cy="325" r="280" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="2"/>
          <circle cx="800" cy="325" r="180" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>
        </svg>
      </div>
    {%- endif -%}

    <div class="georg-hero-overlay-content">
      <div class="georg-hero-card">
        <h2 class="georg-hero-heading georg-serif">{{ section.settings.heading | default: 'Weft kollektionen' }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="georg-hero-subheading georg-sans">{{ section.settings.subheading }}</p>
        {%- endif -%}
        <div class="georg-hero-cta">
          <a href="{{ section.settings.button_link | default: '#' }}" class="button-georg-black">
            {{ section.settings.button_label | default: 'Udforsk weft' }}
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .georg-hero-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #191c20;
  }

  .georg-hero-media-wrap {
    position: relative;
    min-height: 580px;
    display: flex;
    align-items: center;
  }

  .georg-hero-img, .georg-hero-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .georg-hero-overlay-content {
    position: relative;
    z-index: 2;
    max-width: 1380px;
    width: 100%;
    margin: 0 auto;
    padding: 60px 40px;
    display: flex;
    justify-content: flex-start;
  }

  .georg-hero-card {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    padding: 48px 44px;
    max-width: 460px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .georg-hero-heading {
    font-size: 38px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 16px 0;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .georg-hero-subheading {
    font-size: 13px;
    line-height: 1.6;
    color: #555555;
    margin: 0 0 24px 0;
  }

  .georg-hero-cta {
    margin-top: 10px;
  }

  @media screen and (max-width: 749px) {
    .georg-hero-media-wrap {
      min-height: 480px;
    }

    .georg-hero-overlay-content {
      padding: 30px 20px;
    }

    .georg-hero-card {
      padding: 32px 24px;
      max-width: 100%;
    }

    .georg-hero-heading {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Weft kollektionen"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Oplev den nyeste kollektion af tidsløse smykker og skandinavisk elegance."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Udforsk weft"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Hero"
    }
  ]
}
{% endschema %}
