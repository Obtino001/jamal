{% comment %}
  Georg Jensen Hero Banner Section - Fully Theme Customizer Editable
{% endcomment %}

<div class="georg-hero-section section-{{ section.id }}">
  <div class="georg-hero-media-wrap" style="min-height: {{ section.settings.desktop_height }}px;">
    {%- if section.settings.hero_image != blank -%}
      <img src="{{ section.settings.hero_image | image_url: width: 2000 }}" alt="{{ section.settings.heading | escape }}" class="georg-hero-img">
    {%- else -%}
      <img src="{{ 'SS26_Home_ecom_Frontpage_story_tile_410x410_Koppel1600.jpg' | asset_url }}" alt="GEORG JENSEN" class="georg-hero-img">
    {%- endif -%}

    <div class="georg-hero-overlay-content" style="justify-content: {{ section.settings.content_position }};">
      <div class="georg-hero-card" style="background: {{ section.settings.card_bg }}; color: {{ section.settings.card_text_color }}; max-width: {{ section.settings.card_max_width }}px;">
        {%- if section.settings.heading != blank -%}
          <h2 class="georg-hero-heading georg-serif" style="color: {{ section.settings.heading_color }}; font-size: {{ section.settings.heading_size }}px;">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="georg-hero-subheading georg-sans" style="color: {{ section.settings.subheading_color }};">
            {{ section.settings.subheading }}
          </p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="georg-hero-cta">
            <a href="{{ section.settings.button_link | default: '#' }}" class="button-georg-black">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .georg-hero-section {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: #191c20;
  }

  .georg-hero-media-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .georg-hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .georg-hero-overlay-content {
    position: relative;
    z-index: 2;
    max-width: 1380px;
    width: 100%;
    margin: 0 auto;
    padding: 60px 40px;
    display: flex;
  }

  .georg-hero-card {
    backdrop-filter: blur(8px);
    padding: 48px 44px;
    width: 100%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  .georg-hero-heading {
    font-weight: 400;
    margin: 0 0 16px 0;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .georg-hero-subheading {
    font-size: 13px;
    line-height: 1.6;
    margin: 0 0 24px 0;
  }

  .georg-hero-cta {
    margin-top: 10px;
  }

  @media screen and (max-width: 749px) {
    .georg-hero-media-wrap {
      min-height: 480px !important;
    }

    .georg-hero-overlay-content {
      padding: 30px 20px;
    }

    .georg-hero-card {
      padding: 32px 24px;
      max-width: 100% !important;
    }

    .georg-hero-heading {
      font-size: 28px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 800,
      "step": 20,
      "default": 580,
      "label": "Hero Height (px)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Weft kollektionen"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 60,
      "step": 2,
      "default": 38,
      "label": "Heading Font Size (px)"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Oplev den nyeste kollektion af tidsløse smykker og skandinavisk elegance."
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#555555"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Udforsk weft"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Card Position",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "color_background",
      "id": "card_bg",
      "label": "Card Background",
      "default": "rgba(255, 255, 255, 0.95)"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "card_max_width",
      "min": 320,
      "max": 700,
      "step": 20,
      "default": 460,
      "label": "Card Width (px)"
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Hero"
    }
  ]
}
{% endschema %}
