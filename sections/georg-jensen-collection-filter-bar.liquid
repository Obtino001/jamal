{% comment %}
  Georg Jensen Collection Filter & Sort Bar - Fully Theme Customizer Editable
{% endcomment %}

<div class="georg-filter-bar-section section-{{ section.id }}">
  <div class="georg-container">
    <div class="georg-filter-bar-inner">
      <!-- Left Filters -->
      <div class="georg-filter-group-left">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="georg-filter-item" {{ block.shopify_attributes }}>
              <button class="georg-filter-btn" type="button">
                {{ block.settings.label | upcase }} <span class="georg-caret">▾</span>
              </button>
            </div>
          {%- endfor -%}
        {%- else -%}
          <div class="georg-filter-item">
            <button class="georg-filter-btn" type="button">PRIS <span class="georg-caret">▾</span></button>
          </div>
          <div class="georg-filter-item">
            <button class="georg-filter-btn" type="button">PRODUKTTYPE <span class="georg-caret">▾</span></button>
          </div>
          <div class="georg-filter-item">
            <button class="georg-filter-btn" type="button">KOLLEKTION <span class="georg-caret">▾</span></button>
          </div>
          <div class="georg-filter-item">
            <button class="georg-filter-btn" type="button">MATERIALE <span class="georg-caret">▾</span></button>
          </div>
          <div class="georg-filter-item">
            <button class="georg-filter-btn" type="button">MERE <span class="georg-caret">▾</span></button>
          </div>
        {%- endif -%}
      </div>

      <!-- Right Sort -->
      {%- if section.settings.show_sort -%}
        <div class="georg-filter-group-right">
          <div class="georg-filter-item">
            <button class="georg-filter-btn georg-sort-btn" type="button">
              {{ section.settings.sort_label | default: 'SORTER EFTER' | upcase }} <span class="georg-caret">▾</span>
            </button>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .georg-filter-bar-section {
    background-color: {{ section.settings.bg_color | default: '#ffffff' }};
    border-bottom: 1px solid #e8e8e8;
    padding: 16px 0;
    font-family: var(--georg-font-sans);
  }

  .georg-filter-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .georg-filter-group-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .georg-filter-group-right {
    display: flex;
    align-items: center;
  }

  .georg-filter-btn {
    border: none;
    background: transparent;
    font-family: var(--georg-font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #111111;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    transition: opacity 0.2s;
  }

  .georg-filter-btn:hover {
    opacity: 0.6;
  }

  .georg-caret {
    font-size: 10px;
    color: #444444;
  }

  @media screen and (max-width: 890px) {
    .georg-filter-group-left {
      gap: 16px;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Filter Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show Sort Button",
      "default": true
    },
    {
      "type": "text",
      "id": "sort_label",
      "label": "Sort Label",
      "default": "SORTER EFTER"
    }
  ],
  "blocks": [
    {
      "type": "filter_item",
      "name": "Filter Dropdown Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Filter Button Label",
          "default": "PRIS"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Filter Bar",
      "blocks": [
        { "type": "filter_item", "settings": { "label": "PRIS" } },
        { "type": "filter_item", "settings": { "label": "PRODUKTTYPE" } },
        { "type": "filter_item", "settings": { "label": "KOLLEKTION" } },
        { "type": "filter_item", "settings": { "label": "MATERIALE" } },
        { "type": "filter_item", "settings": { "label": "MERE" } }
      ]
    }
  ]
}
{% endschema %}
