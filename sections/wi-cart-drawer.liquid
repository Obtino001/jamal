.WI_complete_look_product { display: flex; gap: 16px; }
.WI_complete_look_img { width: 70px; height: 90px; flex-shrink: 0; background: rgba(var(--color-foreground), 0.04); }
.WI_complete_look_img img { width: 100%; height: 100%; object-fit: cover; }
.WI_complete_look_info { flex: 1; display: flex; flex-direction: column; gap: 8px; }
.WI_complete_look_info_top { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
.WI_complete_look_title { font-size: 13px; font-weight: 500; color: rgb(var(--color-foreground)); line-height: 1.3; }
.WI_complete_look_price { font-size: 13px; font-weight: 600; color: rgb(var(--color-foreground)); white-space: nowrap; }
.WI_complete_look_options { display: flex; flex-direction: column; gap: 4px; }
.WI_complete_look_option_group { display: flex; flex-direction: column; gap: 4px; }
.WI_complete_look_option_label { font-size: 12px; color: rgba(var(--color-foreground), 0.5); }
.WI_complete_look_option_values { display: flex; gap: 6px; flex-wrap: wrap; }
.WI_complete_look_option_val { border: 1px solid rgba(var(--color-foreground), 0.2); background: rgb(var(--color-background)); padding: 5px 12px; min-width: 35px; text-align: center; font-size: 12px; font-weight: 500; cursor: pointer; color: rgb(var(--color-foreground)); transition: all 0.2s; }
.WI_complete_look_option_val:hover { border-color: rgb(var(--color-foreground)); }
.WI_complete_look_option_val.selected { border-color: rgb(var(--color-foreground)); background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); }
.WI_complete_look_add_btn { background: rgb(var(--color-foreground)); color: rgb(var(--color-background)); font-size: 12px; font-weight: 700; letter-spacing: 1.5px; border: none; height: 36px; padding: 0 24px; cursor: pointer; text-transform: uppercase; margin-top: 10px; display: inline-flex; align-items: center; justify-content: center; align-self: flex-start; transition: background 0.2s; }
.WI_complete_look_add_btn:hover { background: rgba(var(--color-foreground), 0.85); }
.WI_also_like { margin-top: 28px; padding-top: 24px; border-top: 1px solid rgba(var(--color-foreground), 0.08); }
.WI_also_like_header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.WI_also_like_header span { font-size: 12px; font-weight: 600; letter-spacing: 1.5px; color: rgb(var(--color-foreground)); }
.WI_also_like_nav { display: flex; gap: 6px; }
.WI_also_like_prev, .WI_also_like_next { border: none; background: transparent; cursor: pointer; padding: 4px; display: flex; align-items: center; justify-content: center; color: rgba(var(--color-foreground), 0.5); transition: color 0.2s; }
.WI_also_like_prev:hover, .WI_also_like_next:hover { color: rgb(var(--color-foreground)); }
.WI_also_like_body { width: 100%; overflow: hidden; }
.WI_also_like_list { display: flex; gap: 12px; overflow-x: auto; scroll-behavior: smooth; -ms-overflow-style: none; scrollbar-width: none; }
.WI_also_like_list::-webkit-scrollbar { display: none; }
.WI_also_like_item { flex: 0 0 160px; display: flex; flex-direction: column; gap: 6px; }
.WI_also_like_item_img { width: 160px; height: 180px; background-color: rgba(var(--color-foreground), 0.04); overflow: hidden; position: relative; }
.WI_also_like_item_img img { width: 100%; height: 100%; object-fit: cover; }
.WI_also_like_item_title { font-family: var(--georg-font-sans-bold, 'SourceSansPro-Bold', 'Source Sans Pro', sans-serif); font-size: 12px; font-weight: 700; color: #000; text-decoration: none; line-height: 1.35; margin-top: 2px; }
.WI_also_like_item_price { font-family: var(--georg-font-sans-bold, 'SourceSansPro-Bold', 'Source Sans Pro', sans-serif); font-size: 12px; font-weight: 700; color: #000; }
.WI_bundle_promo { background-color: rgba(var(--color-foreground), 0.05); padding: 16px; margin-top: 28px; border-radius: 0; }
