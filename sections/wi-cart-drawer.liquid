.WI_discount_wrap { display: flex; align-items: center; gap: 12px; margin-top: 24px; padding-bottom: 24px; }
.WI_discount_input { flex: 1; border: none; border-bottom: 1.5px solid rgba(var(--color-foreground), 0.2); padding: 8px 0; font-size: 13px; outline: none; background: transparent; color: rgb(var(--color-foreground)); transition: border-color 0.2s; }
.WI_discount_input:focus { border-color: rgb(var(--color-foreground)); }
.WI_discount_btn { border: 1px solid rgb(var(--color-foreground)); background: rgb(var(--color-background)); color: rgb(var(--color-foreground)); padding: 8px 16px; font-size: 11px; font-weight: 600; cursor: pointer; letter-spacing: 1px; transition: all 0.2s; }
.WI_discount_btn:hover { border-color: rgb(var(--color-foreground)); background: rgba(var(--color-foreground), 0.04); }
.WI_cartLoading { display: none; }
.WI_cartLoadingin { display: none; }

/* ── Circle SVG loaders (UpCart-style) ── */
.wi-cart-item-loader {
  position: absolute;
  inset: 0;
  z-index: 6;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(var(--color-background), 0.78);
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
  opacity: 1;
  visibility: visible;
  transition: opacity 0.22s ease, visibility 0.22s ease;
  pointer-events: all;
}
.wi-cart-item-loader.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.wi-cart-global-loader {
  position: absolute;
  inset: 0;
  z-index: 25;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(var(--color-background), 0.88);
  backdrop-filter: blur(3px);
  -webkit-backdrop-filter: blur(3px);
  transition: opacity 0.22s ease, visibility 0.22s ease;
}
.wi-cart-global-loader.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.wi-cart-spinner {
  display: block;
  animation: wiCartSpinRotate 1.4s linear infinite;
}
.wi-cart-spinner__path {
  stroke: rgb(var(--color-foreground));
  stroke-linecap: round;
  stroke-dasharray: 180;
  stroke-dashoffset: 0;
  transform-origin: center;
  animation: wiCartSpinDash 1.4s ease-in-out infinite;
}
.wi-cart-global-loader .wi-cart-spinner {
  width: 44px;
  height: 44px;
}
.wi-cart-qty-loader {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgb(var(--color-background));
  transition: opacity 0.2s ease, visibility 0.2s ease;
}
.wi-cart-qty-loader.hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}
.WI_cartDrawer_quantity {
  position: relative;
}
.WI_cartDrawer_item.wi-cart-item--loading .WI_cartDrawer_quantity button,
.WI_cartDrawer_item.wi-cart-item--loading .text-remove-btn {
  pointer-events: none;
  opacity: 0.45;
}
@keyframes wiCartSpinRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(270deg); }
}
@keyframes wiCartSpinDash {
  0% { stroke-dashoffset: 180; }
  50% { stroke-dashoffset: 45; transform: rotate(135deg); }
  100% { stroke-dashoffset: 180; transform: rotate(450deg); }
}
.WI_cartDrawerin_cart_footer { width: 100%; padding: 16px 24px; border-top: 1px solid rgba(var(--color-foreground), 0.08); background-color: rgb(var(--color-background)); z-index: 10; flex-shrink: 0; }
.WI_cartDrawer_total { width: 100%; display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
.WI_cartDrawer_total h5 { margin: 0; font-size: 13px; color: rgb(var(--color-foreground)); font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
.WI_cartDrawer_total h5.WI_cartDrawer_total_price { font-size: 16px; font-weight: 700; }
.WI_cartDrawer_checkout { width: 100%; height: 48px; background-color: rgb(var(--color-foreground)) !important; color: rgb(var(--color-background)) !important; border: none; font-size: 13px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background-color 0.2s; }
.WI_cartDrawer_checkout:hover { background-color: rgba(var(--color-foreground), 0.85) !important; }
.WI_cartDrawer_badges { display: flex; justify-content: center; align-items: center; gap: 8px; margin-bottom: 12px; padding: 0; list-style: none; }
.WI_cartDrawer_badges li { display: flex; align-items: center; }
.WI_cartDrawer_badges svg, .WI_cartDrawer_badges img { height: 20px; width: 32px; object-fit: contain; }
.WI_cartDrawer_subtext { font-size: 11px; color: rgba(var(--color-foreground), 0.55); text-align: center; margin: 0; line-height: 1.4; }
wi-cartdrawer .WI_cartDrawerin_cart_header, wi-cartdrawer .WI_cartDrawer_item, wi-cartdrawer .WI_complete_look, wi-cartdrawer .WI_also_like, wi-cartdrawer .WI_bundle_promo, wi-cartdrawer .WI_discount_wrap, wi-cartdrawer .WI_cartDrawerin_cart_footer { opacity: 0; transform: translateX(-40px); transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease; }
wi-cartdrawer.active .WI_cartDrawerin_cart_header, wi-cartdrawer.active .WI_cartDrawer_item, wi-cartdrawer.active .WI_complete_look, wi-cartdrawer.active .WI_also_like, wi-cartdrawer.active .WI_bundle_promo, wi-cartdrawer.active .WI_discount_wrap, wi-cartdrawer.active .WI_cartDrawerin_cart_footer { opacity: 1; transform: translateX(0); }
wi-cartdrawer.active .WI_cartDrawerin_cart_header { transition-delay: 0.1s; }
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(1) { transition-delay: 0.15s; }
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(2) { transition-delay: 0.2s; }
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(3) { transition-delay: 0.25s; }
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(4) { transition-delay: 0.3s; }
wi-cartdrawer.active .WI_cartDrawer_item:nth-child(n+5) { transition-delay: 0.35s; }
wi-cartdrawer.active .WI_complete_look { transition-delay: 0.35s; }
wi-cartdrawer.active .WI_also_like { transition-delay: 0.4s; }
wi-cartdrawer.active .WI_bundle_promo { transition-delay: 0.45s; }
wi-cartdrawer.active .WI_discount_wrap { transition-delay: 0.5s; }
wi-cartdrawer.active .WI_cartDrawerin_cart_footer { transition-delay: 0.25s; }
wi-cartdrawer:not(.active) .WI_cartDrawerin_cart_header, wi-cartdrawer:not(.active) .WI_cartDrawer_item, wi-cartdrawer:not(.active) .WI_complete_look, wi-cartdrawer:not(.active) .WI_also_like, wi-cartdrawer:not(.active) .WI_bundle_promo, wi-cartdrawer:not(.active) .WI_discount_wrap, wi-cartdrawer:not(.active) .WI_cartDrawerin_cart_footer { transition: none !important; }

/* ── UpCart-style cart item animations ── */
.WI_cartDrawer_item {
  transition: opacity 0.38s cubic-bezier(0.16, 1, 0.3, 1), transform 0.38s cubic-bezier(0.16, 1, 0.3, 1), max-height 0.42s cubic-bezier(0.16, 1, 0.3, 1), padding 0.42s ease, margin 0.42s ease, border-color 0.42s ease;
  overflow: hidden;
  max-height: 280px;
}
.WI_cartDrawer_item.wi-cart-item--entering {
  opacity: 0;
  transform: translateX(-24px);
}
.WI_cartDrawer_item.wi-cart-item--entered {
  opacity: 1;
  transform: translateX(0);
}
.WI_cartDrawer_item.wi-cart-item--removing {
  opacity: 0 !important;
  transform: translateX(28px) !important;
  max-height: 0 !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  margin-top: 0 !important;
  margin-bottom: 0 !important;
  border-bottom-color: transparent !important;
  pointer-events: none;
}
.WI_cartDrawer_item.wi-cart-item--updating {
  animation: wiCartItemPulse 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes wiCartItemPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  45% { opacity: 0.65; transform: scale(0.985); }
}
.WI_cartDrawer_total_price.wi-cart-total--pulse {
  animation: wiCartTotalPulse 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  display: inline-block;
}
@keyframes wiCartTotalPulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  35% { transform: scale(1.08); opacity: 0.85; }
}
.WI_cartDrawer_count.wi-cart-count--bump {
  display: inline-block;
  animation: wiCartCountBump 0.45s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes wiCartCountBump {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.18); }
}
wi-cartdrawer.wi-cart-updating .WI_cartDrawerin_cart_items {
  pointer-events: none;
}
.WI_cartDrawerin_cart_body.wi-cart-body--fade-in {
  animation: wiCartBodyFadeIn 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
}
@keyframes wiCartBodyFadeIn {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
wi-cartdrawer { transition: background-color 0.32s cubic-bezier(0.16, 1, 0.3, 1); }

@media screen and (max-width: 800px) {
  .WI_cartDrawerin_cart { width: calc(100vw - 30px); height: 100dvh; }
  .WI_cartDrawerin_cart_footer { padding-bottom: max(16px, env(safe-area-inset-bottom)); }
}
</style>

<wi-cartdrawer>
    <div class="WI_cartDrawerin">
        <div class="WI_cartDrawerin_cart">
            <data-cart-count hidden>{{ cart.item_count }}</data-cart-count>
            <div class="WI_cartDrawerin_cart_header">
                <h2 class="WI_cartDrawerin_cart_headerH">
                  <div class="WI_cartDrawerin_cart_header_left">
                    <span class="WI_cartDrawer_bag_icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="19" height="20" viewBox="0 0 19 20" fill="none">
                        <mask id="mask0_288_159" style="mask-type:luminance" maskUnits="userSpaceOnUse" x="1" y="1" width="17" height="17">
                          <path d="M17.2464 1.65829H1.32682V17.5779H17.2464V1.65829Z" fill="white"/>
                        </mask>
                        <g mask="url(#mask0_288_159)">
                          <path d="M14.5931 5.37195H3.98002V16.4493H14.5931V5.37195Z" stroke="#000" stroke-width="1.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M7.62828 7.03128V3.64837C7.62828 3.18405 8.02627 2.78606 8.49059 2.78606H10.2152C10.6795 2.78606 11.0775 3.18405 11.0775 3.64837V7.09761" stroke="#000" stroke-width="1.2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
                        </g>
                      </svg>
                    </span>
                    <span class="WI_cartDrawer_count">{{ 'sections.header.cart_count' | t: count: cart.item_count | upcase }}</span>
                  </div>
                  <span class="WI_cartDrawerCls">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                </h2>
            </div>
            <div class="wi-cart-global-loader hidden" aria-live="polite" aria-label="{{ 'accessibility.loading' | t | default: 'Loading' }}">
              {% render 'wi-cart-spinner', size: 44 %}
            </div>
            
            {% if cart.item_count > 0 %}
            <div class="WI_cartDrawerin_cart_body">
                {% form 'cart', cart %}
                <div class="WI_cartDrawerin_cart_form_in">
                    <div class="WI_cartDrawerin_cart_items">
                        {% for item in cart.items %}
                        <div class="WI_cartDrawer_item" data-itemKey="{{item.key}}" 
                        data-savingPrice="{%- if item.variant.compare_at_price -%}{{ item.variant.compare_at_price | minus: item.variant.price | times: item.quantity }}{%- endif -%}">
                            <div class="WI_cartDrawer_item_img">
                                <a href="{{ item.product.url }}">{{item.image | image_url: width: 250 | image_tag: loading: 'eager'}}</a>
                            </div>
                            <div class="WI_cartDrawer_item_info">
                                <div class="WI_cartDrawer_item_info_top">
                                    <a href="{{ item.product.url }}" class="WI_cartDrawer_item_title">{{item.product.title | escape}}</a>
                                    <span class="WI_cartDrawer_item_price">
                                        {%- if item.variant.compare_at_price > item.variant.price -%}
                                        <span class="compare-price">{{item.variant.compare_at_price | money_without_trailing_zeros}}</span>
                                        <span>{{item.variant.price | money_without_trailing_zeros}}</span>
                                        {%- else -%}
                                        <span>{{item.variant.price | money_without_trailing_zeros}}</span>
                                        {%- endif -%}
                                    </span>
                                </div>
                                
                                {%- if item.product.has_only_default_variant == false or item.properties.size > 0 -%}
                                    <div class="WI_cartDrawer_item_options">
                                        {%- if item.product.has_only_default_variant == false -%}
                                            {%- for option in item.options_with_values -%}
                                                <span class="option-tag">{{ option.name }}: {{ option.value }}</span>
                                            {%- endfor -%}
                                        {%- endif -%}
                                        {%- assign property_size = item.properties | size -%}
                                        {%- if property_size > 0 -%}
                                            {%- for p in item.properties -%}
                                                {%- assign first_character_in_key = p.first | truncate: 1, '' -%}
                                                {%- unless p.last == blank or first_character_in_key == '_' -%}
                                                    <span class="option-tag">
                                                        <strong>{{ p.first }}:</strong>
                                                         {%- if p.last contains '/uploads/' -%}
                                                             <a href="{{ p.last }}" target="_blank">{{ p.last | split: '/' | last }}</a>
                                                        {%- else -%}
                                                            {{ p.last }}
                                                        {%- endif -%}
                                                    </span>
                                                {%- endunless -%}
                                            {%- endfor -%}
                                        {%- endif -%}
                                    </div>
                                {%- endif -%}
                                
                                <div class="WI_cartDrawer_item_info_bottom">
                                    <div class="WI_cartDrawer_quantity">
                                        <div class="wi-cart-qty-loader hidden" aria-hidden="true">
                                          {% render 'wi-cart-spinner', size: 18 %}
                                        </div>
                                        <button type="button" class="WI_cartDrawer_minus">
                                          <svg class="WI_cartDrawer_minus" width="10" height="2" viewBox="0 0 10 2" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path class="WI_cartDrawer_minus" d="M0 1H10" stroke="currentColor" stroke-width="1.5"/>
                                          </svg>
                                        </button>
                                        <input value="{{ item.quantity }}" type="number" readonly />
                                        <button type="button" class="WI_cartDrawer_plus">
                                          <svg class="WI_cartDrawer_plus" width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path class="WI_cartDrawer_plus" d="M5 0V10M0 5H10" stroke="currentColor" stroke-width="1.5"/>
                                          </svg>
                                        </button>
                                    </div>
                                     <button type="button" class="cartDrawerRemove text-remove-btn">{{ 'sections.cart.remove_title' | t: title: '' | strip }}</button>
                                </div>
                            </div>
                            <div class="wi-cart-item-loader hidden" aria-hidden="true">
                              {% render 'wi-cart-spinner', size: 32 %}
                            </div>
                        </div>
                        {% endfor %}
                    </div>

                    {% comment %} COMPLETE THE LOOK - Powered by Shopify Complementary Products (Search & Discovery) {% endcomment %}
                    <div class="WI_complete_look open" id="WI_complete_look_section" style="display:none;">
                      <div class="WI_complete_look_header" onclick="this.closest('.WI_complete_look').classList.toggle('open')">
                        <span>{{ section.settings.complete_look_title | default: 'FULLFØR STILEN' }}</span>
                        <span class="WI_complete_look_toggle"><svg xmlns="http://www.w3.org/2000/svg" class="icon-cancel" width="9" height="9" viewBox="0 0 9 9" fill="none">
    <path d="M0.5 8.5L4.5 4.5L0.5 8.5ZM8.5 0.5L4.49924 4.5L8.5 0.5ZM4.49924 4.5L0.5 0.5L4.49924 4.5ZM4.5 4.5L8.5 8.5L4.5 4.5Z" fill="#fff"></path>
    <path d="M0.5 8.5L4.5 4.5L8.5 8.5M8.5 0.5L4.49924 4.5L0.5 0.5" stroke="#fff" stroke-linecap="round" stroke-linejoin="round"></path>
</svg></span>
                      </div>
                      <div class="WI_complete_look_body"></div>
                    </div>

                    {% comment %} YOU MAY ALSO LIKE - Powered by Shopify Related Products (Search & Discovery) {% endcomment %}
                    <div class="WI_also_like" id="WI_also_like_section" style="display:none;">
                      <div class="WI_also_like_header">
                        <span>{{ section.settings.you_may_also_like_title | default: 'DU VIL KANSKJE OGSÅ LIKE' }}</span>
                        <div class="WI_also_like_nav">
                          <button type="button" class="WI_also_like_prev">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="15 18 9 12 15 6"></polyline>
                            </svg>
                          </button>
                          <button type="button" class="WI_also_like_next">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <polyline points="9 18 15 12 9 6"></polyline>
                            </svg>
                          </button>
                        </div>
                      </div>
                      <div class="WI_also_like_body">
                        <div class="WI_also_like_list"></div>
                      </div>
                    </div>
                    <div id="cart-drawer-data" style="display:none;" 
                      data-first-product-id="{% if cart.items.size > 0 %}{{ cart.items[0].product.id }}{% endif %}"
                      data-cart-handles="{% for item in cart.items %}{{ item.product.handle }}{% unless forloop.last %},{% endunless %}{% endfor %}">
                    </div>
                    {% comment %} EXERCERE BUNDLE promo box {% endcomment %}
                    {% if section.settings.bundle_desc != blank %}
                      <div class="WI_bundle_promo">
                        {% if section.settings.bundle_title != blank %}
                          <h4 class="WI_bundle_promo_title">{{ section.settings.bundle_title }}</h4>
                        {% endif %}
                        <div class="WI_bundle_promo_desc">
                          {{ section.settings.bundle_desc }}
                        </div>
                      </div>
                    {% endif %}

                    {% comment %} Discount Code Input {% endcomment %}
                    {% if section.settings.show_discount_code %}
                      <div class="WI_discount_wrap">
                        <input type="text" name="discount" class="WI_discount_input" placeholder="{{ section.settings.discount_placeholder | default: 'Skriv inn rabattkode' }}" autocomplete="off">
                        <button type="button" class="WI_discount_btn" data-applied-text="{{ section.settings.discount_applied_btn_text | default: 'BRUKT' }}">{{ section.settings.discount_btn_text | default: 'BRUK' }}</button>
                      </div>
                    {% endif %}

                </div>
                
                <div class="WI_cartDrawerin_cart_footer">
                    <div class="WI_cartDrawer_total">
                        <h5>{{ 'sections.cart.estimated_total' | t }}</h5>
                        <h5 class="WI_cartDrawer_total_price">{{ cart.total_price | money_without_trailing_zeros }}</h5>
                    </div>

                    <button type="submit" name="checkout" value="Checkout" class="WI_cartDrawer_checkout">{{ section.settings.checkout_btn_text | default: 'GÅ TIL KASSEN' }}</button>
                    
                    <ul class="WI_cartDrawer_badges">
                      <!-- Apple Pay -->
                     {% render 'Payments' %}
                    </ul>
                    <p class="WI_cartDrawer_subtext">
                      {%- if cart.duties_included and cart.taxes_included -%}
                        {%- if shop.shipping_policy.body == blank -%}
                          {{ 'sections.cart.duties_and_taxes_included_shipping_at_checkout_without_policy' | t }}
                        {%- else -%}
                          {{
                            'sections.cart.duties_and_taxes_included_shipping_at_checkout_with_policy_html'
                            | t: link: shop.shipping_policy.url
                          }}
                        {%- endif -%}
                      {%- elsif cart.duties_included == false and cart.taxes_included -%}
                        {%- if shop.shipping_policy.body == blank -%}
                          {{ 'sections.cart.taxes_included_shipping_at_checkout_without_policy' | t }}
                        {%- else -%}
                          {{
                            'sections.cart.taxes_included_shipping_at_checkout_with_policy_html'
                            | t: link: shop.shipping_policy.url
                          }}
                        {%- endif -%}
                      {%- elsif cart.duties_included and cart.taxes_included == false -%}
                        {%- if shop.shipping_policy.body == blank -%}
                          {{ 'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                        {%- else -%}
                          {{
                            'sections.cart.duties_included_taxes_at_checkout_shipping_at_checkout_with_policy_html'
                            | t: link: shop.shipping_policy.url
                          }}
                        {%- endif -%}
                      {%- elsif cart.duties_included == false and cart.taxes_included == false -%}
                        {%- if shop.shipping_policy.body == blank -%}
                          {{ 'sections.cart.taxes_at_checkout_shipping_at_checkout_without_policy' | t }}
                        {%- else -%}
                          {{
                            'sections.cart.taxes_at_checkout_shipping_at_checkout_with_policy_html'
                            | t: link: shop.shipping_policy.url
                          }}
                        {%- endif -%}
                      {%- endif -%}
                    </p>
                </div>
                {% endform %}
            </div>
            {%- else -%}
              <div class="WI_cartDrawerin_cart_empty">
                <div class="WI_cartDrawerin_cart_empty_svg">
                  <svg width="56" viewBox="0 0 65 74" xmlns="http://www.w3.org/2000/svg"><g fill-rule="nonzero" fill="none"><path d="M64.407 9.856L53.605 0H11.371L.569 9.856A1.548 1.548 0 00.1 11.603c.235.619.843 1.031 1.524 1.031h61.727a1.62 1.62 0 001.522-1.031 1.545 1.545 0 00-.467-1.747z" fill="#C4C4C4"></path><path d="M63.351 9.927H1.624C.728 9.927 0 10.644 0 11.529v59.267C0 72.566 1.454 74 3.249 74h58.478c1.795 0 3.249-1.434 3.249-3.204V11.53c0-.885-.728-1.602-1.625-1.602z" fill="#E4E4E4"></path><path d="M32.488 45.122c-7.963 0-14.44-6.447-14.44-14.37v-4.79a1.6 1.6 0 011.605-1.596 1.6 1.6 0 011.604 1.596v4.79c0 6.163 5.04 11.177 11.23 11.177 6.192 0 11.231-5.014 11.231-11.177v-4.79a1.6 1.6 0 011.604-1.596 1.6 1.6 0 011.605 1.596v4.79c0 7.923-6.477 14.37-14.44 14.37z" fill="#6D6D6D"></path></g></svg>
                  <p>{{ 'general.cart.empty' | t }}</p>
                </div>
              </div>
            {% endif %}
        </div>
    </div>
</wi-cartdrawer>


{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "text",
      "id": "complete_look_title",
      "label": "Complete the Look Title",
      "default": "FULDEND LOOKET"
    },
    {
      "type": "text",
      "id": "complete_look_add_btn_text",
      "label": "Complete the Look Add Button Text",
      "default": "+ TILFØJ"
    },
    {
      "type": "text",
      "id": "you_may_also_like_title",
      "label": "You May Also Like Title",
      "default": "DU VIL MÅSKE OGSÅ KUNNE LIDE"
    },
    {
      "type": "text",
      "id": "bundle_title",
      "label": "Bundle Title",
      "default": "EXERCERE PAKKE"
    },
    {
      "type": "richtext",
      "id": "bundle_desc",
      "label": "Bundle Description",
      "default": "<p>Spar 15 % ved køb af en pakke. Tilføj blot en <a href=\"/collections/tops\">Top</a>, <a href=\"/collections/blouses\">Bluse</a> og <a href=\"/collections/bottoms\">Underdel</a> til indkøbskurven. Allerede nedsatte varer er ekskluderet.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_discount_code",
      "label": "Show Discount Code Input",
      "default": true
    },
    {
      "type": "text",
      "id": "discount_placeholder",
      "label": "Discount Input Placeholder",
      "default": "Indtast rabatkode"
    },
    {
      "type": "text",
      "id": "discount_btn_text",
      "label": "Discount Button Text",
      "default": "ANVEND"
    },
    {
      "type": "text",
      "id": "discount_applied_btn_text",
      "label": "Discount Applied Button Text",
      "default": "ANVENDT"
    },
    {
      "type": "text",
      "id": "checkout_btn_text",
      "label": "Checkout Button Text",
      "default": "GÅ TIL KASSEN"
    }
  ]
}
{% endschema %}