.WI_cartDrawer_item_title { font-family: var(--georg-font-sans-bold, 'SourceSansPro-Bold', 'Source Sans Pro', sans-serif); font-size: 14px; font-weight: 700; color: #000; text-decoration: none; line-height: 1.3; }
