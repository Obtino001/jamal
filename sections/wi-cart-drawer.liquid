.WI_complete_look { border: 1px solid rgba(var(--color-foreground), 0.08); margin-top: 24px; border-radius: 0; overflow: hidden; }
.WI_complete_look_header { background-color: rgb(var(--color-foreground)); padding: 12px 16px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
