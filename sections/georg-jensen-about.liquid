{% comment %}
  Georg Jensen About Us Section - 1-to-1 Replica
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="georg-about-section section-{{ section.id }}-padding">
  <div class="georg-container page-width">
    <div class="georg-about-header" data-aos="fade-up">
      <span class="georg-story-tag">SIDEN 1904</span>
      <h1 class="georg-about-title georg-serif">Om Georg Jensen</h1>
      <p class="georg-about-intro georg-sans">
        Med en historie på over 100 år står Georg Jensen for uovertruffen kunsthåndværk, tidløst skandinavisk design og kompromisløs kvalitet.
      </p>
    </div>

    <div class="georg-about-hero-media" data-aos="fade-up" data-aos-delay="100">
      <svg viewBox="0 0 1200 500" width="100%" height="100%" preserveAspectRatio="xMidYMid slice">
        <rect width="100%" height="100%" fill="#191c20"/>
        <circle cx="600" cy="250" r="180" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
        <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="Cormorant Garamond" font-size="36" fill="#ffffff" letter-spacing="4">GEORG JENSEN COPENHAGEN</text>
      </svg>
    </div>

    <div class="georg-about-story-grid">
      <div class="georg-about-col" data-aos="fade-up" data-aos-delay="200">
        <h3 class="georg-serif">Dansk Designtradition</h3>
        <p class="georg-sans">
          Grundlagt af sølvsmed Georg Jensen i København i 1904 har mærket altid været synonymt med organisk elegance, præcision og funktionalitet. Vores filosofi er at skabe demokratisk design, der kombinerer skønhed og funktion.
        </p>
      </div>

      <div class="georg-about-col" data-aos="fade-up" data-aos-delay="300">
        <h3 class="georg-serif">Kompromisløst Håndværk</h3>
        <p class="georg-sans">
          Fra de ikoniske Moonlight Grapes og Bernadotte serier til vores moderne bolig- og smykkekollektioner udstråler hvert enkelt produkt sølvsmedens ekspertise og passion for ædle metaller.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .georg-about-section {
    background-color: #ffffff;
    font-family: var(--georg-font-sans);
  }

  .georg-about-header {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 50px auto;
  }

  .georg-about-title {
    font-size: 42px;
    font-weight: 400;
    color: #111111;
    margin: 12px 0 20px 0;
  }

  .georg-about-intro {
    font-size: 16px;
    line-height: 1.7;
    color: #444444;
  }

  .georg-about-hero-media {
    width: 100%;
    height: 450px;
    margin-bottom: 60px;
    overflow: hidden;
  }

  .georg-about-story-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 60px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .georg-about-col h3 {
    font-size: 26px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 16px 0;
  }

  .georg-about-col p {
    font-size: 14px;
    line-height: 1.75;
    color: #555555;
  }

  @media screen and (max-width: 749px) {
    .georg-about-title {
      font-size: 32px;
    }
    .georg-about-story-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen About",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 70
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 90
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen About"
    }
  ]
}
{% endschema %}
