{% comment %}
  Georg Jensen 1-to-1 Main Product Detail Page (Exact HTML & Styling Match)
{% endcomment %}

<div id="main" role="main" class="full-width clearfix georg-pdp-section section-{{ section.id }}">
  <div class="georg-container">
    <!-- Breadcrumbs -->
    <ul class="breadcrumbs">
      <li class="d-none">
        <span><a class="breadcrumb-element" href="{{ routes.root_url }}"><span>Hjem</span></a></span>
      </li>
      <li>
        <span><a class="breadcrumb-element" href="/collections/all"><span>Smykker</span></a></span>
      </li>
      <li>
        <span><a class="breadcrumb-element" href="{{ collection.url | default: '/collections/all' }}"><span>Halskæder</span></a></span>
      </li>
      <li class="d-none">
        <span><span class="breadcrumb-element">{{ product.title }}</span></span>
      </li>
    </ul>

    <div id="primary" class="primary-content">
      <div id="pdpMain" class="pdp-main">
        
        <!-- Left Column: Images -->
        <div class="product-col-1">
          <div class="pdp-sticky-left product-image-container">
            <div class="product-primary-image">
              <div class="product-image-carousel">
                {%- if product.media.size > 0 -%}
                  {%- for media in product.media -%}
                    <a class="product-image main-image {% if forloop.first %}active{% endif %}" href="{{ media | image_url: width: 1200 }}" title="{{ product.title }}">
                      <img src="{{ media | image_url: width: 600 }}" alt="{{ product.title | escape }} {{ forloop.index }}" class="cld-responsive primary-image product-image" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
                    </a>
                  {%- endfor -%}
                {%- else -%}
                  <a class="product-image main-image active" href="#" title="MOONLIGHT GRAPES halskæde">
                    <img src="https://res.cloudinary.com/georgjensen/image/upload/f_auto,dpr_2/w_500,c_scale/products/images/hi-res/GJ_SS25_ECOM_SHOOT_MOONLIGHT_GRAPES_NECKLACE_20001008?_i=AG" alt="MOONLIGHT GRAPES halskæde" class="cld-responsive primary-image product-image">
                  </a>
                  <a class="product-image main-image" href="#" title="MOONLIGHT GRAPES halskæde">
                    <img src="https://res.cloudinary.com/georgjensen/image/upload/f_auto,dpr_2/w_500,c_scale/products/images/hi-res/GJ_SS25_ECOM_SHOOT_MOONLIGHT_GRAPES_NECKLACE_20001008_?_i=AG" alt="MOONLIGHT GRAPES halskæde" class="cld-responsive primary-image product-image">
                  </a>
                  <a class="product-image main-image" href="#" title="MOONLIGHT GRAPES halskæde">
                    <img src="https://res.cloudinary.com/georgjensen/image/upload/f_auto,dpr_2/w_500,c_scale/products/images/hi-res/20001008_GRAPE_NECKLACE_551I_SILVER?_i=AG" alt="MOONLIGHT GRAPES halskæde" class="cld-responsive primary-image product-image">
                  </a>
                {%- endif -%}
              </div>

              <!-- Thumbnails -->
              <div id="thumbnails" class="product-thumbnails not-show-desktop">
                <div class="owl-thumbs">
                  {%- if product.media.size > 0 -%}
                    {%- for media in product.media -%}
                      <button class="thumb {% if forloop.first %}selected{% endif %}" aria-label="change current image">
                        <div class="thumbnail-link">
                          <img src="{{ media | image_url: width: 100 }}" alt="" class="cld-responsive productthumbnail">
                        </div>
                      </button>
                    {%- endfor -%}
                  {%- else -%}
                    <button class="thumb selected"><div class="thumbnail-link"><img src="https://res.cloudinary.com/georgjensen/image/upload/f_auto,dpr_2/w_100,c_scale/products/images/hi-res/GJ_SS25_ECOM_SHOOT_MOONLIGHT_GRAPES_NECKLACE_20001008?_i=AG" class="cld-responsive productthumbnail"></div></button>
                    <button class="thumb"><div class="thumbnail-link"><img src="https://res.cloudinary.com/georgjensen/image/upload/f_auto,dpr_2/w_100,c_scale/products/images/hi-res/GJ_SS25_ECOM_SHOOT_MOONLIGHT_GRAPES_NECKLACE_20001008_?_i=AG" class="cld-responsive productthumbnail"></div></button>
                    <button class="thumb"><div class="thumbnail-link"><img src="https://res.cloudinary.com/georgjensen/image/upload/f_auto,dpr_2/w_100,c_scale/products/images/hi-res/20001008_GRAPE_NECKLACE_551I_SILVER?_i=AG" class="cld-responsive productthumbnail"></div></button>
                  {%- endif -%}
                </div>
              </div>
            </div>

            <!-- Gallery Extension Top -->
            <div class="gallery-extension-top">
              <span class="gallery-extension-text">{{ section.settings.gallery_text | default: 'Vi har genfortolket elementer fra klassiske Georg Jensen-designs med smukke resultater. Lige fra det underspillede og sofistikerede til det dristige og personlighedsskabende.' }}</span>
            </div>
          </div>
        </div>

        <!-- Right Column: Product Detail -->
        <div class="product-col-2 product-detail pdp-sticky-right">
          <div id="product-content">
            <!-- Collection Name -->
            <a class="product-collection" href="/collections/all">{{ product.vendor | default: 'Moonlight Grapes' }} Kollektion</a>
            
            <!-- Title -->
            <h1 class="product-name">{{ product.title }}</h1>
            
            <!-- Material Info -->
            <div class="product-material pdpMaterial">
              <div class="">{{ product.metafields.custom.material | default: 'Oxideret sterlingsølv' }}</div>
            </div>

            <!-- Variations / Sizes -->
            {%- unless product.has_only_default_variant -%}
              <div class="product-variations-container">
                <div class="product-variations">
                  <h2 class="visually-hidden">Variations</h2>
                  <ul>
                    {%- for option in product.options_with_values -%}
                      <li class="attribute variation-dropdown">
                        <div class="value">
                          <label for="Option-{{ option.name }}" class="d-none">Vælg {{ option.name | downcase }}</label>
                          <select id="Option-{{ option.name }}" class="variation-select" name="options[{{ option.name | escape }}]">
                            <option value="">Vælg {{ option.name | downcase }}</option>
                            {%- for value in option.values -%}
                              <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                                {{ value }}
                              </option>
                            {%- endfor -%}
                          </select>
                        </div>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            {%- endunless -%}

            <!-- Price -->
            <div class="product-price pdpPrice">
              <span class="price-sales effectiveprice">{{ product.price | money }}</span>
            </div>

            <!-- Add to Cart Form -->
            <div class="mobile-sticky-container">
              <div class="cta">
                <form method="post" action="/cart/add" id="add-to-cart-form" class="pdpForm">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <fieldset>
                    <legend style="display:none;">Læg i kurv Felter</legend>
                    <div class="product-add-to-cart">
                      <button id="add-to-cart" type="submit" class="button-fancy-large add-to-cart {% unless product.available %}disabled{% endunless %}" {% unless product.available %}disabled{% endunless %}>
                        {% if product.available %}Læg i kurv{% else %}Udsolgt{% endif %}
                      </button>
                    </div>
                  </fieldset>
                </form>

                <!-- Wishlist -->
                <div class="add-remove-wishlist add" tabindex="0">Tilføj ønskeliste</div>
              </div>
            </div>

            <!-- Gift Wrapping Banner -->
            {%- if section.settings.show_gift_wrapping -%}
              <div class="giftwrapping">
                <span class="giftwrapping-text">Gratis gaveindpakning</span>
                <img class="giftwrapping-image" src="https://www.georgjensen.com/on/demandware.static/-/Sites/default/dwd8cb5458/gift-wrap-banner@2x.jpg" alt="Gratis gaveindpakning" loading="eager">
              </div>
            {%- endif -%}

            <!-- Product Info Description -->
            <div class="product-info_content_item active">
              <p>{{ product.description | strip_html | truncatewords: 40 | default: 'Moonlight Grapes halskæden i sterlingsølv bærer de elegante druer i en abstrakt fortolkning og er inspireret af Georg Jensens tidlige værker.' }}</p>
            </div>
            <div class="product-info_content_item-read-more">Læs mere</div>

            <!-- Accordions -->
            <div class="product-accordion">
              <!-- Details Accordion -->
              <h2 class="accordion-head accordion-1"><span></span>Produktdetaljer</h2>
              <div class="accordion-body accordion-1">
                <section class="product-info">
                  <div class="product-info_details">
                    <div class="product-info_content">
                      <div class="product-info_content_item_list">
                        <ul>
                          <li><span class="product-info_content_item_detail">Varenummer:</span> {{ product.selected_or_first_available_variant.sku | default: '20001008' }}</li>
                          <li><span class="product-info_content_item_detail">Materialer:</span> {{ product.metafields.custom.material | default: 'Oxideret sterlingsølv' }}</li>
                          <li><span class="product-info_content_item_detail">Mål:</span> B: 12 mm. L: 425 mm.</li>
                          <li><span class="product-info_content_item_detail">Omkreds:</span> S: 405 mm, M: 440 mm, L: 470 mm</li>
                          <li><span class="product-info_content_item_detail">Designår:</span> {{ product.metafields.custom.design_year | default: '2021' }}</li>
                          <li>
                            <span class="product-info_content_item_detail meta-collection">Kollektion: </span>
                            <a href="/collections/all">{{ product.vendor | default: 'Moonlight Grapes' }}</a>
                          </li>
                        </ul>
                      </div>
                    </div>
                  </div>
                </section>
              </div>

              <!-- Shipping & Returns Accordion -->
              <h2 class="accordion-head accordion-2"><span></span>Forsendelse og returnering</h2>
              <div class="accordion-body accordion-2">
                <ul>
                  <li>Gratis gaveindpakning undtagen på nedsatte varer</li>
                  <li>Fri fragt på alle ordrer over 800 kr.</li>
                  <li>Nem ombytning og returnering</li>
                </ul>
              </div>
            </div>

            <!-- Contact USP Items -->
            <div class="product-usp-items-container">
              <div class="product-usp-item book-appointment">
                <a href="/pages/contact">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                  Book en aftale
                </a>
              </div>
              <div class="product-usp-item call-customer-service">
                <a href="tel: +45 38 14 90 44">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  Ring +45 38 14 90 44
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .georg-pdp-section {
    font-family: var(--georg-font-sans);
    color: #111111;
  }
  .georg-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }
  
  /* Breadcrumbs */
  .breadcrumbs {
    list-style: none;
    padding: 24px 0 16px;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .breadcrumbs li:not(:last-child)::after {
    content: "/";
    color: #777;
    margin-left: 8px;
  }
  .breadcrumb-element {
    color: #555;
    text-decoration: none;
  }
  .breadcrumb-element:hover {
    color: #111;
  }

  /* Main PDP Layout */
  .pdp-main {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
    margin-top: 10px;
    margin-bottom: 80px;
  }
  
  .product-col-1 {
    flex: 1 1 55%;
    min-width: 300px;
  }
  .product-col-2 {
    flex: 1 1 35%;
    max-width: 450px;
  }

  /* Left Image Gallery */
  .product-image-carousel {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .product-image {
    display: block;
    width: 100%;
    background: #f7f7f7;
  }
  .product-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .gallery-extension-top {
    margin-top: 40px;
    font-size: 14px;
    line-height: 1.6;
    color: #444;
  }

  /* Right Details Panel */
  .pdp-sticky-right {
    position: sticky;
    top: 100px;
  }
  
  .product-collection {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #555;
    text-decoration: none;
    margin-bottom: 12px;
    display: block;
  }
  
  .product-name {
    font-size: 28px;
    font-weight: 400;
    margin: 0 0 8px 0;
    line-height: 1.2;
    color: #111;
  }

  .product-material {
    font-size: 13px;
    color: #555;
    margin-bottom: 24px;
  }

  .variation-select {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ccc;
    background: #fff;
    font-size: 13px;
    border-radius: 0;
    appearance: none;
    margin-bottom: 24px;
  }

  .product-price {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 30px;
  }

  /* Buttons */
  .cta {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }
  .button-fancy-large {
    width: 100%;
    padding: 16px;
    background: #111;
    color: #fff;
    border: none;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background 0.3s;
  }
  .button-fancy-large:hover {
    background: #333;
  }
  
  .add-remove-wishlist {
    text-align: center;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    text-decoration: underline;
    color: #555;
  }
  .add-remove-wishlist:hover {
    color: #111;
  }

  .giftwrapping {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
    background: #fdfdfd;
    padding: 16px;
    border: 1px solid #eaeaea;
  }
  .giftwrapping-text {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .giftwrapping-image {
    width: 100%;
    height: auto;
  }

  .product-info_content_item {
    font-size: 14px;
    line-height: 1.6;
    color: #444;
    margin-bottom: 12px;
  }
  .product-info_content_item-read-more {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    text-decoration: underline;
    cursor: pointer;
    margin-bottom: 40px;
  }

  /* Accordion */
  .product-accordion {
    border-top: 1px solid #eaeaea;
  }
  .accordion-head {
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 20px 0;
    border-bottom: 1px solid #eaeaea;
    margin: 0;
    cursor: pointer;
    position: relative;
  }
  .accordion-head::after {
    content: "+";
    position: absolute;
    right: 0;
    font-size: 18px;
  }
  .accordion-body {
    padding: 20px 0;
    border-bottom: 1px solid #eaeaea;
    font-size: 13px;
    line-height: 1.6;
    color: #555;
  }
  .accordion-body ul {
    padding-left: 20px;
    margin: 0;
  }
  .product-info_content_item_list ul {
    list-style: none;
    padding: 0;
  }
  .product-info_content_item_detail {
    font-weight: 600;
    margin-right: 4px;
  }

  /* USP Contact Items */
  .product-usp-items-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 40px;
  }
  .product-usp-item a {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #111;
    text-decoration: none;
    padding: 16px;
    border: 1px solid #eaeaea;
    transition: background 0.3s;
  }
  .product-usp-item a:hover {
    background: #f7f7f7;
  }

  @media screen and (max-width: 890px) {
    .pdp-main {
      flex-direction: column;
    }
    .product-col-2 {
      max-width: 100%;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    // Simple Accordion Toggle Script
    var accHeads = document.querySelectorAll(".accordion-head");
    accHeads.forEach(function(head) {
      head.addEventListener("click", function() {
        var body = this.nextElementSibling;
        if (body.style.display === "none") {
          body.style.display = "block";
          this.style.borderBottom = "none";
          this.innerHTML = this.innerHTML.replace("+", "-"); // quick indicator hack
        } else {
          body.style.display = "none";
          this.style.borderBottom = "1px solid #eaeaea";
          this.innerHTML = this.innerHTML.replace("-", "+");
        }
      });
      // Hide initially
      head.nextElementSibling.style.display = "none";
    });
  });
</script>

{% schema %}
{
  "name": "Georg Jensen Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_gift_wrapping",
      "label": "Show Gift Wrapping Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "gallery_text",
      "label": "Gallery Sub-text",
      "default": "Vi har genfortolket elementer fra klassiske Georg Jensen-designs med smukke resultater."
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Product"
    }
  ]
}
{% endschema %}
