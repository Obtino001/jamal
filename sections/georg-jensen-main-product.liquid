{{ 'georg-jensen-pdp.css' | asset_url | stylesheet_tag }}
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0.36/dist/fancybox/fancybox.css"
>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script
  src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0.36/dist/fancybox/fancybox.umd.js"
  defer
></script>
<script src="{{ 'georg-jensen-pdp.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign product_form_id = 'gj-product-form-' | append: section.id
  assign collection_title = section.settings.collection_label
  if collection_title == blank and product.collections.size > 0
    assign collection_title = product.collections.first.title
  endif
  if collection_title == blank
    assign collection_title = product.vendor
  endif
  assign collection_url = section.settings.collection_link
  if collection_url == blank and product.collections.size > 0
    assign collection_url = product.collections.first.url
  endif
  if collection_url == blank
    assign collection_url = routes.all_products_collection_url
  endif

  assign material = product.metafields.custom.material.value | default: product.metafields.custom.material
  if material == blank
    assign material = section.settings.material_fallback
  endif

  assign design_year = product.metafields.custom.design_year.value | default: product.metafields.custom.design_year
  if design_year == blank
    assign design_year = section.settings.design_year_fallback
  endif

  assign measurements = product.metafields.custom.measurements.value | default: product.metafields.custom.measurements
  if measurements == blank
    assign measurements = section.settings.measurements_fallback
  endif

  assign gallery_text = product.metafields.custom.gallery_extension_text.value | default: product.metafields.custom.gallery_extension_text
  if gallery_text == blank
    assign gallery_text = section.settings.gallery_extension_text
  endif

  assign gallery_image = section.settings.gallery_extension_image
  if product.metafields.custom.gallery_extension_image.value != blank
    assign gallery_image = product.metafields.custom.gallery_extension_image.value
  endif

  assign gift_text = section.settings.gift_wrapping_text
  assign gift_image = section.settings.gift_wrapping_image
  assign phone = section.settings.phone_number
  assign phone_label = section.settings.phone_label
  assign atc_label = section.settings.add_to_cart_label
  assign wishlist_label = section.settings.wishlist_label
  assign wishlist_remove_label = section.settings.wishlist_remove_label
  assign read_more_label = section.settings.read_more_label
  assign read_less_label = section.settings.read_less_label
  assign details_heading = section.settings.details_heading
  assign shipping_heading = section.settings.shipping_heading
  assign shipping_content = section.settings.shipping_content
  assign item_number_label = section.settings.item_number_label
  assign materials_label = section.settings.materials_label
  assign measurements_label = section.settings.measurements_label
  assign design_year_label = section.settings.design_year_label
  assign collection_meta_label = section.settings.collection_meta_label
  assign explore_label = section.settings.explore_label
-%}

<div
  id="main"
  role="main"
  class="full-width clearfix georg-pdp-section section-{{ section.id }}"
  data-gj-pdp
  data-product-id="{{ product.id }}"
  data-money-format="{{ shop.money_format | escape }}"
  data-show-gallery-arrows="{% if section.settings.show_gallery_arrows %}true{% else %}false{% endif %}"
  data-hide-thumbnails="{% if section.settings.hide_mobile_thumbnails %}true{% else %}false{% endif %}"
>
  <div class="georg-containers georg-container">
    {%- if section.settings.show_breadcrumbs -%}
      <nav aria-label="Breadcrumb">
        <ul class="breadcrumbs">
          <li class="d-none">
            <span><a class="breadcrumb-element" href="{{ routes.root_url }}"><span>{{ section.settings.breadcrumb_home | default: 'Home' }}</span></a></span>
          </li>
          {%- if section.settings.breadcrumb_parent_label != blank -%}
            <li>
              <span>
                <a class="breadcrumb-element" href="{{ section.settings.breadcrumb_parent_link | default: routes.all_products_collection_url }}">
                  <span>{{ section.settings.breadcrumb_parent_label }}</span>
                </a>
              </span>
            </li>
          {%- endif -%}
          {%- if collection != blank -%}
            <li>
              <span>
                <a class="breadcrumb-element" href="{{ collection.url }}">
                  <span>{{ collection.title }}</span>
                </a>
              </span>
            </li>
          {%- elsif product.collections.size > 0 -%}
            <li>
              <span>
                <a class="breadcrumb-element" href="{{ product.collections.first.url }}">
                  <span>{{ product.collections.first.title }}</span>
                </a>
              </span>
            </li>
          {%- endif -%}
          <li class="d-none">
            <span><span class="breadcrumb-element">{{ product.title }}</span></span>
          </li>
        </ul>
      </nav>
    {%- endif -%}

    <div id="primary" class="primary-content">
      <div id="pdpMain" class="pdp-main">
        <div class="product-col-1" style="position: relative;">
          <div class="pdp-sticky-left product-image-container">
            <div class="product-primary-image{% if section.settings.show_gallery_arrows %} has-gallery-arrows{% endif %}{% if section.settings.hide_mobile_thumbnails %} hide-mobile-thumbs{% endif %}">
              <div class="product-image-carousel owl-carousel owl-theme" data-slider-id="productImageCarousel" data-gj-gallery-track>
                {%- if product.media.size > 0 -%}
                  {%- assign gj_slide_index = 0 -%}
                  {%- for media in product.media -%}
                    {%- if media.media_type == 'image' -%}
                      {%- liquid
                        if gj_slide_index == 0
                          assign img_loading = 'eager'
                          assign img_fetch = 'high'
                        else
                          assign img_loading = 'lazy'
                          assign img_fetch = 'auto'
                        endif
                      -%}
                      <a
                        class="product-image main-image{% if gj_slide_index == 0 %} is-active{% endif %}"
                        data-gallery="gallery-{{ section.id }}"
                        data-gj-gallery-slide
                        data-fancybox="gj-gallery-{{ section.id }}"
                        data-caption="{{ product.title | escape }}"
                        href="{{ media | image_url: width: 2400 }}"
                        title="{{ product.title | escape }}"
                      >
                        {%- if gj_slide_index == 0 -%}
                          <link rel="preload" as="image" href="{{ media | image_url: width: 900 }}">
                        {%- endif -%}
                        {{
                          media
                          | image_url: width: 900
                          | image_tag:
                            loading: img_loading,
                            fetchpriority: img_fetch,
                            class: 'cld-responsive primary-image product-image',
                            widths: '400, 600, 700, 900, 1200',
                            sizes: '(min-width: 990px) 33vw, 100vw',
                            alt: product.title
                        }}
                      </a>
                      {%- assign gj_slide_index = gj_slide_index | plus: 1 -%}

                    {%- elsif media.media_type == 'video' or media.media_type == 'external_video' -%}
                      {%- liquid
                        assign video_href = blank
                        assign video_type = 'html5video'
                        if media.media_type == 'video'
                          assign video_href = media.sources.first.url
                          assign video_type = 'html5video'
                        elsif media.host == 'youtube'
                          assign video_href = 'https://www.youtube.com/watch?v=' | append: media.external_id
                          assign video_type = 'youtube'
                        elsif media.host == 'vimeo'
                          assign video_href = 'https://vimeo.com/' | append: media.external_id
                          assign video_type = 'vimeo'
                        else
                          assign video_href = media | external_video_url
                          assign video_type = 'iframe'
                        endif
                      -%}
                      <a
                        class="product-image main-image product-image--video{% if gj_slide_index == 0 %} is-active{% endif %}"
                        data-gallery="gallery-{{ section.id }}"
                        data-gj-gallery-slide
                        data-fancybox="gj-gallery-{{ section.id }}"
                        data-type="{{ video_type }}"
                        {% if video_type == 'html5video' %}
                          data-width="1280"
                          data-height="720"
                        {% endif %}
                        data-caption="{{ product.title | escape }}"
                        href="{{ video_href }}"
                        title="{{ product.title | escape }} — video"
                      >
                        {%- if media.preview_image -%}
                          {{
                            media.preview_image
                            | image_url: width: 900
                            | image_tag:
                              loading: 'lazy',
                              class: 'cld-responsive primary-image product-image',
                              widths: '400, 600, 700, 900, 1200',
                              sizes: '(min-width: 990px) 33vw, 100vw',
                              alt: product.title
                          }}
                        {%- else -%}
                          <span class="product-image__video-fallback" aria-hidden="true"></span>
                        {%- endif -%}
                        <span class="product-image__play" aria-hidden="true">
                          <svg viewBox="0 0 64 64" width="56" height="56" fill="none">
                            <circle cx="32" cy="32" r="31" stroke="currentColor" stroke-width="1.5" fill="rgba(255,255,255,0.92)"/>
                            <path d="M27 22l18 10-18 10V22z" fill="currentColor"/>
                          </svg>
                        </span>
                      </a>
                      {%- assign gj_slide_index = gj_slide_index | plus: 1 -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>

              {%- if section.settings.show_gallery_arrows and product.media.size > 1 -%}
                <div class="gj-gallery-arrows" data-gj-gallery-arrows>
                  <button
                    type="button"
                    class="gj-gallery-arrow gj-gallery-arrow--prev"
                    data-gj-gallery-prev
                    aria-label="{{ 'general.pagination.previous' | t | default: 'Previous' }}"
                  >
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
                      <path d="M15 5l-7 7 7 7"/>
                    </svg>
                  </button>
                  <button
                    type="button"
                    class="gj-gallery-arrow gj-gallery-arrow--next"
                    data-gj-gallery-next
                    aria-label="{{ 'general.pagination.next' | t | default: 'Next' }}"
                  >
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
                      <path d="M9 5l7 7-7 7"/>
                    </svg>
                  </button>
                </div>
              {%- endif -%}

              {%- unless section.settings.hide_mobile_thumbnails -%}
                <div id="thumbnails" class="product-thumbnails not-show-desktop">
                  <div class="owl-thumbs" data-slider-id="productImageCarousel">
                    {%- assign gj_thumb_index = 0 -%}
                    {%- for media in product.media -%}
                      {%- if media.media_type == 'image' or media.media_type == 'video' or media.media_type == 'external_video' -%}
                        <button
                          type="button"
                          class="thumb owl-thumb-item{% if gj_thumb_index == 0 %} selected{% endif %}{% if media.media_type != 'image' %} thumb--video{% endif %}"
                          aria-label="{{ 'products.product.media.gallery_viewer' | t | default: 'Change current image' }}"
                        >
                          <div class="thumbnail-link">
                            {%- if media.media_type == 'image' -%}
                              {{
                                media
                                | image_url: width: 140
                                | image_tag:
                                  loading: 'lazy',
                                  class: 'cld-responsive productthumbnail',
                                  alt: '',
                                  widths: '70, 140'
                              }}
                            {%- elsif media.preview_image -%}
                              {{
                                media.preview_image
                                | image_url: width: 140
                                | image_tag:
                                  loading: 'lazy',
                                  class: 'cld-responsive productthumbnail',
                                  alt: '',
                                  widths: '70, 140'
                              }}
                              <span class="thumb__play" aria-hidden="true"></span>
                            {%- endif -%}
                          </div>
                        </button>
                        {%- assign gj_thumb_index = gj_thumb_index | plus: 1 -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endunless -%}
            </div>

            {%- if gallery_text != blank or gallery_image != blank -%}
              <div class="gallery-extension-top gallery-extension-top--desktop-only">
                {%- if gallery_text != blank -%}
                  <span class="gallery-extension-text">{{ gallery_text }}</span>
                {%- endif -%}
                {%- if gallery_image != blank -%}
                  <div class="gallery-extension-image">
                    {{
                      gallery_image
                      | image_url: width: 1400
                      | image_tag:
                        loading: 'lazy',
                        class: 'cld-responsive',
                        widths: '600, 900, 1200, 1400',
                        sizes: '(min-width: 990px) 60vw, 100vw',
                        alt: product.title
                    }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>

        <div class="product-col-2 product-detail pdp-sticky-right">
          <div id="product-content">
            {%- if collection_title != blank -%}
              <a class="product-collection" href="{{ collection_url }}">
                {{ collection_title }}
                {%- unless collection_title contains 'Collection' or collection_title contains 'collection' or collection_title contains 'Kollektion' -%}
                  {{ ' ' }}{{ section.settings.collection_suffix | default: 'Collection' }}
                {%- endunless -%}
              </a>
            {%- endif -%}

            <h1 class="product-name">{{ product.title }}</h1>

            {%- if material != blank -%}
              <div class="product-material pdpMaterial">
                <div>{{ material }}</div>
              </div>
            {%- endif -%}

            <span class="visually-hidden">{{ product.vendor }}</span>
            <span class="visually-hidden">{{ current_variant.sku }}</span>
            <span class="visually-hidden">{{ shop.url }}{{ product.url }}</span>

            {%- liquid
              assign show_pdp_usps = false
              if section.settings.show_usps
                if section.settings.usp_1 != blank or section.settings.usp_2 != blank or section.settings.usp_3 != blank
                  assign show_pdp_usps = true
                endif
                for block in section.blocks
                  if block.type == 'usp' and block.settings.text != blank
                    assign show_pdp_usps = true
                    break
                  endif
                endfor
              endif
            -%}
            {%- if show_pdp_usps -%}
              <ul class="gj-pdp-usps" aria-label="Product benefits">
                {%- if section.settings.usp_1 != blank -%}
                  <li class="gj-pdp-usp">
                    <span class="gj-pdp-usp__text">{{ section.settings.usp_1 | escape }}</span>
                    <span class="gj-pdp-usp__check" aria-hidden="true">
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4">
                        <path d="M3 8.2l3.2 3.2L13 4.5"/>
                      </svg>
                    </span>
                  </li>
                {%- endif -%}
                {%- if section.settings.usp_2 != blank -%}
                  <li class="gj-pdp-usp">
                    <span class="gj-pdp-usp__text">{{ section.settings.usp_2 | escape }}</span>
                    <span class="gj-pdp-usp__check" aria-hidden="true">
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4">
                        <path d="M3 8.2l3.2 3.2L13 4.5"/>
                      </svg>
                    </span>
                  </li>
                {%- endif -%}
                {%- if section.settings.usp_3 != blank -%}
                  <li class="gj-pdp-usp">
                    <span class="gj-pdp-usp__text">{{ section.settings.usp_3 | escape }}</span>
                    <span class="gj-pdp-usp__check" aria-hidden="true">
                      <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4">
                        <path d="M3 8.2l3.2 3.2L13 4.5"/>
                      </svg>
                    </span>
                  </li>
                {%- endif -%}
                {%- for block in section.blocks -%}
                  {%- if block.type == 'usp' and block.settings.text != blank -%}
                    <li class="gj-pdp-usp" {{ block.shopify_attributes }}>
                      <span class="gj-pdp-usp__text">{{ block.settings.text | escape }}</span>
                      <span class="gj-pdp-usp__check" aria-hidden="true">
                        <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.4">
                          <path d="M3 8.2l3.2 3.2L13 4.5"/>
                        </svg>
                      </span>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}

            <div class="product-variations-container{% if product.has_only_default_variant %} empty-vairation{% endif %}">
              {%- unless product.has_only_default_variant -%}
                {%- if section.settings.show_delivery_note -%}
                  <p
                    class="gj-delivery-note"
                    data-gj-delivery-note
                    hidden
                  >
                    {{ section.settings.delivery_note_text }}
                  </p>
                {%- endif -%}

                <div class="product-variations" data-gj-variations>
                  {%- for option in product.options_with_values -%}
                    {%- liquid
                      assign option_label = section.settings.choose_option_label | default: 'Choose size'
                      if product.options.size > 1
                        assign option_label = 'Choose ' | append: option.name
                      endif
                    -%}
                    <div
                      class="gj-size-picker"
                      data-gj-size-picker
                      data-option-index="{{ forloop.index0 }}"
                      data-placeholder="{{ option_label | escape }}"
                    >
                      <button
                        type="button"
                        class="gj-size-picker__trigger"
                        data-gj-size-trigger
                        aria-expanded="false"
                        aria-controls="GjSizePanel-{{ section.id }}-{{ forloop.index0 }}"
                        id="GjSizeTrigger-{{ section.id }}-{{ forloop.index0 }}"
                      >
                        <span class="gj-size-picker__label" data-gj-size-trigger-label>{{ option_label }}</span>
                        <span class="gj-size-picker__caret" aria-hidden="true"></span>
                      </button>

                      <div
                        class="gj-size-picker__panel"
                        id="GjSizePanel-{{ section.id }}-{{ forloop.index0 }}"
                        data-gj-size-panel
                        hidden
                        role="listbox"
                        aria-labelledby="GjSizeTrigger-{{ section.id }}-{{ forloop.index0 }}"
                      >
                        <div class="gj-size-picker__panel-inner">
                          {%- for value in option.values -%}
                            <button
                              type="button"
                              class="gj-size-picker__option"
                              role="option"
                              data-gj-size-option
                              data-value="{{ value | escape }}"
                              aria-selected="false"
                            >
                              {{ value }}
                            </button>
                          {%- endfor -%}
                        </div>
                      </div>

                      <label class="visually-hidden" for="Option-{{ section.id }}-{{ forloop.index0 }}">
                        {{ option.name }}
                      </label>
                      <select
                        id="Option-{{ section.id }}-{{ forloop.index0 }}"
                        class="variation-select visually-hidden"
                        name="options[{{ option.name | escape }}]"
                        form="{{ product_form_id }}"
                        data-gj-variation-select
                        tabindex="-1"
                        aria-hidden="true"
                      >
                        <option value="" selected disabled>{{ option_label }}</option>
                        {%- for value in option.values -%}
                          <option value="{{ value | escape }}">{{ value }}</option>
                        {%- endfor -%}
                      </select>
                    </div>
                  {%- endfor -%}
                </div>
                <script type="application/json" data-gj-variants>
                  [
                    {%- for variant in product.variants -%}
                      {
                        "id": {{ variant.id | json }},
                        "available": {{ variant.available | json }},
                        "price": {{ variant.price | json }},
                        "price_formatted": {{ variant.price | money_without_trailing_zeros | json }},
                        "compare_at_price": {{ variant.compare_at_price | json }},
                        "compare_at_price_formatted": {% if variant.compare_at_price %}{{ variant.compare_at_price | money_without_trailing_zeros | json }}{% else %}null{% endif %},
                        "options": {{ variant.options | json }},
                        "sku": {{ variant.sku | json }}
                      }{% unless forloop.last %},{% endunless %}
                    {%- endfor -%}
                  ]
                </script>
              {%- endunless -%}
            </div>

            <p
              class="gj-size-error"
              data-gj-size-error
              hidden
              {% if product.has_only_default_variant %}style="display:none"{% endif %}
            >
              {{ section.settings.size_required_error | default: 'Please choose a size' }}
            </p>

            <div class="product-price pdpPrice">
              <span class="price-sales effectiveprice" data-gj-price>
                {{ current_variant.price | money_without_trailing_zeros }}
              </span>
              {%- if current_variant.compare_at_price > current_variant.price -%}
                <span class="price-compare" data-gj-compare>{{ current_variant.compare_at_price | money_without_trailing_zeros }}</span>
              {%- else -%}
                <span class="price-compare" data-gj-compare hidden></span>
              {%- endif -%}
            </div>

            <div class="mobile-sticky-container">
              <div class="cta">
                <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
                  <div class="product-form__error-message-wrapper" role="alert" hidden>
                    <span class="product-form__error-message"></span>
                  </div>

                  {%- form 'product', product, id: product_form_id, class: 'pdpForm form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    <input
                      type="hidden"
                      name="id"
                      value="{{ current_variant.id }}"
                      class="product-variant-id"
                      {% if current_variant.available == false %}disabled{% endif %}
                    >
                    <input type="hidden" name="quantity" value="1">
                    <fieldset>
                      <legend>Add to basket Fields</legend>
                      <div class="product-add-to-cart">
                        <button
                          id="add-to-cart"
                          type="submit"
                          name="add"
                          class="button-fancy-large add-to-cart product-form__submit"
                          data-gj-atc
                          data-available-label="{{ atc_label | escape }}"
                          data-soldout-label="{{ section.settings.sold_out_label | escape }}"
                          data-unavailable-label="{{ section.settings.unavailable_label | escape }}"
                          {% if current_variant.available == false %}disabled aria-disabled="true"{% endif %}
                        >
                          <span data-gj-atc-label>
                            {%- if current_variant.available -%}
                              {{ atc_label }}
                            {%- else -%}
                              {{ section.settings.sold_out_label }}
                            {%- endif -%}
                          </span>
                          {%- render 'loading-spinner' -%}
                        </button>
                      </div>
                    </fieldset>
                  {%- endform -%}
                </product-form>

                {%- if section.settings.show_wishlist -%}
                  <div
                    aria-label="{{ wishlist_label | escape }}"
                    class="add-remove-wishlist add"
                    tabindex="0"
                    role="button"
                    data-gj-wishlist-add
                    data-product-handle="{{ product.handle }}"
                  >
                    {{ wishlist_label }}
                  </div>
                  <div
                    aria-label="{{ wishlist_remove_label | escape }}"
                    class="add-remove-wishlist remove"
                    tabindex="0"
                    role="button"
                    data-gj-wishlist-remove
                    data-product-handle="{{ product.handle }}"
                    style="display:none"
                  >
                    {{ wishlist_remove_label }}
                  </div>
                {%- endif -%}
              </div>
            </div>

         {%- if section.settings.show_gift_wrapping -%}
  <div class="giftwrapping">
    {%- if gift_image != blank -%}
      {{
        gift_image
        | image_url: width: 800
        | image_tag:
          class: 'giftwrapping-image',
          loading: 'lazy',
          alt: gift_text
      }}
    {%- else -%}
      <img
        class="giftwrapping-image"
        src="https://www.georgjensen.com/on/demandware.static/-/Sites/default/dwd8cb5458/gift-wrap-banner@2x.jpg"
        alt="{{ gift_text | escape }}"
        loading="lazy"
        width="800"
        height="300"
      >
    {%- endif -%}
    <span class="giftwrapping-text">{{ gift_text }}</span>
  </div>
{%- endif -%}

            {%- liquid
              assign desc_plain = product.description | strip_html | strip | replace: '&nbsp;', '' | strip
              assign show_description = false
              if desc_plain != blank and desc_plain != '.' and desc_plain != '-' and desc_plain.size > 2
                assign show_description = true
              endif
            -%}
            {%- if show_description -%}
              <div class="gj-pdp-description">
                <div
                  class="product-info_content_item active is-collapsed"
                  data-full-text="{{ desc_plain | escape }}"
                >
                  <p>{{ desc_plain | newline_to_br }}</p>
                </div>
                {%- if desc_plain.size > 180 -%}
                  <div
                    class="product-info_content_item-read-more"
                    role="button"
                    tabindex="0"
                    data-more-label="{{ read_more_label | escape }}"
                    data-less-label="{{ read_less_label | escape }}"
                  >
                    {{ read_more_label }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            <div class="product-accordion" role="tablist">
              <h2 class="accordion-head accordion-1" role="tab" tabindex="0" aria-expanded="false">
                {{ details_heading }}
              </h2>
              <div class="accordion-body accordion-1" role="tabpanel">
                <section class="product-info">
                  <div class="product-info_details">
                    <div class="product-info_content">
                      <div class="product-info_content_item_list">
                        <ul>
                          <li>
                            <span class="product-info_content_item_detail">{{ item_number_label }}</span>
                            {{ current_variant.sku | default: product.id }}
                          </li>
                          {%- if material != blank -%}
                            <li>
                              <span class="product-info_content_item_detail">{{ materials_label }}</span>
                              {{ material }}
                            </li>
                          {%- endif -%}
                          {%- if measurements != blank -%}
                            <li>
                              <span class="product-info_content_item_detail">{{ measurements_label }}</span>
                              {{ measurements }}
                            </li>
                          {%- endif -%}
                          {%- if design_year != blank -%}
                            <li>
                              <span class="product-info_content_item_detail">{{ design_year_label }}</span>
                              {{ design_year }}
                            </li>
                          {%- endif -%}
                          {%- if collection_title != blank -%}
                            <li>
                              <span class="product-info_content_item_detail meta-collection">{{ collection_meta_label }}</span>
                              <a href="{{ collection_url }}">{{ collection_title }}</a>
                            </li>
                          {%- endif -%}
                          {%- if section.settings.explore_text != blank -%}
                            <li>
                              <span class="product-info_content_item_detail">{{ explore_label }}</span>
                              <a class="product-info_content_item_explore" href="{{ section.settings.explore_link | default: routes.all_products_collection_url }}">
                                {{ section.settings.explore_text }}
                              </a>
                            </li>
                          {%- endif -%}
                          {%- for block in section.blocks -%}
                            {%- if block.type == 'detail_row' and block.settings.value != blank -%}
                              <li {{ block.shopify_attributes }}>
                                {%- if block.settings.label != blank -%}
                                  <span class="product-info_content_item_detail">{{ block.settings.label }}</span>
                                {%- endif -%}
                                {{ block.settings.value }}
                              </li>
                            {%- endif -%}
                          {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  </div>
                </section>
              </div>

              {%- if section.settings.show_shipping_accordion -%}
                <h2 class="accordion-head accordion-2" role="tab" tabindex="0" aria-expanded="false">
                  {{ shipping_heading }}
                </h2>
                <div class="accordion-body accordion-2" role="tabpanel">
                  {{ shipping_content }}
                </div>
              {%- endif -%}
            </div>

            {%- if section.settings.show_phone and phone != blank -%}
              <div class="product-usp-items-container">
                <div class="product-usp-item call-customer-service">
                  <a href="tel:{{ phone | replace: ' ', '' }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    </svg>
                    {{ phone_label }} {{ phone }}
                  </a>
                </div>
              </div>
            {%- endif -%}

            {%- if gallery_text != blank or gallery_image != blank -%}
              <div class="gallery-extension-top gallery-extension-top--mobile-only">
                {%- if gallery_text != blank -%}
                  <span class="gallery-extension-text">{{ gallery_text }}</span>
                {%- endif -%}
                {%- if gallery_image != blank -%}
                  <div class="gallery-extension-image">
                    {{
                      gallery_image
                      | image_url: width: 900
                      | image_tag:
                        loading: 'lazy',
                        class: 'cld-responsive',
                        alt: product.title
                    }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  {%- if section.settings.show_mobile_sticky_bar -%}
    <div class="gj-mobile-atc-bar" aria-hidden="true">
      {% comment %} <span class="price-sales" data-gj-mobile-price>{{ current_variant.price | money_without_trailing_zeros }}</span> {% endcomment %}
      <button
        type="button"
        class="button-fancy-large add-to-cart"
        data-gj-mobile-atc
        data-gj-atc
        {% if current_variant.available == false %}disabled{% endif %}
      >
        <span data-gj-atc-label>
          {%- if current_variant.available -%}{{ atc_label }}{%- else -%}{{ section.settings.sold_out_label }}{%- endif -%}
        </span>
      </button>
    </div>
  {%- endif -%}
</div>

