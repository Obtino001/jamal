      "id": "menu_2_heading",
      "label": "Menu 2 heading",
      "default": "More from Georg Jensen"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu 2"
    },
    {
      "type": "text",
      "id": "menu_3_heading",
      "label": "Menu 3 heading",
      "default": "Corporate info"
    },
    {
      "type": "link_list",
