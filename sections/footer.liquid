      "default": "Copyright © Georg Jensen."
    },
    {
      "type": "image_picker",
      "id": "crest_image",
      "label": "Crest / logo image"
    },
    {
      "type": "text",
      "id": "crest_line_1",
      "label": "Crest line 1",
      "default": "BY APPOINTMENT TO"
    },
    {
      "type": "text",
      "id": "crest_line_2",
      "label": "Crest line 2",
      "default": "HER MAJESTY THE QUEEN OF DENMARK"
    },
    {
      "type": "text",
      "id": "crest_brand",
      "label": "Crest brand",
      "default": "GEORG JENSEN"
    },
    {
      "type": "text",
      "id": "crest_sub",
      "label": "Crest subline",
      "default": "ESTABLISHED 1904"
    },
    {
      "type": "header",
      "content": "Back to top"
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Show back to top button",
      "default": true
    },
    {
      "type": "text",
      "id": "back_to_top_label",
      "label": "Back to top label",
      "default": "Back to top"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Online Shopping"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "textarea",
          "id": "fallback_links",
          "label": "Fallback links",
          "info": "One per line: Label|/path (used if no menu selected)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Footer"
    }
  ]
