      "info": "Comma-separated: mastercard, maestro, visa, amex, paypal, google-pay, apple-pay, shop-pay",
      "default": "mastercard,maestro,visa,amex,paypal,google-pay,apple-pay,shop-pay"
    },
    {
      "type": "image_picker",
