</footer>

<style>
  .sitecore-signup-footer {
    padding: 50px 0;
    font-family: var(--georg-font-sans);
  }

  .sitecore-signup-footer-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .sitecore-signup-footer-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 60px;
  }

  .footer-signup-left-pane {
    flex: 0 0 42%;
  }

  .footer-signup-left-pane h2 {
    font-size: 34px;
    font-weight: 400;
    margin: 0 0 24px 0;
    color: #ffffff;
  }

  .user-cta-footer {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .button-georg-signup {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #8ed0f8;
    color: #111111;
    padding: 12px 32px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 0;
    transition: background 0.2s;
  }

  .button-georg-signup:hover {
    background-color: #79c4f0;
  }

  .login-prompt-span {
    font-size: 13px;
    color: #cccccc;
  }

  .footer-login-inline-link {
    color: #ffffff;
    text-decoration: underline;
    margin-left: 4px;
  }

  .footer-signup-right-pane {
    flex: 0 0 52%;
  }

  .footer-signup-right-pane h2 {
    font-size: 20px;
    font-weight: 400;
    margin: 0 0 20px 0;
    color: #ffffff;
  }

  .usp {
    list-style: none;
    padding: 0;
    margin: 0 0 16px 0;
    display: flex;
    gap: 24px;
  }

  .usp li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: #dddddd;
  }

  .usp-disclaimer {
    display: block;
    font-size: 10px;
    line-height: 1.5;
    color: #999999;
  }

  .footer-container-wrap {
    padding: 60px 0 40px 0;
    font-family: var(--georg-font-sans);
    border-top: 1px solid rgba(255,255,255,0.1);
  }

  .footer-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 30px;
    display: grid;
    grid-template-columns: 1fr 2.4fr 1.2fr;
    gap: 50px;
  }

  .georg-country-dropdown {
    background: #111720;
    color: #ffffff;
    border: 1px solid #333333;
    padding: 8px 14px;
    font-size: 12px;
    width: 160px;
    margin-bottom: 30px;
    outline: none;
  }

  .footer-item h3, .footer-item h4 {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: #ffffff;
    margin: 0 0 14px 0;
  }

  .footer-item .phone a {
    font-size: 22px;
    color: #ffffff;
    text-decoration: none;
    font-weight: 300;
  }

  .footer-item .hours {
    font-size: 11px;
    color: #aaaaaa;
    margin: 6px 0;
  }

  .footer-item .email {
    font-size: 12px;
    color: #ffffff;
    text-decoration: underline;
  }

  .footer-col2 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }

  .menu-footer {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .menu-footer a {
    font-size: 12px;
    color: #bbbbbb;
    text-decoration: none;
    transition: color 0.2s;
  }

  .menu-footer a:hover {
    color: #ffffff;
  }

  .payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 24px;
  }

  .payment-badge {
    background: #ffffff;
    color: #111111;
    font-size: 9px;
    font-weight: 700;
    padding: 4px 6px;
    border-radius: 2px;
  }

  .social-links-list {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
    display: flex;
    gap: 16px;
  }

  .social-links-list a {
    color: #ffffff;
    transition: opacity 0.2s;
  }

  .social-links-list a:hover {
    opacity: 0.7;
  }

  .copyright {
    font-size: 11px;
    color: #888888;
    margin-bottom: 30px;
  }

  .footer-logo-crest {
    text-align: right;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 20px;
  }

  .crest-text-small {
    font-size: 8px;
    letter-spacing: 0.2em;
    color: #888888;
  }

  .crest-brand-name {
    font-family: var(--georg-font-serif);
    font-size: 18px;
    letter-spacing: 0.25em;
    color: #ffffff;
    margin-top: 4px;
  }

  .crest-sub {
    font-size: 8px;
    letter-spacing: 0.3em;
    color: #888888;
  }

  @media screen and (max-width: 989px) {
    .sitecore-signup-footer-row {
      flex-direction: column;
    }
    .footer-container {
      grid-template-columns: 1fr;
    }
    .footer-col2 {
      grid-template-columns: 1fr;
    }
    .footer-logo-crest {
      text-align: left;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_member_banner",
      "label": "Show Member Banner",
      "default": true
    },
    {
      "type": "color",
      "id": "banner_bg",
      "label": "Member Banner Background",
      "default": "#1b2430"
    },
    {
      "type": "text",
      "id": "member_heading",
      "label": "Member Banner Heading",
      "default": "Bliv medlem af Georg Jensen"
    },
    {
      "type": "text",
      "id": "register_button_text",
      "label": "Register Button Label",
      "default": "Tilmeld"
    },
    {
      "type": "url",
      "id": "register_url",
      "label": "Register URL"
    },
    {
      "type": "text",
      "id": "benefits_heading",
      "label": "Benefits Heading",
      "default": "Få eksklusive medlemsfordele allerede i dag"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "*Rabatkoden kan ikke bruges på gavekort, sølvhåndværk, produktsæt, custom smykker samt kombineres med øvrige rabatter og kampagner. Koden er gyldig i 30 dage."
    },
    {
      "type": "color",
      "id": "footer_bg",
      "label": "Footer Main Background",
      "default": "#161e27"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support Heading",
      "default": "Kundeservice"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone Number",
      "default": "+45 38 14 90 44"
    },
    {
      "type": "text",
      "id": "opening_hours",
      "label": "Opening Hours",
      "default": "Mandag, tirsdag, torsdag og fredag: 10.00–12.00"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support Email",
      "default": "onlinestore@georgjensen.com"
    },
    {
      "type": "url",
      "id": "withdraw_url",
      "label": "Withdraw Contract Link URL"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation Linklist Column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column Heading",
          "default": "Online Shopping"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Menu Linklist"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": { "heading": "Online Shopping" }
