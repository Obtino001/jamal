{{ 'georg-jensen-footer.css' | asset_url | stylesheet_tag }}
<script src="{{ 'georg-jensen-footer.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign menu_1 = linklists[section.settings.menu_1]
  assign menu_2 = linklists[section.settings.menu_2]
  assign menu_3 = linklists[section.settings.menu_3]
-%}

<div
  class="gj-footer"
  style="
    --gj-f-bg: {{ section.settings.footer_bg }};
    --gj-f-banner: {{ section.settings.banner_bg }};
    --gj-f-text: {{ section.settings.footer_text_color }};
    --gj-f-heading: {{ section.settings.heading_color }};
    --gj-f-accent: {{ section.settings.accent_color }};
  "
>
  {%- if section.settings.show_member_banner -%}
    <section class="gj-footer__member" aria-label="{{ section.settings.member_heading | escape }}">
      <div class="gj-footer__inner">
        <div class="gj-footer__member-row">
          <div>
            <h2 class="gj-footer__member-title">{{ section.settings.member_heading }}</h2>
            <div class="gj-footer__member-cta">
              <a
                class="gj-footer__signup"
                href="{{ section.settings.register_url | default: routes.account_register_url }}"
              >
                {{ section.settings.register_button_text }}
              </a>
              <span class="gj-footer__login-prompt">
                {{ section.settings.login_prompt_text }}
                <a href="{{ section.settings.login_url | default: routes.account_login_url }}">
                  {{- section.settings.login_link_text -}}
                </a>
              </span>
            </div>
          </div>

          <div>
            <h3 class="gj-footer__benefits-title">{{ section.settings.benefits_heading }}</h3>
            <ul class="gj-footer__usps">
              {%- if section.settings.usp_1_text != blank -%}
                <li class="gj-footer__usp">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M1 7h11v8H1z"/>
                    <path d="M12 10h4l3 3v2h-7V10z"/>
                    <circle cx="5.5" cy="17.5" r="1.8"/>
                    <circle cx="16.5" cy="17.5" r="1.8"/>
                  </svg>
                  <span>{{ section.settings.usp_1_text }}</span>
                </li>
              {%- endif -%}
              {%- if section.settings.usp_2_text != blank -%}
                <li class="gj-footer__usp">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.6 13.4 12 22l-8.6-8.6A4 4 0 0 1 9 6.2L12 9l3-2.8a4 4 0 0 1 5.6 7.2z"/>
                    <circle cx="8.2" cy="8.2" r="1"/>
                  </svg>
                  <span>{{ section.settings.usp_2_text }}</span>
                </li>
              {%- endif -%}
              {%- if section.settings.usp_3_text != blank -%}
                <li class="gj-footer__usp">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <circle cx="12" cy="12" r="9"/>
                    <path d="M12 11v5"/>
                    <circle cx="12" cy="8" r="0.8" fill="currentColor" stroke="none"/>
                  </svg>
                  <span>{{ section.settings.usp_3_text }}</span>
                </li>
              {%- endif -%}
            </ul>
            {%- if section.settings.disclaimer_text != blank -%}
              <span class="gj-footer__disclaimer">{{ section.settings.disclaimer_text }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  <footer class="gj-footer__main">
    <div class="gj-footer__inner">
      <div class="gj-footer__grid">
        <div>
          {%- if section.settings.show_country_selector -%}
            <label class="visually-hidden" for="gj-footer-country">Country</label>
            <select id="gj-footer-country" class="gj-footer__country" name="gj-footer-country">
              <option selected>{{ section.settings.default_country }}</option>
              {%- if section.settings.country_options != blank -%}
                {%- assign countries = section.settings.country_options | split: ',' -%}
                {%- for country in countries -%}
                  {%- assign c = country | strip -%}
                  {%- if c != blank and c != section.settings.default_country -%}
                    <option>{{ c }}</option>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </select>
          {%- endif -%}

          <p class="gj-footer__service-label">{{ section.settings.support_heading }}</p>
          {%- if section.settings.phone_number != blank -%}
            <p class="gj-footer__phone">
              <a href="tel:{{ section.settings.phone_number | replace: ' ', '' | replace: '–', '' }}">
                {{ section.settings.phone_number }}
              </a>
            </p>
          {%- endif -%}
          {%- if section.settings.opening_hours != blank -%}
            <p class="gj-footer__hours">{{ section.settings.opening_hours }}</p>
          {%- endif -%}
          {%- if section.settings.support_email != blank -%}
            <a class="gj-footer__email" href="mailto:{{ section.settings.support_email }}">
              {{ section.settings.support_email }}
            </a>
          {%- endif -%}
        </div>

        <div class="gj-footer__menus">
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'menu' -%}
                <div {{ block.shopify_attributes }}>
                  {%- if block.settings.heading != blank -%}
                    <h4 class="gj-footer__menu-title">{{ block.settings.heading }}</h4>
                  {%- endif -%}
                  {%- assign block_menu = linklists[block.settings.menu] -%}
                  <ul class="gj-footer__menu">
                    {%- if block_menu != blank and block_menu.links.size > 0 -%}
                      {%- for link in block_menu.links -%}
                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                      {%- endfor -%}
                    {%- elsif block.settings.fallback_links != blank -%}
                      {%- assign lines = block.settings.fallback_links | newline_to_br | split: '<br />' -%}
                      {%- for line in lines -%}
                        {%- assign clean = line | strip -%}
                        {%- if clean != blank -%}
                          {%- assign parts = clean | split: '|' -%}
                          <li>
                            <a href="{{ parts[1] | default: '#' | strip }}">{{ parts[0] | strip }}</a>
                          </li>
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}
                  </ul>
                </div>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            <div>
              <h4 class="gj-footer__menu-title">{{ section.settings.menu_1_heading }}</h4>
              <ul class="gj-footer__menu">
                {%- if menu_1 != blank and menu_1.links.size > 0 -%}
                  {%- for link in menu_1.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                {%- else -%}
                  <li><a href="/pages/contact">Contact Us</a></li>
                  <li><a href="/pages/terms-and-conditions">Terms and Conditions</a></li>
                  <li><a href="/pages/shipping">Shipping</a></li>
                  <li><a href="/pages/exchanges-and-returns">Exchanges and Returns</a></li>
                  <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
                  <li><a href="/policies/privacy-policy">Cookie Policy</a></li>
                  <li><a href="/pages/terms-of-membership">Terms of Membership</a></li>
                  <li><a href="/pages/faq">Frequently Asked Questions</a></li>
                  <li><a href="/products/gift-card">Gift Card</a></li>
                {%- endif -%}
              </ul>
            </div>

            <div>
              <h4 class="gj-footer__menu-title">{{ section.settings.menu_2_heading }}</h4>
              <ul class="gj-footer__menu">
                {%- if menu_2 != blank and menu_2.links.size > 0 -%}
                  {%- for link in menu_2.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                {%- else -%}
                  <li><a href="{{ routes.account_url }}">My Georg Jensen</a></li>
                  <li><a href="/pages/store-locator">Find Store</a></li>
                  <li><a href="/pages/food-safety">Food Safety Declaration</a></li>
                  <li><a href="/pages/product-care-jewellery">Product Care Jewellery</a></li>
                  <li><a href="/pages/product-care-home">Product Care Home</a></li>
                  <li><a href="/pages/breakage-warranty">Breakage Warranty</a></li>
                  <li><a href="/pages/diamonds-and-materials">Diamonds and Materials</a></li>
                  <li><a href="/pages/repairs">Jewellery and Watch Repairs</a></li>
                {%- endif -%}
              </ul>
            </div>

            <div>
              <h4 class="gj-footer__menu-title">{{ section.settings.menu_3_heading }}</h4>
              <ul class="gj-footer__menu">
                {%- if menu_3 != blank and menu_3.links.size > 0 -%}
                  {%- for link in menu_3.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                {%- else -%}
                  <li><a href="/pages/about">About Georg Jensen</a></li>
                  <li><a href="/pages/careers">Careers</a></li>
                  <li><a href="/pages/sustainability">Sustainability</a></li>
                  <li><a href="/pages/csr">Corporate Social Responsibility</a></li>
                  <li><a href="/pages/press">Press</a></li>
                  <li><a href="/pages/investor-relations">Investor Relations</a></li>
                {%- endif -%}
              </ul>
            </div>
          {%- endif -%}
        </div>

        <div>
          {%- if section.settings.show_payment_badges -%}
            <div class="gj-footer__payments" aria-label="Payment methods">
             <div class="footer-misc">
<div class="payment-icons">
<img loading="eager" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dw2e37d150/payment_icons/maestro.png" fetchpriority="high"> alt="maestro"&gt;
<img loading="lazy" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dw490e2e2d/payment_icons/mastercard.png"> alt="mastercard"&gt;
<img loading="lazy" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dwa5522949/payment_icons/visa.png"> alt="visa"&gt; 
<img loading="lazy" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dwace3538d/payment_icons/american express.png"> alt="american express"&gt;
<img loading="lazy" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dwb2ba9920/payment_icons/ppc-acceptance-small.png"> alt="PayPal"&gt;
<img loading="lazy" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dwa24664b4/payment_icons/paywithgoogle.png"> alt="google pay"&gt;
<img loading="lazy" src="https://www.georgjensen.com/on/demandware.static/-/Sites-GeorgJensen_Global-Library/default/dw3229d801/payment_icons/apple_pay.png"> alt="apple pay"&gt;
</div>
<div class="footer-item social-links">
<div class="footer-item">
<ul class="social-links">
	<li><a class="fa fa-facebook-square fa-3x" href="https://www.facebook.com/georgjensen/" target="_blank" title="Go to Facebook"><span class="visually-hidden">Facebook</span></a></li>
	<li><a class="fa fa-instagram-square fa-3x" href="https://www.instagram.com/georgjensen/" target="_blank" title="Go to Instagram"><span class="visually-hidden">Instagram</span></a></li>
	<li><a class="fa fa-twitter-square fa-3x" href="https://twitter.com/georgjensen/" target="_blank" title="Go to Twitter"><span class="visually-hidden">Twitter</span></a></li>
	<li><a class="fa fa-pinterest-square fa-3x" href="https://www.pinterest.com/GeorgJensen/" target="_blank" title="Go to Pinterest"><span class="visually-hidden">Pinterest</span></a></li>
</ul>
</div>
</div>
<div class="copyright">Copyright © Georg Jensen.</div>
</div>

          <p class="gj-footer__copy">{{ section.settings.copyright_text }}</p>

          <div class="gj-footer__crest">
            {%- if section.settings.crest_image != blank -%}
              {{
                section.settings.crest_image
                | image_url: width: 240
                | image_tag:
                  class: 'gj-footer__crest-img',
                  loading: 'lazy',
                  widths: '110, 160, 220',
                  width: 110,
                  alt: shop.name
              }}
            {%- else -%}
              <img
                class="gj-footer__crest-svg"
                src="{{ 'gj-crest.svg' | asset_url }}"
                alt="{{ shop.name | escape }}"
                width="110"
                height="82"
                loading="lazy"
              >
            {%- endif -%}
            {%- if section.settings.crest_line_1 != blank -%}
              <span class="gj-footer__crest-line">{{ section.settings.crest_line_1 }}</span>
            {%- endif -%}
            {%- if section.settings.crest_line_2 != blank -%}
              <span class="gj-footer__crest-line">{{ section.settings.crest_line_2 }}</span>
            {%- endif -%}
            {%- if section.settings.crest_brand != blank -%}
              <span class="gj-footer__crest-brand">{{ section.settings.crest_brand }}</span>
            {%- endif -%}
            {%- if section.settings.crest_sub != blank -%}
              <span class="gj-footer__crest-sub">{{ section.settings.crest_sub }}</span>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </footer>

  {%- if section.settings.show_back_to_top -%}
    <button
      type="button"
      class="gj-footer__top"
      data-gj-back-top
      aria-label="{{ section.settings.back_to_top_label | escape }}"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M6 14l6-6 6 6"/>
      </svg>
    </button>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Georg Jensen Footer",
  "settings": [
    {
      "type": "header",
      "content": "Member banner"
    },
    {
      "type": "checkbox",
      "id": "show_member_banner",
      "label": "Show member banner",
      "default": true
    },
    {
      "type": "color",
      "id": "banner_bg",
      "label": "Banner background",
      "default": "#1a2533"
    },
    {
      "type": "text",
      "id": "member_heading",
      "label": "Member heading",
      "default": "Become a Georg Jensen member"
    },
    {
      "type": "text",
      "id": "register_button_text",
      "label": "Sign up button",
      "default": "SIGN UP"
    },
    {
      "type": "url",
      "id": "register_url",
      "label": "Sign up URL"
    },
    {
      "type": "text",
      "id": "login_prompt_text",
      "label": "Login prompt",
      "default": "Already have an account?"
    },
    {
      "type": "text",
      "id": "login_link_text",
      "label": "Login link text",
      "default": "Login"
    },
    {
      "type": "url",
      "id": "login_url",
      "label": "Login URL"
    },
    {
      "type": "text",
      "id": "benefits_heading",
      "label": "Benefits heading",
      "default": "Join us and discover a world of exclusive benefits today"
    },
    {
      "type": "text",
      "id": "usp_1_text",
      "label": "Benefit 1",
      "default": "Save shipping information"
    },
    {
      "type": "text",
      "id": "usp_2_text",
      "label": "Benefit 2",
      "default": "10% discount on first order"
    },
    {
      "type": "text",
      "id": "usp_3_text",
      "label": "Benefit 3",
      "default": "News and exclusive offers"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer",
      "default": "*The voucher code cannot be used on gift cards, silver craftsmanship, product sets, custom jewellery or combined with other discounts and campaigns. The code is valid for 30 days."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "footer_bg",
      "label": "Footer background",
      "default": "#1a2533"
    },
    {
      "type": "color",
      "id": "footer_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Column heading color",
      "default": "#9fd6f5"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Sign up button color",
      "default": "#b6e3ff"
    },
    {
      "type": "header",
      "content": "Customer service"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "Show country selector",
      "default": true
    },
    {
      "type": "text",
      "id": "default_country",
      "label": "Default country label",
      "default": "Other countries"
    },
    {
      "type": "text",
      "id": "country_options",
      "label": "Extra countries (comma-separated)",
      "default": "Denmark, Sweden, Norway, Germany, United Kingdom, USA & Canada, Australia"
    },
    {
      "type": "text",
      "id": "support_heading",
      "label": "Support heading",
      "default": "Customer Service"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone",
      "default": "+45 38 14 90 44"
    },
    {
      "type": "text",
      "id": "opening_hours",
      "label": "Opening hours",
      "default": "Monday, Tuesday, Thursday and Friday: 10:00–15:00 CET"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Email",
      "default": "onlinestore@georgjensen.com"
