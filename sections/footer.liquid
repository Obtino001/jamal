{% comment %}
  Georg Jensen 1-to-1 Footer Section (Dawn Theme Structure Compatible)
{% endcomment %}

<!-- Top Signup Banner -->
{%- if section.settings.show_member_banner -%}
  <div class="sitecore-signup-footer" style="background-color: {{ section.settings.banner_bg }}; color: #ffffff;">
    <div class="sitecore-signup-footer-container">
      <div class="sitecore-signup-footer-row">
        <div class="footer-signup-left-pane">
          <h2 class="georg-serif">{{ section.settings.member_heading | default: 'Bliv medlem af Georg Jensen' }}</h2>
          <div class="user-cta-footer">
            <a class="button-georg-signup" id="footer-cta-register-link" href="{{ section.settings.register_url | default: '/account/register' }}" title="Tilmeld">
              {{ section.settings.register_button_text | default: 'Tilmeld' }}
            </a>
            <span class="login-prompt-span">
              Har du allerede en konto? 
              <a href="{{ routes.account_login_url }}" class="footer-login-inline-link">Log ind</a>
            </span>
          </div>
        </div>

        <div class="footer-signup-right-pane">
          <h2 class="georg-sans-title">{{ section.settings.benefits_heading | default: 'Få eksklusive medlemsfordele allerede i dag' }}</h2> 
          <ul class="usp">
            <li>
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#8ed0f8" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>Fri fragt på alle ordrer</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#8ed0f8" stroke-width="1.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              <span>10% på din første ordre</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="#8ed0f8" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
              <span>Nyheder og eksklusive tilbud</span>
            </li>
          </ul>
          <span class="usp-disclaimer">{{ section.settings.disclaimer_text | default: '*Rabatkoden kan ikke bruges på gavekort, sølvhåndværk, produktsæt, custom smykker samt kombineres med øvrige rabatter og kampagner. Koden er gyldig i 30 dage.' }}</span>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

<!-- Main Footer Container -->
<footer class="footer-container-wrap" style="background-color: {{ section.settings.footer_bg }}; color: #ffffff;">
  <div class="footer-container">
    <!-- Col 1: Customer Service & Country -->
    <div class="footer-col1">
      <div class="language ui-front">
        <select name="countries" id="countryselector" class="georg-country-dropdown">
          <option value="DK" selected>Denmark</option>
          <option value="SE">Sweden</option>
          <option value="DE">Germany</option>
          <option value="GB">United Kingdom</option>
          <option value="NO">Norway</option>
          <option value="US">USA & Canada</option>
          <option value="AU">Australia</option>
        </select>
      </div>

      <div class="footer-item contact-info">
        <h3>{{ section.settings.support_heading | default: 'Kundeservice' }}</h3>
        <h3 class="phone"><a href="tel:004538149044">{{ section.settings.phone_number | default: '+45 38 14 90 44' }}</a></h3>
        <p class="hours">{{ section.settings.opening_hours | default: 'Mandag, tirsdag, torsdag og fredag: 10.00–12.00' }}</p>
        <a class="email" href="mailto:{{ section.settings.support_email | default: 'onlinestore@georgjensen.com' }}">{{ section.settings.support_email | default: 'onlinestore@georgjensen.com' }}</a>
      </div>

      <div class="footer-item contact-info" style="margin-top: 24px;">
        <h3>Fortrydelsesret</h3>
        <p class="hours"><a class="email" href="{{ section.settings.withdraw_url | default: '#' }}">Fortryd aftale</a></p>
      </div>
    </div>

    <!-- Col 2: Navigation Links (Customizer blocks or linklists) -->
    <div class="footer-col2">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="footer-item" {{ block.shopify_attributes }}>
            <h4 class="custom-tab">{{ block.settings.heading }}</h4>
            {%- assign menu = linklists[block.settings.menu] -%}
            {%- if menu != blank and menu.links.size > 0 -%}
              <ul class="menu-footer menu pipe">
                {%- for link in menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <!-- Default menu links -->
              <ul class="menu-footer menu pipe">
                {%- if forloop.index == 1 -%}
                  <li><a href="#">Kontakt os</a></li>
                  <li><a href="#">Handelsbetingelser</a></li>
                  <li><a href="#">Forsendelse og levering</a></li>
                  <li><a href="#">Fortrydelse og ombytning</a></li>
                  <li><a href="#">Persondatapolitik</a></li>
                  <li><a href="#">Cookiepolitik</a></li>
                  <li><a href="#">Medlemsbetingelser</a></li>
                  <li><a href="#">Ofte stillede spørgsmål</a></li>
                  <li><a href="#">Gavekort</a></li>
                {%- elsif forloop.index == 2 -%}
                  <li><a href="#">Mit Georg Jensen</a></li>
                  <li><a href="#">Firmagaver</a></li>
                  <li><a href="#">Find butik</a></li>
                  <li><a href="#">Fødevarestyrelsens kontrolrapporter</a></li>
                  <li><a href="#">Overensstemmelseserklæring</a></li>
                  <li><a href="#">Forhandlersite (kræver login)</a></li>
                  <li><a href="#">Brudgaranti</a></li>
                  <li><a href="#">Produktpleje smykker</a></li>
                  <li><a href="#">Produktpleje bolig</a></li>
                  <li><a href="#">Diamanter og materialer</a></li>
                  <li><a href="#">Smykke- og ur reparationer</a></li>
                {%- else -%}
                  <li><a href="/pages/about">Om Georg Jensen</a></li>
                  <li><a href="#">Karriere</a></li>
                  <li><a href="#">Bæredygtighed</a></li>
                  <li><a href="#">Corporate Social Responsibility</a></li>
                  <li><a href="#">Presse</a></li>
                  <li><a href="#">Investor relations</a></li>
                {%- endif -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback 3 columns -->
        <div class="footer-item">
          <h4 class="custom-tab">Online Shopping</h4>
          <ul class="menu-footer menu pipe">
            <li><a href="#">Kontakt os</a></li>
            <li><a href="#">Handelsbetingelser</a></li>
            <li><a href="#">Forsendelse og levering</a></li>
            <li><a href="#">Fortrydelse og ombytning</a></li>
            <li><a href="#">Persondatapolitik</a></li>
            <li><a href="#">Cookiepolitik</a></li>
            <li><a href="#">Medlemsbetingelser</a></li>
            <li><a href="#">Ofte stillede spørgsmål</a></li>
            <li><a href="#">Gavekort</a></li>
          </ul>
        </div>
        <div class="footer-item">
          <h4 class="custom-tab">Mere fra Georg Jensen</h4>
          <ul class="menu-footer menu pipe">
            <li><a href="#">Mit Georg Jensen</a></li>
            <li><a href="#">Firmagaver</a></li>
            <li><a href="#">Find butik</a></li>
            <li><a href="#">Fødevarestyrelsens kontrolrapporter</a></li>
            <li><a href="#">Overensstemmelseserklæring</a></li>
            <li><a href="#">Forhandlersite (kræver login)</a></li>
            <li><a href="#">Brudgaranti</a></li>
            <li><a href="#">Produktpleje smykker</a></li>
            <li><a href="#">Produktpleje bolig</a></li>
            <li><a href="#">Diamanter og materialer</a></li>
            <li><a href="#">Smykke- og ur reparationer</a></li>
          </ul>
        </div>
        <div class="footer-item">
          <h4 class="custom-tab">Firmainfo</h4>
          <ul class="menu-footer menu pipe">
            <li><a href="/pages/about">Om Georg Jensen</a></li>
            <li><a href="#">Karriere</a></li>
            <li><a href="#">Bæredygtighed</a></li>
            <li><a href="#">Corporate Social Responsibility</a></li>
            <li><a href="#">Presse</a></li>
            <li><a href="#">Investor relations</a></li>
          </ul>
        </div>
      {%- endif -%}
    </div>

    <!-- Col 3: Payment Icons, Socials, Copyright, Crest Logo -->
    <div class="footer-col3">
      <div class="payment-icons">
        <span class="payment-badge">VISA</span>
        <span class="payment-badge">MAESTRO</span>
        <span class="payment-badge">MASTERCARD</span>
        <span class="payment-badge">AMEX</span>
        <span class="payment-badge">KLARNA</span>
        <span class="payment-badge">MOBILEPAY</span>
        <span class="payment-badge">PAYPAL</span>
        <span class="payment-badge">G PAY</span>
        <span class="payment-badge">APPLE PAY</span>
      </div>

      <div class="footer-item social-links">
