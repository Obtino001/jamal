{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .designer-spotlight {
    display: flex;
    flex-direction: column;
  }

  .designer-spotlight__grid {
    margin: 0;
    width: 100%;
    /* Override default dawn grid gap for flush layout */
    gap: 0 !important; 
  }

  .designer-spotlight__media-item {
    padding: 0;
    position: relative;
    min-height: 400px;
  }

  .designer-spotlight__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .designer-spotlight__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .designer-spotlight__text-item {
    display: flex;
    align-items: center;
    padding: 4rem 2rem;
  }

  @media screen and (min-width: 750px) {
    .designer-spotlight__text-item {
      padding: 6rem 8rem;
    }
    .designer-spotlight__media-item {
      min-height: 550px;
    }
  }

  .designer-spotlight__content {
    max-width: 500px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .designer-spotlight__caption {
    font-size: 1rem;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.7);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .designer-spotlight__heading {
    margin-top: 0;
    margin-bottom: 2rem;
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 3.6rem);
    line-height: 1.2;
    font-weight: 400;
    color: rgb(var(--color-foreground));
  }

  .designer-spotlight__text {
    font-size: 1.4rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground));
    margin-bottom: 3.5rem;
  }

  .designer-spotlight__link {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.4rem;
    text-decoration-thickness: 0.1rem;
    color: rgb(var(--color-foreground));
    transition: opacity 0.2s ease;
  }

  .designer-spotlight__link:hover {
    opacity: 0.7;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="page-width{% if section.settings.full_width %} page-width--narrow{% endif %}">
    <div class="designer-spotlight">
      <div class="grid grid--1-col grid--2-col-tablet designer-spotlight__grid {% if section.settings.layout == 'text_first' %} grid--reverse{% endif %}">
        
        <!-- Media Column -->
        <div class="grid__item designer-spotlight__media-item">
          <div class="designer-spotlight__media">
            {%- if section.settings.image != blank -%}
              {{ section.settings.image | image_url: width: 1500 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '375, 550, 750, 1100, 1500',
                alt: section.settings.image.alt | escape
              }}
            {%- else -%}
              <!-- Fallback to reference image name if no image selected -->
              {{ 'image_d16589.jpg' | asset_url | img_tag: 'Designer Spotlight', 'designer-spotlight-placeholder' }}
            {%- endif -%}
          </div>
        </div>

        <!-- Text Column -->
        <div class="grid__item designer-spotlight__text-item color-{{ section.settings.color_scheme }} gradient">
          <div class="designer-spotlight__content">
            {%- for block in section.blocks -%}
              {% case block.type %}
                {%- when 'caption' -%}
                  <div class="designer-spotlight__caption" {{ block.shopify_attributes }}>
                    {{ block.settings.text | escape }}
                  </div>
                
                {%- when 'heading' -%}
                  <h2 class="designer-spotlight__heading" {{ block.shopify_attributes }}>
                    {{ block.settings.heading | escape }}
                  </h2>
                
                {%- when 'text' -%}
                  <div class="designer-spotlight__text rte" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                
                {%- when 'link' -%}
                  {%- if block.settings.link_label != blank -%}
                    <a {% if block.settings.link_url == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.link_url }}"{% endif %} class="designer-spotlight__link" {{ block.shopify_attributes }}>
                      {{ block.settings.link_label | escape }}
                    </a>
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Designer Spotlight",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Upload or select an image. Reference: image_d16589.jpg"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first",
      "label": "Desktop layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "Make section full width",
      "info": "Removes standard page-width constraints."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Text block color scheme",
      "default": "background-2"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "caption",
      "name": "Caption",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Meet the designer",
          "label": "Caption text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Georg Jensen Design Studio",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Rooted in the house's century-long heritage, the Georg Jensen Design Studio upholds the superior craftsmanship and innovation that have defined Georg Jensen since its foundation in 1904.</p>",
          "label": "Description"
        }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "link_label",
          "default": "Find out more",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Designer Spotlight",
      "blocks": [
        {
          "type": "caption"
        },
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "link"
        }
      ]
    }
  ]
}
{% endschema %}