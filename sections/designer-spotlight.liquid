{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* 1:1 Layout Structure */
  .designer-spotlight-{{ section.id }} {
    display: flex;
    flex-direction: column;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .designer-spotlight-{{ section.id }} {
      flex-direction: row;
    }
    .designer-spotlight-{{ section.id }}--reverse {
      flex-direction: row-reverse;
    }
  }

  .designer-spotlight__media-item,
  .designer-spotlight__text-item {
    flex: 1;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .designer-spotlight__media-item,
    .designer-spotlight__text-item {
      width: 50%;
    }
  }

  /* Image Area */
  .designer-spotlight__media-item {
    position: relative;
    min-height: 400px;
  }

  .designer-spotlight__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .designer-spotlight__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Text Area */
  .designer-spotlight__text-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 3rem;
  }

  @media screen and (min-width: 750px) {
    .designer-spotlight__text-item {
      padding: 8rem 6rem;
    }
  }

  @media screen and (min-width: 990px) {
    .designer-spotlight__text-item {
      padding: 10rem 8rem;
    }
  }

  .designer-spotlight__content {
    max-width: 480px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Typography */
  .designer-spotlight__caption {
    font-size: 1rem;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    color: {{ section.settings.caption_color }};
    margin-bottom: 2rem;
    font-weight: 600;
  }

  .designer-spotlight__heading {
    margin-top: 0;
    margin-bottom: 2.5rem;
    font-family: var(--font-heading-family);
    font-size: clamp(2.8rem, 4vw, 4.2rem);
    line-height: 1.25;
    font-weight: 400;
    color: {{ section.settings.heading_color }};
  }

  .designer-spotlight__text {
    font-size: 1.4rem;
    line-height: 1.7;
    color: {{ section.settings.text_color }};
    margin-bottom: 4rem;
  }

  .designer-spotlight__text p {
    margin: 0;
  }

  .designer-spotlight__link {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.15rem;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
    text-decoration: none;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid {{ section.settings.heading_color }};
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .designer-spotlight__link:hover {
    opacity: 0.7;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="page-width{% if section.settings.full_width %} page-width--narrow{% endif %}">
    
    <div class="designer-spotlight-{{ section.id }} {% if section.settings.layout == 'text_first' %} designer-spotlight-{{ section.id }}--reverse{% endif %}">
      
      <!-- Media Column -->
      <div class="designer-spotlight__media-item">
        <div class="designer-spotlight__media">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1500 | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 750px) 50vw, 100vw',
              widths: '375, 550, 750, 1100, 1500',
              alt: section.settings.image.alt | escape
            }}
          {%- else -%}
            {{ 'image_3e587b.jpg' | asset_url | img_tag: 'Designer Spotlight', 'designer-spotlight-placeholder' }}
          {%- endif -%}
        </div>
      </div>

      <!-- Text Column -->
      <div class="designer-spotlight__text-item">
        <div class="designer-spotlight__content">
          {%- for block in section.blocks -%}
            {% case block.type %}
              
              {%- when 'caption' -%}
                <div class="designer-spotlight__caption" {{ block.shopify_attributes }}>
                  {{ block.settings.text | escape }}
                </div>
              
              {%- when 'heading' -%}
                <h2 class="designer-spotlight__heading" {{ block.shopify_attributes }}>
                  {{ block.settings.heading | escape | newline_to_br }}
                </h2>
              
              {%- when 'text' -%}
                <div class="designer-spotlight__text rte" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </div>
              
              {%- when 'link' -%}
                {%- if block.settings.link_label != blank -%}
                  <a {% if block.settings.link_url == blank %} role="link" aria-disabled="true"{% else %} href="{{ block.settings.link_url }}"{% endif %} class="designer-spotlight__link" {{ block.shopify_attributes }}>
                    {{ block.settings.link_label | escape }}
                  </a>
                {%- endif -%}
                
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Designer Spotlight",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "image_first",
          "label": "Image first"
        },
        {
          "value": "text_first",
          "label": "Text first"
        }
      ],
      "default": "image_first",
      "label": "Desktop layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "Make section full width"
    },
    {
      "type": "header",
      "content": "Colors (1:1 Match Settings)"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Text Background",
      "default": "#F4F3F1",
      "info": "Reference light beige."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading & Link Color",
      "default": "#1C2633",
      "info": "Reference dark slate/navy."
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption Color",
      "default": "#8C8681",
      "info": "Reference warm taupe/grey."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color",
      "default": "#1A1A1A"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "caption",
      "name": "Caption",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Meet the designer",
          "label": "Caption text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "default": "Georg Jensen\nDesign Studio",
          "label": "Heading",
          "info": "Use line breaks to force text onto a new line like the reference."
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Rooted in the house's century-long heritage, the Georg Jensen Design Studio upholds the superior craftsmanship and innovation that have defined Georg Jensen since its foundation in 1904.</p>",
          "label": "Description"
        }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "link_label",
          "default": "Find out more",
          "label": "Link label"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Designer Spotlight",
      "blocks": [
        {
          "type": "caption"
        },
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "link"
        }
      ]
    }
  ]
}
{% endschema %}