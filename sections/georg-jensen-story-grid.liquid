{% comment %}
  Georg Jensen Story Grid Section ("Bliv inspireret") - Fully Theme Customizer Editable
{% endcomment %}

<div class="georg-story-grid-section section-{{ section.id }}">
  <div class="georg-container">
    {%- if section.settings.section_title != blank -%}
      <div class="georg-section-header-wrap">
        <h2 class="georg-section-title georg-serif" style="color: {{ section.settings.title_color }}; font-size: {{ section.settings.title_size }}px;">
          {{ section.settings.section_title }}
        </h2>
      </div>
    {%- endif -%}

    <div class="georg-story-grid" style="grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);">
      {%- for block in section.blocks -%}
        <div class="georg-story-card" {{ block.shopify_attributes }}>
          <div class="georg-story-media-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" class="georg-story-img">
            {%- elsif forloop.index == 1 -%}
              <img src="{{ 'GJ_SS26_Seasonal_JW_eCOM_storytile_410x410_131600.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="georg-story-img">
            {%- elsif forloop.index == 2 -%}
              <img src="{{ 'GJ_SS26_Seasonal_JW_eCOM_storytile_410x410_61600.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="georg-story-img">
            {%- else -%}
              <img src="{{ 'Menu_Tile_SS26_Home4190_190_190.jpg' | asset_url }}" alt="{{ block.settings.title | escape }}" class="georg-story-img">
            {%- endif -%}
          </div>

          <div class="georg-story-content">
            {%- if block.settings.category_tag != blank -%}
              <span class="georg-story-tag">{{ block.settings.category_tag }}</span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="georg-story-title georg-serif">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="georg-story-desc georg-sans">{{ block.settings.text }}</p>
            {%- endif -%}

            {%- if block.settings.link_label != blank -%}
              <div class="georg-story-cta">
                <a href="{{ block.settings.link_url | default: '#' }}" class="georg-link-underline">
                  {{ block.settings.link_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .georg-story-grid-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color }};
  }

  .georg-section-header-wrap {
    text-align: center;
    margin-bottom: 48px;
  }

  .georg-section-title {
    font-weight: 400;
    margin: 0;
  }

  .georg-story-grid {
    display: grid;
    gap: 32px;
  }

  .georg-story-card {
    display: flex;
    flex-direction: column;
  }

  .georg-story-media-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f8f8f8;
  }

  .georg-story-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .georg-story-card:hover .georg-story-img {
    transform: scale(1.04);
  }

  .georg-story-content {
    padding: 24px 0 0 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .georg-story-tag {
    font-family: var(--georg-font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888888;
    margin-bottom: 8px;
  }

  .georg-story-title {
    font-size: 22px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 10px 0;
    line-height: 1.3;
  }

  .georg-story-desc {
    font-size: 13px;
    line-height: 1.6;
    color: #555555;
    margin: 0 0 20px 0;
  }

  .georg-story-cta {
    margin-top: auto;
  }

  @media screen and (max-width: 989px) {
    .georg-story-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media screen and (max-width: 640px) {
    .georg-story-grid {
      grid-template-columns: 1fr !important;
      gap: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Story Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Bliv inspireret"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 50,
      "step": 2,
      "default": 34,
      "label": "Title Font Size (px)"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Desktop Columns"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 70,
      "label": "Padding Top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 70,
      "label": "Padding Bottom (px)"
    }
  ],
  "blocks": [
    {
      "type": "story_card",
      "name": "Story Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "category_tag",
          "label": "Category Tag",
          "default": "DESIGNIKONER"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Georg Jensens designikoner"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description Text",
          "default": "Udforsk vores mest elskede og ikoniske kollektioner igennem tiden."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "UDFORSK DESIGNIKONER"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Story Grid",
      "blocks": [
        {
          "type": "story_card",
          "settings": {
            "category_tag": "DESIGNIKONER",
            "title": "Georg Jensens designikoner",
            "text": "Udforsk vores mest elskede og ikoniske kollektioner igennem tiden.",
            "link_label": "UDFORSK DESIGNIKONER"
          }
        },
        {
          "type": "story_card",
          "settings": {
            "category_tag": "SOMMER 2026",
            "title": "Nye kollektioner",
            "text": "Oplev sæsonens nyeste smykke- og boligdesign fremstillet i ædle metaller.",
            "link_label": "SE NYHEDER"
          }
        },
        {
          "type": "story_card",
          "settings": {
            "category_tag": "SØLVHÅNDVÆRK",
            "title": "Tidsløst håndværk",
            "text": "Enestående håndlavede sølvarbejder skabt af mestersølvsmede i København.",
            "link_label": "UDFORSK SØLVHÅNDVÆRK"
          }
        }
      ]
    }
  ]
}
{% endschema %}
