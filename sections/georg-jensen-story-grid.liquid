{% comment %}
  Be Inspired Grid — Georg Jensen 1:1
{% endcomment %}

{%- style -%}
  .section-{{ section.id }} {
    --bi-bg: {{ section.settings.background_color }};
    --bi-card: {{ section.settings.card_background }};
    --bi-gap: {{ section.settings.card_gap }}px;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--bi-bg);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{{ 'georg-jensen-be-inspired.css' | asset_url | stylesheet_tag }}

<section class="gj-bi section-{{ section.id }}" data-gj-be-inspired>
  <div class="page-width gj-bi__inner">
    {%- if section.settings.heading != blank -%}
      <header class="gj-bi__header">
        <h2 class="gj-bi__heading">{{ section.settings.heading | escape }}</h2>
      </header>
    {%- endif -%}

    <div class="gj-bi__grid">
      {%- for block in section.blocks -%}
        <article class="gj-bi__card" {{ block.shopify_attributes }}>
          <div class="gj-bi__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  class: 'gj-bi__img',
                  widths: '400, 600, 800, 900',
                  sizes: '(min-width: 990px) 30vw, 100vw',
                  alt: block.settings.image.alt | default: block.settings.title | escape
              }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'gj-bi__placeholder' }}
            {%- endif -%}
          </div>

          <div class="gj-bi__body">
            {%- if block.settings.tag != blank -%}
              <p class="gj-bi__tag" style="color: {{ block.settings.tag_color }};">
                {{ block.settings.tag | escape }}
              </p>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="gj-bi__title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <div class="gj-bi__text">{{ block.settings.text }}</div>
            {%- endif -%}

            {%- if block.settings.button_label != blank -%}
              <a
                class="gj-bi__button"
                {% if block.settings.button_link != blank %}
                  href="{{ block.settings.button_link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                style="background-color: {{ block.settings.button_bg_color }}; color: {{ block.settings.button_text_color }};"
              >
                {{ block.settings.button_label | escape }}
              </a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Be Inspired Grid",
  "tag": "section",
  "class": "section-be-inspired",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "BE INSPIRED",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Card gap",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (square crop)"
        },
        {
          "type": "text",
          "id": "tag",
          "default": "ICONS",
          "label": "Tag"
        },
        {
          "type": "color",
          "id": "tag_color",
          "label": "Tag color",
          "default": "#5b8aa8"
        },
        {
          "type": "text",
          "id": "title",
          "default": "The House Icons",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Boasting a 120-year history of collaborations with great designers, Georg Jensen is behind some of the most iconic designs of the past century.</p>",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "DISCOVER THE ICONS",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button background",
          "default": "#aee1fd"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text",
          "default": "#1a2533"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Be Inspired Grid",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "tag": "ICONS",
            "title": "The House Icons",
            "button_label": "DISCOVER THE ICONS"
          }
        },
        {
          "type": "card",
          "settings": {
            "tag": "DISCOVER",
            "title": "Bracelets and bangles",
            "text": "<p>A selection of timeless designs created in collaboration with leading designers.</p>",
            "button_label": "EXPLORE"
          }
        },
        {
          "type": "card",
          "settings": {
            "tag": "DISCOVER",
            "title": "Silver Stacking",
            "text": "<p>It's layering season. Discover our wide-ranging designs in sterling silver.</p>",
            "button_label": "SHOP SILVER"
          }
        }
      ]
    }
  ]
}
{% endschema %}
