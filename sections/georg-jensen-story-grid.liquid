{% comment %}
  Georg Jensen Story Grid Section ("Bliv inspireret") - 1-to-1 Replica
{% endcomment %}

<div class="georg-story-grid-section">
  <div class="georg-container">
    {%- if section.settings.section_title != blank -%}
      <div class="georg-section-header-wrap">
        <h2 class="georg-section-title georg-serif">{{ section.settings.section_title }}</h2>
      </div>
    {%- endif -%}

    <div class="georg-story-grid">
      {%- for block in section.blocks -%}
        <div class="georg-story-card" {{ block.shopify_attributes }}>
          <div class="georg-story-media-wrap">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" class="georg-story-img">
            {%- else -%}
              <div class="georg-story-img-placeholder">
                <svg viewBox="0 0 450 450" width="100%" height="100%">
                  <rect width="100%" height="100%" fill="#f4f4f4"/>
                  <circle cx="225" cy="225" r="100" fill="none" stroke="#d5d5d5" stroke-width="1.5"/>
                  <text x="50%" y="50%" dominant-baseline="middle" text-anchor="middle" font-family="Montserrat" font-size="12" fill="#888" letter-spacing="2">GEORG JENSEN</text>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <div class="georg-story-content">
            {%- if block.settings.category_tag != blank -%}
              <span class="georg-story-tag">{{ block.settings.category_tag }}</span>
            {%- endif -%}

            <h3 class="georg-story-title georg-serif">{{ block.settings.title | default: 'Georg Jensens designikoner' }}</h3>

            {%- if block.settings.text != blank -%}
              <p class="georg-story-desc georg-sans">{{ block.settings.text }}</p>
            {%- endif -%}

            {%- if block.settings.link_label != blank -%}
              <div class="georg-story-cta">
                <a href="{{ block.settings.link_url | default: '#' }}" class="georg-link-underline">
                  {{ block.settings.link_label }}
                </a>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .georg-story-grid-section {
    padding: 70px 0;
    background-color: #ffffff;
  }

  .georg-section-header-wrap {
    text-align: center;
    margin-bottom: 48px;
  }

  .georg-section-title {
    font-size: 34px;
    font-weight: 400;
    color: #1a1a1a;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .georg-story-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .georg-story-card {
    display: flex;
    flex-direction: column;
  }

  .georg-story-media-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f8f8f8;
  }

  .georg-story-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .georg-story-card:hover .georg-story-img {
    transform: scale(1.04);
  }

  .georg-story-content {
    padding: 24px 0 0 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .georg-story-tag {
    font-family: var(--georg-font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888888;
    margin-bottom: 8px;
  }

  .georg-story-title {
    font-size: 22px;
    font-weight: 400;
    color: #111111;
    margin: 0 0 10px 0;
    line-height: 1.3;
  }

  .georg-story-desc {
    font-size: 13px;
    line-height: 1.6;
    color: #555555;
    margin: 0 0 20px 0;
  }

  .georg-story-cta {
    margin-top: auto;
  }

  @media screen and (max-width: 989px) {
    .georg-story-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 640px) {
    .georg-story-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Story Grid",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Bliv inspireret"
    }
  ],
  "blocks": [
    {
      "type": "story_card",
      "name": "Story Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "category_tag",
          "label": "Category Tag",
          "default": "DESIGNIKONER"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Georg Jensens designikoner"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description Text",
          "default": "Udforsk vores ikoniske kollektioner skabt af anerkendte skandinaviske designere."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "UDFORSK DESIGNIKONER"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Story Grid",
      "blocks": [
        {
          "type": "story_card",
          "settings": {
            "category_tag": "DESIGNIKONER",
            "title": "Georg Jensens designikoner",
            "text": "Udforsk vores mest elskede og ikoniske kollektioner igennem tiden.",
            "link_label": "UDFORSK DESIGNIKONER"
          }
        },
        {
          "type": "story_card",
          "settings": {
            "category_tag": "SOMMER 2026",
            "title": "Nye kollektioner",
            "text": "Oplev sæsonens nyeste smykke- og boligdesign fremstillet i ædle metaller.",
            "link_label": "SE NYHEDER"
          }
        },
        {
          "type": "story_card",
          "settings": {
            "category_tag": "SØLVHÅNDVÆRK",
            "title": "Tidsløst håndværk",
            "text": "Enestående håndlavede sølvarbejder skabt af mestersølvsmede i København.",
            "link_label": "UDFORSK SØLVHÅNDVÆRK"
          }
        }
      ]
    }
  ]
}
{% endschema %}
