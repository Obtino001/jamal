{% comment %}
  Georg Jensen Footer Section - Fully Theme Customizer Editable
{% endcomment %}

<footer class="georg-footer-wrapper">
  <!-- Member Club Banner -->
  {%- if section.settings.show_member_banner -%}
    <div class="georg-member-banner" style="background-color: {{ section.settings.member_bg }}; color: {{ section.settings.member_text_color }};">
      <div class="georg-container georg-member-inner">
        <div class="georg-member-content">
          <h3 class="georg-member-title georg-serif" style="color: {{ section.settings.member_text_color }};">{{ section.settings.member_title }}</h3>
          {%- if section.settings.member_benefits != blank -%}
            <div class="georg-member-benefits georg-sans">
              {{ section.settings.member_benefits }}
            </div>
          {%- endif -%}
        </div>

        <div class="georg-member-form-wrap">
          {%- form 'customer', class: 'georg-member-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="georg-input-group">
              <input type="email" name="contact[email]" placeholder="{{ section.settings.email_placeholder | default: 'Indtast din e-mailadresse' }}" class="georg-member-input" required>
              <button type="submit" class="button-georg-black">{{ section.settings.submit_label | default: 'TILMELD' }}</button>
            </div>
            {%- if section.settings.login_prompt != blank -%}
              <div class="georg-member-login-link">
                {{ section.settings.login_prompt }}
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Main Footer Links Grid -->
  <div class="georg-footer-main">
    <div class="georg-container">
      <div class="georg-footer-columns">
        {%- for block in section.blocks -%}
          <div class="georg-footer-col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h4 class="georg-footer-heading georg-sans">{{ block.settings.title }}</h4>
            {%- endif -%}

            {%- assign menu = linklists[block.settings.menu] -%}
            {%- if menu != blank and menu.links.size > 0 -%}
              <ul class="georg-footer-links">
                {%- for link in menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <div class="georg-footer-custom-text">
                {{ block.settings.custom_text }}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <!-- Bottom Bar: Socials, Country, Copyright -->
      <div class="georg-footer-bottom">
        <div class="georg-country-select">
          <span class="georg-country-label">{{ section.settings.region_label | default: 'Region:' }}</span>
          <span class="georg-country-active">{{ section.settings.region_value | default: 'Danmark (DKK kr.)' }}</span>
        </div>

        {%- if section.settings.show_socials -%}
          <div class="georg-social-links">
            <a href="{{ section.settings.facebook_link | default: '#' }}" aria-label="Facebook"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H7.5v-3H10V9.5C10 7.01 11.49 5.6 13.78 5.6c1.1 0 2.25.2 2.25.2v2.47h-1.27c-1.23 0-1.62.77-1.62 1.56V12h2.78l-.44 3h-2.34v6.8c4.56-.93 8-4.96 8-9.8z"/></svg></a>
            <a href="{{ section.settings.instagram_link | default: '#' }}" aria-label="Instagram"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg></a>
            <a href="{{ section.settings.pinterest_link | default: '#' }}" aria-label="Pinterest"><svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg></a>
          </div>
        {%- endif -%}

        <div class="georg-copyright">
          {{ section.settings.copyright_text | default: 'Copyright © Georg Jensen. Alle rettigheder forbeholdes.' }}
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .georg-footer-wrapper {
    background: #ffffff;
    font-family: var(--georg-font-sans);
    color: #222222;
  }

  .georg-member-banner {
    padding: 56px 0;
  }

  .georg-member-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }

  .georg-member-content {
    max-width: 500px;
  }

  .georg-member-title {
    font-size: 30px;
    font-weight: 400;
    margin: 0 0 16px 0;
  }

  .georg-member-benefits {
    font-size: 13px;
    line-height: 1.8;
  }

  .georg-member-form-wrap {
    flex-grow: 1;
    max-width: 480px;
  }

  .georg-input-group {
    display: flex;
    gap: 0;
  }

  .georg-member-input {
    flex-grow: 1;
    padding: 14px 18px;
    border: none;
    outline: none;
    font-size: 13px;
    background: #ffffff;
    color: #000000;
  }

  .georg-member-login-link {
    font-size: 11px;
    color: #999999;
    margin-top: 10px;
  }

  .georg-member-login-link a {
    color: #ffffff;
    text-decoration: underline;
  }

  .georg-footer-main {
    padding: 70px 0 40px 0;
    background: #ffffff;
    border-top: 1px solid #eeeeee;
  }

  .georg-footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 60px;
    border-bottom: 1px solid #eeeeee;
  }

  .georg-footer-heading {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 20px 0;
  }

  .georg-footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .georg-footer-links a {
    font-size: 13px;
    color: #555555;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .georg-footer-links a:hover {
    color: #000000;
  }

  .georg-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 30px;
    font-size: 12px;
    color: #777777;
  }

  .georg-country-select {
    display: flex;
    gap: 6px;
  }

  .georg-country-active {
    font-weight: 600;
    color: #222222;
  }

  .georg-social-links {
    display: flex;
    gap: 20px;
  }

  .georg-social-links a {
    color: #444444;
    transition: color 0.2s ease;
  }

  .georg-social-links a:hover {
    color: #000000;
  }

  @media screen and (max-width: 989px) {
    .georg-member-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .georg-member-form-wrap {
      max-width: 100%;
      width: 100%;
    }
    .georg-footer-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 550px) {
    .georg-footer-columns {
      grid-template-columns: 1fr;
    }
    .georg-footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_member_banner",
      "label": "Show Member Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "member_title",
      "label": "Member Banner Title",
      "default": "Bliv medlem af Georg Jensen"
    },
    {
      "type": "richtext",
      "id": "member_benefits",
      "label": "Member Benefits List",
      "default": "<p>✓ Få 10% rabat på dit første køb<br>✓ Gratis standardfragt på alle ordrer<br>✓ Eksklusive medlemsfordele og nyheder</p>"
    },
    {
      "type": "color",
      "id": "member_bg",
      "label": "Member Banner Background",
      "default": "#191c20"
    },
    {
      "type": "color",
      "id": "member_text_color",
      "label": "Member Banner Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email Input Placeholder",
      "default": "Indtast din e-mailadresse"
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit Button Label",
      "default": "TILMELD"
    },
    {
      "type": "text",
      "id": "login_prompt",
      "label": "Login Prompt Text",
      "default": "Har du allerede en konto? Log ind her"
    },
    {
      "type": "text",
      "id": "region_label",
      "label": "Region Label",
      "default": "Region:"
    },
    {
      "type": "text",
      "id": "region_value",
      "label": "Region Value",
      "default": "Danmark (DKK kr.)"
    },
    {
      "type": "checkbox",
      "id": "show_socials",
      "label": "Show Social Links",
      "default": true
    },
    {
      "type": "url",
      "id": "facebook_link",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "pinterest_link",
      "label": "Pinterest URL"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Copyright © Georg Jensen. Alle rettigheder forbeholdes."
    }
  ],
  "blocks": [
    {
      "type": "footer_column",
      "name": "Footer Link Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column Title",
          "default": "Kundeservice"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Select Linklist Menu"
        },
        {
          "type": "richtext",
          "id": "custom_text",
          "label": "Custom Text / Address"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Footer",
      "blocks": [
        {
          "type": "footer_column",
          "settings": { "title": "Kundeservice" }
        },
        {
          "type": "footer_column",
          "settings": { "title": "Online Shopping" }
        },
        {
          "type": "footer_column",
          "settings": { "title": "Mere fra Georg Jensen" }
        },
        {
          "type": "footer_column",
          "settings": { "title": "Firmainfo" }
        }
      ]
    }
  ]
}
{% endschema %}
