        <div class="georg-copyright">
          Copyright © Georg Jensen. Alle rettigheder forbeholdes.
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .georg-footer-wrapper {
    background: #ffffff;
    font-family: var(--georg-font-sans);
    color: #222222;
  }

  .georg-member-banner {
    background-color: #191c20;
    color: #ffffff;
    padding: 56px 0;
  }

  .georg-member-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }

  .georg-member-content {
    max-width: 500px;
  }

  .georg-member-title {
    font-size: 30px;
    font-weight: 400;
    color: #ffffff;
    margin: 0 0 16px 0;
  }

  .georg-member-benefits {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 13px;
    line-height: 1.8;
    color: #cccccc;
  }

  .georg-member-benefits li::before {
    content: "✓ ";
    color: #ffffff;
    margin-right: 6px;
  }

  .georg-member-form-wrap {
    flex-grow: 1;
    max-width: 480px;
  }

  .georg-input-group {
    display: flex;
    gap: 0;
  }

  .georg-member-input {
    flex-grow: 1;
    padding: 14px 18px;
    border: none;
    outline: none;
    font-size: 13px;
    background: #ffffff;
    color: #000000;
  }

  .georg-member-login-link {
    font-size: 11px;
    color: #999999;
    margin-top: 10px;
  }

  .georg-member-login-link a {
    color: #ffffff;
    text-decoration: underline;
  }

  .georg-footer-main {
    padding: 70px 0 40px 0;
    background: #ffffff;
    border-top: 1px solid #eeeeee;
  }

  .georg-footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 60px;
    border-bottom: 1px solid #eeeeee;
  }

  .georg-footer-heading {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #000000;
    margin: 0 0 20px 0;
  }

  .georg-footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .georg-footer-links a {
    font-size: 13px;
    color: #555555;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .georg-footer-links a:hover {
    color: #000000;
  }

  .georg-footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 30px;
    font-size: 12px;
    color: #777777;
  }

  .georg-country-select {
    display: flex;
    gap: 6px;
  }

  .georg-country-active {
    font-weight: 600;
    color: #222222;
  }

  .georg-social-links {
    display: flex;
    gap: 20px;
  }

  .georg-social-links a {
    color: #444444;
    transition: color 0.2s ease;
  }

  .georg-social-links a:hover {
    color: #000000;
  }

  @media screen and (max-width: 989px) {
    .georg-member-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .georg-member-form-wrap {
      max-width: 100%;
      width: 100%;
    }
    .georg-footer-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 550px) {
    .georg-footer-columns {
      grid-template-columns: 1fr;
    }
    .georg-footer-bottom {
      flex-direction: column;
      gap: 20px;
      text-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Footer",
  "settings": [],
  "presets": [
    {
      "name": "Georg Jensen Footer"
    }
  ]
}
{% endschema %}
