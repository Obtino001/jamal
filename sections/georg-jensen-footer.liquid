{% comment %}
  Georg Jensen Footer Section - 1-to-1 Replica
{% endcomment %}

<footer class="georg-footer-wrapper">
  <!-- Member Club Banner -->
  <div class="georg-member-banner">
    <div class="georg-container georg-member-inner">
      <div class="georg-member-content">
        <h3 class="georg-member-title georg-serif">Bliv medlem af Georg Jensen</h3>
        <ul class="georg-member-benefits georg-sans">
          <li>Få 10% rabat på dit første køb</li>
          <li>Gratis standardfragt på alle ordrer</li>
          <li>Eksklusive medlemsfordele og nyheder</li>
        </ul>
      </div>

      <div class="georg-member-form-wrap">
        {%- form 'customer', class: 'georg-member-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="georg-input-group">
            <input type="email" name="contact[email]" placeholder="Indtast din e-mailadresse" class="georg-member-input" required>
            <button type="submit" class="button-georg-black">TILMELD</button>
          </div>
          <div class="georg-member-login-link">
            Har du allerede en konto? <a href="{{ routes.account_login_url }}">Log ind her</a>
          </div>
        {%- endform -%}
      </div>
    </div>
  </div>

  <!-- Main Footer Links Grid -->
  <div class="georg-footer-main">
    <div class="georg-container">
      <div class="georg-footer-columns">
        <!-- Col 1: Kundeservice -->
        <div class="georg-footer-col">
          <h4 class="georg-footer-heading georg-sans">Kundeservice</h4>
          <ul class="georg-footer-links">
            <li><a href="#">Kontakt os</a></li>
            <li><a href="#">Tlf: +45 38 14 98 98</a></li>
            <li><a href="#">E-mail: kundeservice@georgjensen.com</a></li>
            <li><a href="#">Åbningstider</a></li>
            <li><a href="#">Ofte stillede spørgsmål</a></li>
          </ul>
        </div>

        <!-- Col 2: Online Shopping -->
        <div class="georg-footer-col">
          <h4 class="georg-footer-heading georg-sans">Online Shopping</h4>
          <ul class="georg-footer-links">
            <li><a href="#">Salgs- og leveringsbetingelser</a></li>
            <li><a href="#">Fragt og levering</a></li>
            <li><a href="#">Retur og ombytning</a></li>
            <li><a href="#">Privatlivspolitik</a></li>
            <li><a href="#">Cookiepolitik</a></li>
          </ul>
        </div>

        <!-- Col 3: Mere fra Georg Jensen -->
        <div class="georg-footer-col">
          <h4 class="georg-footer-heading georg-sans">Mere fra Georg Jensen</h4>
          <ul class="georg-footer-links">
            <li><a href="{{ routes.account_url }}">Min Georg Jensen konto</a></li>
            <li><a href="#">Firmagaver</a></li>
            <li><a href="#">Find butik</a></li>
            <li><a href="#">Gavekort</a></li>
            <li><a href="#">Plejeguide</a></li>
          </ul>
        </div>

        <!-- Col 4: Firmainfo -->
        <div class="georg-footer-col">
          <h4 class="georg-footer-heading georg-sans">Firmainfo</h4>
          <ul class="georg-footer-links">
            <li><a href="/pages/about">Om Georg Jensen</a></li>
            <li><a href="#">Karriere (Fiskars Group)</a></li>
            <li><a href="#">Bæredygtighed & CSR</a></li>
            <li><a href="#">Presse</a></li>
            <li><a href="#">Whistleblower</a></li>
          </ul>
        </div>
      </div>

      <!-- Bottom Bar: Socials, Country, Copyright -->
      <div class="georg-footer-bottom">
        <div class="georg-country-select">
          <span class="georg-country-label">Region:</span>
          <span class="georg-country-active">Danmark (DKK kr.)</span>
        </div>

