{%- if predictive_search.performed -%}
  <div id="predictive-search-results">
    <div class="WI_productResult_con" style="width: 70%; padding-right: 40px;">
        {%- if predictive_search.resources.products.size > 0 -%}
      <h3 id="predictive-search-products" style="width: 100%; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 15px;">
        Produkter
        <button style="border: none; background: #000; color: #fff; cursor: pointer; padding: 5px 15px; font-size: 14px;">
          Søg efter “{{ predictive_search.terms }}”
        </button>
      </h3>
      <div style="display: flex; flex-wrap: wrap; gap: 20px;">
        {%- for product in predictive_search.resources.products -%}
          {% if product.available %}
          <div class="WI_productResult_product" style="width: calc(25% - 15px);">
              {%- render 'card-product',
                card_product: product,
                media_aspect_ratio: 1,
                show_secondary_image: false,
                show_vendor: false,
                show_rating: false
              -%}
          </div>
          {% endif %}
        {%- endfor -%}
      </div>
        {%- else -%}
        <p class="noSugg">Ingen produkter fundet</p>
    {%- endif -%}
    </div>
    <div class="WI_suggResult_con" style="width: 30%;">
        <h3 id="predictive-search-products" style="border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 15px;">
          Foreslag
        </h3>
      {%- if predictive_search.resources.queries.size > 0 -%}
      <ul
        id="predictive-search-results-queries-list"
        class="predictive-search__results-list list-unstyled"
        role="group"
        aria-labelledby="predictive-search-queries"
        style="list-style: none; padding: 0; margin: 0 0 20px 0;"
      >
        {%- for query in predictive_search.resources.queries -%}
        <li
        id="predictive-search-option-query-{{ forloop.index }}"
        class="predictive-search__list-item"
        role="option"
        aria-selected="false"
        style="margin-bottom: 10px;"
      >
        <a href="{{ query.url }}" class="predictive-search__item link link--text" tabindex="-1" style="text-decoration: none; color: #333;">
          <div class="predictive-search__item-content predictive-search__item-content--centered">
            <p
              class="predictive-search__item-heading predictive-search__item-query-result h5"
              aria-label="{{ query.text }}"
            >
              {{ query.styled_text }}
            </p>
          </div>
        </a>
      </li>
      {%- endfor -%}
          </ul>
        {%- else -%}
          <p class="noSugg" style="margin-bottom: 20px;"> Ingen foreslag fundet</p>
        {%- endif -%}
        <h3 id="predictive-search-products" style="border-bottom: 1px solid #eee; padding-bottom: 5px; margin-bottom: 15px;">
          Kollektioner
        </h3>
        {%- if predictive_search.resources.collections.size > 0 -%}
          <ul style="list-style: none; padding: 0; margin: 0;">
            {%- for collection in predictive_search.resources.collections -%}
                <li style="margin-bottom: 10px;">
                  <a href="{{ collection.url }}" class="predictive-search__item link link--text" tabindex="-1" style="text-decoration: none; color: #333;">
                    <div class="predictive-search__item-content predictive-search__item-content--centered">
                      <p class="predictive-search__item-heading h5">{{ collection.title }}</p>
                    </div>
                  </a>
                </li>
            {%- endfor -%}
          </ul>
          {% else %}
          <p class="noSugg">Ingen kollektion fundet</p>
        {%- endif -%}
      </div>
  </div>
{%- endif -%}
