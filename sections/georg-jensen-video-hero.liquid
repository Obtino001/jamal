{% comment %}
  Georg Jensen 1-to-1 Video Hero Banner
{% endcomment %}

<div class="georg-video-hero section-{{ section.id }}">
  <div class="herobanner_poster" data-ga-id="hero-banner-video" data-ga-creative="category">
    <div class="herobanner_poster_image">
      <div class="herobanner_poster_overlay" data-height="{{ section.settings.desktop_height }}px" style="height: {{ section.settings.desktop_height }}px;">
        <div class="site-core-video" style="background: transparent; position: absolute;">
          <div id="video-{{ section.id }}" class="cld-video-player cld-fluid video-js vjs-controls-disabled vjs-workinghover vjs-v7 vjs-fluid cld-video-player-skin-dark vjs-contextmenu vjs-playing vjs-has-started" style="height: auto; position: absolute; font-family: 'Fira Sans';">
            <video 
              data-url="{{ section.settings.video_url }}" 
              data-url-mobile="{{ section.settings.video_url_mobile | default: section.settings.video_url }}" 
              autoplay loop muted playsinline 
              class="vjs-tech pauseFirstClick" 
              style="height: auto; position: absolute; font-family: 'Fira Sans'; width: 100%; object-fit: cover;" 
              poster="{{ section.settings.poster_image | image_url: width: 1920 }}" 
              src="{{ section.settings.video_url }}">
            </video>
          </div>
        </div>
      </div>
    </div>
    
    <div class="herobanner_poster_content placementCenterLeft alignmentLeft">
      <div class="herobanner_poster_content_subheadline">
        {{ section.settings.subheading }}
      </div>
      <div class="herobanner_poster_content_headline">
        <div class="">{{ section.settings.heading }}</div>
      </div>
      <div class="herobanner_poster_content_body">
        {{ section.settings.text }}
      </div>
      <div class="herobanner_poster_content_button">
        {%- if section.settings.button_label != blank -%}
          <a class="button black-solid" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .georg-video-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .herobanner_poster {
    position: relative;
    width: 100%;
  }
  .herobanner_poster_image {
    width: 100%;
    position: relative;
    overflow: hidden;
  }
  .herobanner_poster_overlay {
    width: 100%;
    position: relative;
  }
  .site-core-video {
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
  }
  .cld-video-player {
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
  }
  
  .herobanner_poster_content {
    position: absolute;
    top: 50%;
    left: 8%;
    transform: translateY(-50%);
    max-width: 500px;
    z-index: 10;
  }
  .herobanner_poster_content_subheadline {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: 12px;
  }
  .herobanner_poster_content_headline {
    font-size: 48px;
    font-weight: 300;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .herobanner_poster_content_body {
    color: #fff;
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  
  .button.black-solid {
    display: inline-block;
    padding: 16px 32px;
    background: #111;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.3s;
  }
  .button.black-solid:hover {
    background: #333;
  }

  @media screen and (max-width: 1023px) {
    .georg-video-hero {
      overflow: visible; /* Allow button to overflow */
    }
    .herobanner_poster_content {
      position: absolute;
      bottom: -24px;
      top: auto;
      left: 50%;
      transform: translateX(-50%);
      padding: 0;
      background: transparent;
      text-align: center;
      width: 100%;
      z-index: 10;
    }
    /* Hide text on mobile as per design reference */
    .herobanner_poster_content_headline,
    .herobanner_poster_content_subheadline,
    .herobanner_poster_content_body {
      display: none; 
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var heroBannerResizeVideoToScreen = function () {
      var videoParent = document.querySelector(".herobanner_poster_overlay video").parentElement;
      var video = document.querySelector(".herobanner_poster_overlay video");
      var overlay = document.querySelector(".herobanner_poster_overlay");
      var siteCoreVideo = document.querySelector(".herobanner_poster_overlay .site-core-video");

      if (videoParent) videoParent.style.background = "transparent";

      if (window.innerWidth > 1023) {
        if (video) {
          video.style.height = "auto";
          video.style.position = "absolute";
        }
        if (videoParent) videoParent.style.position = "absolute";
        if (siteCoreVideo) siteCoreVideo.style.position = "absolute";
        if (overlay) overlay.style.height = overlay.dataset.height;
      } else {
        if (overlay) overlay.style = null;
        if (video) {
          video.style.height = "100%";
          video.style.position = "inherit";
        }
        if (videoParent) videoParent.style.position = "inherit";
        if (siteCoreVideo) siteCoreVideo.style.position = "inherit";
      }
    };
    
    window.addEventListener("resize", heroBannerResizeVideoToScreen);
    // Initial call
    setTimeout(heroBannerResizeVideoToScreen, 100);
  });
</script>

{% schema %}
{
  "name": "Georg Jensen Video Hero",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (Desktop/Default)",
      "default": "https://res.cloudinary.com/georgjensen/video/upload/f_auto,q_auto:good,w_1920/v1782976215/videos/Jewellery%20Videos/Campaign%20Videos/GJ_SS26_WEFT_20002032_20002034_CLEAN_16X9.mp4"
    },
    {
      "type": "text",
      "id": "video_url_mobile",
      "label": "Video URL (Mobile)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster Image (Fallback)"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 1000,
      "step": 50,
      "default": 800,
      "label": "Desktop Height (px)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Udforsk weft"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Video Hero"
    }
  ]
}
{% endschema %}
