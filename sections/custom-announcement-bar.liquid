{%- style -%}
  .custom-announcement {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 1rem 0;
    /* Optional: subtle bottom border if needed to separate from header */
    border-bottom: 1px solid rgba(0,0,0,0.05); 
  }

  .custom-announcement__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: {{ section.settings.alignment }};
    gap: 4rem; /* Controls the spacing between the text items */
  }

  .custom-announcement__message {
    font-size: 1.2rem;
    font-family: var(--georg-font-futura, Futura, sans-serif);
    margin: 0;
    letter-spacing: 0.04rem;
    line-height: 1.2;
  }

  .custom-announcement__link {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .custom-announcement__link:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .custom-announcement__inner {
      justify-content: center;
      gap: 1.5rem;
      flex-direction: column;
      padding: 0 1.5rem;
      text-align: center;
    }
  }
{%- endstyle -%}

<div class="custom-announcement" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
  <div class="page-width">
    <div class="custom-announcement__inner">
      
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}
          <p class="custom-announcement__message" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" class="custom-announcement__link">
            {%- endif -%}
              
            {{ block.settings.text | escape }}
            
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </p>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Announcement",
  "max_blocks": 4,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2D3542",
      "info": "Default matches the dark slate blue in your reference."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Desktop Alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-end",
      "info": "Set to right (flex-end) to push text to the right side like the reference image."
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Welcome, signup and get 10%",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Announcement",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Welcome, signup and get 10%"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Home delivery service"
          }
        }
      ]
    }
  ]
}
{% endschema %}