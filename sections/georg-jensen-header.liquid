{% comment %}
  Georg Jensen Header Section - Fully Theme Customizer Editable
{% endcomment %}

<div class="georg-header-wrapper">
  <!-- Announcement Bar -->
  {%- if section.settings.show_announcement -%}
    <div class="georg-announcement-bar" style="background-color: {{ section.settings.announcement_bg }}; color: {{ section.settings.announcement_text_color }};">
      <div class="georg-container georg-announcement-inner">
        <div class="georg-announcement-left">
          <a href="{{ section.settings.announcement_left_link | default: '#' }}" class="georg-announcement-link" style="color: {{ section.settings.announcement_text_color }};">
            {{ section.settings.announcement_left_text }}
          </a>
        </div>
        <div class="georg-announcement-right">
          <a href="{{ section.settings.announcement_right_link | default: '#' }}" class="georg-announcement-link" style="color: {{ section.settings.announcement_text_color }};">
            {{ section.settings.announcement_right_text }}
          </a>
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Main Header Top Row -->
  <header class="georg-main-header">
    <div class="georg-container georg-header-inner">
      <!-- Left Quick Links -->
      <div class="georg-header-left">
        {%- if section.settings.store_locator_label != blank -%}
          <a href="{{ section.settings.store_locator_link | default: '#' }}" class="georg-utility-link">
            <svg class="georg-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-6-5.33-6-10a6 6 0 0 1 12 0c0 4.67-6 10-6 10z"/><circle cx="12" cy="11" r="2"/></svg>
            <span>{{ section.settings.store_locator_label }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.support_label != blank -%}
          <a href="{{ section.settings.support_link | default: '#' }}" class="georg-utility-link">
            <span>{{ section.settings.support_label }}</span>
          </a>
        {%- endif -%}
      </div>

      <!-- Center Brand Logo -->
      <div class="georg-header-center">
        <a href="{{ routes.root_url }}" class="georg-brand-logo-link">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="georg-logo-img" style="width: {{ section.settings.logo_width }}px;">
          {%- else -%}
            <img src="{{ 'logo.svg' | asset_url }}" alt="GEORG JENSEN" class="georg-logo-img" style="width: {{ section.settings.logo_width }}px;">
          {%- endif -%}
        </a>
      </div>

      <!-- Right Utility Actions -->
      <div class="georg-header-right">
        <form action="{{ routes.search_url }}" method="get" class="georg-search-box">
          <input type="text" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Søg...' }}" class="georg-search-input">
          <button type="submit" class="georg-search-btn" aria-label="Søg">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
          </button>
        </form>

        <a href="{{ routes.account_url }}" class="georg-icon-link" aria-label="Konto">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        </a>

        <a href="#" class="georg-icon-link georg-wishlist-icon" aria-label="Ønskeliste">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <span class="georg-badge">0</span>
        </a>

        <a href="{{ routes.cart_url }}" class="georg-icon-link georg-cart-icon" aria-label="Kurv">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="georg-badge">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </header>

  <!-- Navigation Menu Bar -->
  <nav class="georg-nav-bar">
    <div class="georg-container">
      <ul class="georg-nav-menu">
        {%- assign nav_menu = linklists[section.settings.menu] -%}
        {%- if nav_menu != blank and nav_menu.links.size > 0 -%}
          {%- for link in nav_menu.links -%}
            <li class="georg-nav-item">
              <a href="{{ link.url }}" class="georg-nav-link">{{ link.title | upcase }}</a>
            </li>
          {%- endfor -%}
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <li class="georg-nav-item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="georg-nav-link">{{ block.settings.title | upcase }}</a>
            </li>
          {%- endfor -%}
        {%- else -%}
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">SMYKKER</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">BOLIG</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">TIL BORD & BAR</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">SØLVHÅNDVÆRK</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">GAVER</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">BRAND</a></li>
        {%- endif -%}
      </ul>
    </div>
  </nav>
</div>

<style>
  .georg-header-wrapper {
    width: 100%;
    font-family: var(--georg-font-sans);
    background: #ffffff;
    border-bottom: 1px solid var(--georg-grey-border);
  }

  .georg-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .georg-announcement-bar {
    border-bottom: 1px solid #eaeaea;
    padding: 8px 0;
    font-size: 11px;
    letter-spacing: 0.05em;
  }

  .georg-announcement-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .georg-announcement-link {
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .georg-announcement-link:hover {
    opacity: 0.7;
  }

  .georg-main-header {
    padding: 20px 0;
  }

  .georg-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .georg-header-left {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
  }

  .georg-utility-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #222222;
    text-decoration: none;
  }

  .georg-header-center {
    text-align: center;
    flex: 1;
  }

  .georg-logo-img {
    display: inline-block;
    max-height: 80px;
    width: auto !important; /* Override inline width which might cause square aspect ratio */
    object-fit: contain;
  }

  .georg-header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    flex: 1;
  }

  .georg-search-box {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #ccc;
    padding-bottom: 2px;
  }

  .georg-search-input {
    border: none;
    outline: none;
    background: transparent;
    font-size: 12px;
    width: 140px;
    padding-right: 24px;
  }

  .georg-search-btn {
    position: absolute;
    right: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    color: #444;
  }

  .georg-icon-link {
    color: #222;
    position: relative;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .georg-badge {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #000000;
    color: #ffffff;
    font-size: 9px;
    font-weight: 600;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .georg-nav-bar {
    border-top: 1px solid #eeeeee;
    padding: 14px 0;
  }

  .georg-nav-menu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    gap: 40px;
  }

  .georg-nav-link {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: #1c1c1c;
    text-decoration: none;
    transition: color 0.2s;
  }

  .georg-nav-link:hover {
    color: #666666;
  }

  @media screen and (max-width: 989px) {
    .georg-header-left {
      display: none;
    }
    .georg-nav-menu {
      gap: 20px;
      overflow-x: auto;
      white-space: nowrap;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_left_text",
      "label": "Announcement Left Text",
      "default": "Medlemmer får altid gratis fragt"
    },
    {
      "type": "url",
      "id": "announcement_left_link",
      "label": "Announcement Left Link"
    },
    {
      "type": "text",
      "id": "announcement_right_text",
      "label": "Announcement Right Text",
      "default": "Tilmeld dig vores nyhedsbrev og få 10%"
    },
    {
      "type": "url",
      "id": "announcement_right_link",
      "label": "Announcement Right Link"
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement Background",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Announcement Text Color",
      "default": "#444444"
    },
    {
      "type": "text",
      "id": "store_locator_label",
      "label": "Store Locator Link Label",
      "default": "Find butik"
    },
    {
      "type": "url",
      "id": "store_locator_link",
      "label": "Store Locator URL"
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Customer Support Label",
      "default": "Kundeservice"
    },
    {
      "type": "url",
      "id": "support_link",
      "label": "Customer Support URL"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand Logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 350,
      "step": 5,
      "default": 220,
      "label": "Logo Width (px)"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu Linklist"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Søg..."
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Custom Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Menu Item Title",
          "default": "KOLLEKTION"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Menu Item Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Header"
    }
  ]
}
{% endschema %}
