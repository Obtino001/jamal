{% comment %}
  Georg Jensen Header Section - Fully Theme Customizer Editable with 1-to-1 Announcement Bar
{% endcomment %}

<div class="georg-header-wrapper">
  <!-- Announcement Bar -->
  {%- if section.settings.show_announcement -%}
    <div class="georg-announcement-bar" style="background-color: {{ section.settings.announcement_bg | default: '#1b2430' }}; color: {{ section.settings.announcement_text_color | default: '#ffffff' }};">
      <div class="georg-container georg-announcement-inner">
        <div class="georg-announcement-left-blank"></div>
        <div class="georg-announcement-messages">
          {%- if section.settings.announcement_left_text != blank -%}
            <a href="{{ section.settings.announcement_left_link | default: '#' }}" class="georg-announcement-link" style="color: {{ section.settings.announcement_text_color | default: '#ffffff' }};">
              {{ section.settings.announcement_left_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.announcement_left_text != blank and section.settings.announcement_right_text != blank -%}
            <span class="announcement-divider">|</span>
          {%- endif -%}
          {%- if section.settings.announcement_right_text != blank -%}
            <a href="{{ section.settings.announcement_right_link | default: '#' }}" class="georg-announcement-link" style="color: {{ section.settings.announcement_text_color | default: '#ffffff' }};">
              {{ section.settings.announcement_right_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <!-- Main Header Top Row -->
  <header class="georg-main-header">
    <div class="georg-container georg-header-inner">
      <!-- Left Quick Links -->
      <div class="georg-header-left">
        {%- if section.settings.store_locator_label != blank -%}
          <a href="{{ section.settings.store_locator_link | default: '#' }}" class="georg-utility-link">
            <svg class="georg-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21s-6-5.33-6-10a6 6 0 0 1 12 0c0 4.67-6 10-6 10z"/><circle cx="12" cy="11" r="2"/></svg>
            <span>{{ section.settings.store_locator_label }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.support_label != blank -%}
          <a href="{{ section.settings.support_link | default: '#' }}" class="georg-utility-link">
            <span>{{ section.settings.support_label }}</span>
          </a>
        {%- endif -%}
      </div>

      <!-- Center Brand Logo -->
      <div class="georg-header-center">
        <a href="{{ routes.root_url }}" class="georg-brand-logo-link">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" class="georg-logo-img" style="width: {{ section.settings.logo_width }}px;">
          {%- else -%}
            <img src="{{ 'logo.svg' | asset_url }}" alt="GEORG JENSEN" class="georg-logo-img" style="width: {{ section.settings.logo_width }}px;">
          {%- endif -%}
        </a>
      </div>

      <!-- Right Utility Actions -->
      <div class="georg-header-right">
        <form action="{{ routes.search_url }}" method="get" class="georg-search-box">
          <input type="text" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Søg...' }}" class="georg-search-input">
          <button type="submit" class="georg-search-btn" aria-label="Søg">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
          </button>
        </form>

        <a href="{{ routes.account_url }}" class="georg-icon-link" aria-label="Konto">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
        </a>

        <a href="#" class="georg-icon-link georg-wishlist-icon" aria-label="Ønskeliste">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <span class="georg-badge">0</span>
        </a>

        <a href="{{ routes.cart_url }}" class="georg-icon-link georg-cart-icon" aria-label="Kurv">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="georg-badge">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </header>

  <!-- Navigation Menu Bar -->
  <nav class="georg-nav-bar">
    <div class="georg-container">
      <ul class="georg-nav-menu">
        {%- assign nav_menu = linklists[section.settings.menu] -%}
        {%- if nav_menu != blank and nav_menu.links.size > 0 -%}
          {%- for link in nav_menu.links -%}
            <li class="georg-nav-item">
              <a href="{{ link.url }}" class="georg-nav-link">{{ link.title | upcase }}</a>
            </li>
          {%- endfor -%}
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <li class="georg-nav-item" {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link | default: '#' }}" class="georg-nav-link">{{ block.settings.title | upcase }}</a>
            </li>
          {%- endfor -%}
        {%- else -%}
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">SMYKKER</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">BOLIG</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">TIL BORD & BAR</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">SØLVHÅNDVÆRK</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">URE & ACCESSOIRES</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">GAVER</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">UDFORSK</a></li>
          <li class="georg-nav-item"><a href="#" class="georg-nav-link">SALE</a></li>
        {%- endif -%}
      </ul>
    </div>
  </nav>
</div>

<style>
  .georg-header-wrapper {
    font-family: var(--georg-font-sans);
    background-color: #ffffff;
  }

  .georg-container {
    max-width: 1380px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .georg-announcement-bar {
    padding: 7px 0;
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  .georg-announcement-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .georg-announcement-messages {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-left: auto;
  }

  .announcement-divider {
    color: rgba(255, 255, 255, 0.4);
    font-size: 10px;
  }

  .georg-announcement-link {
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .georg-announcement-link:hover {
    opacity: 0.8;
  }

  .georg-main-header {
    padding: 20px 0;
  }

  .georg-header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .georg-header-left {
    display: flex;
    align-items: center;
    gap: 20px;
    flex: 1;
  }

  .georg-utility-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: #222222;
    text-decoration: none;
  }

  .georg-header-center {
    text-align: center;
    flex: 1;
  }

  .georg-logo-img {
    height: auto;
    display: inline-block;
  }

  .georg-header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 20px;
    flex: 1;
  }

  .georg-search-box {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #ccc;
    padding-bottom: 2px;
  }

  .georg-search-input {
    border: none;
    outline: none;
    background: transparent;
    font-size: 12px;
    width: 140px;
    padding-right: 24px;
  }

  .georg-search-btn {
    position: absolute;
    right: 0;
    border: none;
    background: transparent;
    cursor: pointer;
    padding: 0;
    color: #444;
  }

  .georg-icon-link {
    color: #222;
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .georg-badge {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #111;
    color: #fff;
    font-size: 9px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .georg-nav-bar {
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
    padding: 12px 0;
  }

  .georg-nav-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
  }

  .georg-nav-link {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: #111111;
    text-decoration: none;
    transition: color 0.2s;
  }

  .georg-nav-link:hover {
    color: #777777;
  }

  @media screen and (max-width: 768px) {
    .georg-header-left {
      display: none;
    }
    .georg-search-input {
      width: 90px;
    }
    .georg-nav-menu {
      gap: 16px;
      overflow-x: auto;
      justify-content: flex-start;
      white-space: nowrap;
    }
  }
</style>

{% schema %}
{
  "name": "Georg Jensen Header",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar Settings"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement Background",
      "default": "#1b2430"
    },
    {
      "type": "color",
      "id": "announcement_text_color",
      "label": "Announcement Text Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "announcement_left_text",
      "label": "Left Message",
      "default": "Medlemmer får altid gratis fragt"
    },
    {
      "type": "url",
      "id": "announcement_left_link",
      "label": "Left Message Link"
    },
    {
      "type": "text",
      "id": "announcement_right_text",
      "label": "Right Message",
      "default": "Tilmeld dig vores nyhedsbrev og få 10%"
    },
    {
      "type": "url",
      "id": "announcement_right_link",
      "label": "Right Message Link"
    },
    {
      "type": "header",
      "content": "Header Navigation & Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Custom Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 180,
      "unit": "px",
      "label": "Logo Width"
    },
    {
      "type": "text",
      "id": "store_locator_label",
      "label": "Store Locator Label",
      "default": "Find butik"
    },
    {
      "type": "url",
      "id": "store_locator_link",
      "label": "Store Locator Link"
    },
    {
      "type": "text",
      "id": "support_label",
      "label": "Support Label",
      "default": "Kundeservice"
    },
    {
      "type": "url",
      "id": "support_link",
      "label": "Support Link"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder",
      "default": "Søg..."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu (Linklist)"
    }
  ],
  "blocks": [
    {
      "type": "menu_item",
      "name": "Custom Menu Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Menu Item Label",
          "default": "SMYKKER"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Menu Item Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Header",
      "blocks": [
        { "type": "menu_item", "settings": { "title": "SMYKKER" } },
        { "type": "menu_item", "settings": { "title": "BOLIG" } },
        { "type": "menu_item", "settings": { "title": "TIL BORD & BAR" } },
        { "type": "menu_item", "settings": { "title": "SØLVHÅNDVÆRK" } }
      ]
    }
  ]
}
{% endschema %}
