{% comment %}
  Style it with — Georg Jensen 1:1
{% endcomment %}

{%- style -%}
  .section-{{ section.id }} {
    --siw-bg: {{ section.settings.background_color }};
    --siw-text: #1a1a1a;
    --siw-muted: #444;
    --siw-link: {{ section.settings.link_color }};
    --siw-media: #f3f2f0;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--siw-bg);
    color: var(--siw-text);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

/* 
  Georg Jensen "Style It With" 1:1 CSS
  Matches the specific BEM classes in your provided Liquid section.
*/

.gj-siw {
  overflow: hidden;
  box-sizing: border-box;
}

.gj-siw * {
  box-sizing: border-box;
}

/* --- Header Area --- */
.gj-siw__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 4rem;
  flex-wrap: wrap;
  gap: 1.5rem;
}

.gj-siw__title {
  font-family: var(--font-heading-family, serif);
  font-size: calc(var(--font-heading-scale) * 3.2rem);
  font-weight: 400;
  line-height: 1.1;
  color: var(--siw-text);
  margin: 0;
}

.gj-siw__link {
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  font-family: var(--font-body-family, sans-serif);
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: 0.15rem;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--siw-link);
  transition: opacity 0.2s ease;
}

.gj-siw__link:hover {
  opacity: 0.7;
}

.gj-siw__link-arrow {
  font-family: monospace; /* Keeps the arrow clean */
  font-size: 1.2rem;
  font-weight: 400;
}

/* --- Main Layout Grid --- */
.gj-siw__layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4rem;
  align-items: stretch; /* Forces both columns to match height */
}

@media screen and (min-width: 750px) {
  .gj-siw__layout {
    grid-template-columns: 1fr 1fr;
    gap: 6rem; /* Generous gap between products and large image */
  }

  .gj-siw__layout--image-first .gj-siw__products {
    order: 2;
  }
  
  .gj-siw__layout--image-first .gj-siw__feature {
    order: 1;
  }
}

/* --- Left Column: Products --- */
.gj-siw__products {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 3rem; /* Space between the two products vertically */
}

.gj-siw__product {
  display: flex;
  align-items: center;
  gap: 3rem; /* Space between product image and text */
  text-decoration: none;
  color: inherit;
  transition: opacity 0.3s ease;
}

.gj-siw__product:hover .gj-siw__product-img {
  transform: scale(1.05);
}

.gj-siw__product-media {
  width: 45%; /* Keeps image box proportioned like reference */
  max-width: 250px;
  position: relative;
  background-color: var(--siw-media);
  border-radius: 0;
  overflow: hidden;
}

/* Creates a 4:5 aspect ratio for the product background boxes */
.gj-siw__product-media::before {
  content: "";
  display: block;
  padding-bottom: 125%; 
}

.gj-siw__product-img,
.gj-siw__placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 15%; /* Creates the inner space inside the beige box natively */
  transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.gj-siw__placeholder {
  background-color: #e5e5e5;
  padding: 0;
  object-fit: cover;
}

.gj-siw__product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}

.gj-siw__product-title {
  font-family: var(--font-heading-family, serif);
  font-size: calc(var(--font-heading-scale) * 2rem);
  font-weight: 400;
  color: var(--siw-text);
  margin: 0;
  line-height: 1.3;
}

.gj-siw__product-price {
  font-family: var(--font-body-family, sans-serif);
  font-size: 1.2rem;
  color: var(--siw-muted);
  margin: 0;
}

/* --- Right Column: Feature Image --- */
.gj-siw__feature {
  position: relative;
  height: 100%;
  min-height: 400px;
}

.gj-siw__feature-media {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 0;
  overflow: hidden;
}

/* On mobile, give it a fixed height ratio. On desktop, let it fill the parent height */
.gj-siw__feature-media::before {
  content: "";
  display: block;
  padding-bottom: 110%; 
}

@media screen and (min-width: 750px) {
  .gj-siw__feature-media::before {
    display: none;
  }
  .gj-siw__feature-media {
    position: absolute; /* Allows it to fully track the stretch of the layout grid */
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }
}

.gj-siw__feature-img,
.gj-siw__placeholder--feature {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  padding: 0; /* Override the padding set for product images */
}

<section class="gj-siw section-{{ section.id }}" data-gj-siw>
  <div class="page-width gj-siw__inner">
    <div class="gj-siw__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="gj-siw__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.link_text != blank -%}
        <a
          href="{{ section.settings.link_url | default: '#' }}"
          class="gj-siw__link"
        >
          <span>{{ section.settings.link_text | escape }}</span>
          <span class="gj-siw__link-arrow" aria-hidden="true">&gt;</span>
        </a>
      {%- endif -%}
    </div>

    <div class="gj-siw__layout{% if section.settings.layout == 'image_first' %} gj-siw__layout--image-first{% endif %}">
      <div class="gj-siw__products">
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <a
              href="{{ product.url }}"
              class="gj-siw__product"
              {{ block.shopify_attributes }}
            >
              <div class="gj-siw__product-media">
                {%- if product.featured_media != blank -%}
                  {{
                    product.featured_media
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      class: 'gj-siw__product-img',
                      widths: '280, 400, 560, 700',
                      sizes: '(min-width: 990px) 18vw, 42vw',
                      alt: product.title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'gj-siw__placeholder' }}
                {%- endif -%}
              </div>
              <div class="gj-siw__product-info">
                <h3 class="gj-siw__product-title">{{ product.title | escape }}</h3>
                <p class="gj-siw__product-price">{{ product.price | money_without_trailing_zeros }}</p>
              </div>
            </a>
          {%- else -%}
            <div class="gj-siw__product" {{ block.shopify_attributes }}>
              <div class="gj-siw__product-media">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'gj-siw__placeholder' }}
              </div>
              <div class="gj-siw__product-info">
                <h3 class="gj-siw__product-title">Weft Earrings</h3>
                <p class="gj-siw__product-price">{{ 39200 | money_without_trailing_zeros }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="gj-siw__feature">
        <div class="gj-siw__feature-media">
          {%- if section.settings.main_image != blank -%}
            {{
              section.settings.main_image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                class: 'gj-siw__feature-img',
                widths: '600, 900, 1200, 1600',
                sizes: '(min-width: 990px) 48vw, 100vw',
                alt: section.settings.heading | default: 'Style it with'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'gj-siw__placeholder gj-siw__placeholder--feature' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Style It With",
  "tag": "section",
  "class": "section-style-it-with",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Style it with",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "link_text",
      "default": "Explore the collection",
      "label": "Link text"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#6b8cae"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Lifestyle image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        { "value": "text_first", "label": "Products left / Image right" },
        { "value": "image_first", "label": "Image left / Products right" }
      ],
      "default": "text_first"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Style It With",
      "blocks": [
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
