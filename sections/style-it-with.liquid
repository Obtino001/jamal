{% comment %}
  Style it with — Georg Jensen 1:1
{% endcomment %}

{%- style -%}
  .section-{{ section.id }} {
    --siw-bg: {{ section.settings.background_color }};
    --siw-text: #1a1a1a;
    --siw-muted: #444;
    --siw-link: {{ section.settings.link_color }};
    --siw-media: #f3f2f0;
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: var(--siw-bg);
    color: var(--siw-text);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{{ 'georg-jensen-style-it-with.css' | asset_url | stylesheet_tag }}

<section class="gj-siw section-{{ section.id }}" data-gj-siw>
  <div class="page-width gj-siw__inner">
    <div class="gj-siw__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="gj-siw__title">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.link_text != blank -%}
        <a
          href="{{ section.settings.link_url | default: '#' }}"
          class="gj-siw__link"
        >
          <span>{{ section.settings.link_text | escape }}</span>
          <span class="gj-siw__link-arrow" aria-hidden="true">&gt;</span>
        </a>
      {%- endif -%}
    </div>

    <div class="gj-siw__layout{% if section.settings.layout == 'image_first' %} gj-siw__layout--image-first{% endif %}">
      <div class="gj-siw__products">
        {%- for block in section.blocks -%}
          {%- assign product = block.settings.product -%}
          {%- if product != blank -%}
            <a
              href="{{ product.url }}"
              class="gj-siw__product"
              {{ block.shopify_attributes }}
            >
              <div class="gj-siw__product-media">
                {%- if product.featured_media != blank -%}
                  {{
                    product.featured_media
                    | image_url: width: 700
                    | image_tag:
                      loading: 'lazy',
                      class: 'gj-siw__product-img gj-siw__product-img--main',
                      widths: '280, 400, 560, 700',
                      sizes: '(min-width: 990px) 18vw, 42vw',
                      alt: product.title
                  }}
                  {%- if product.media[1] != blank -%}
                    {{
                      product.media[1]
                      | image_url: width: 700
                      | image_tag:
                        loading: 'lazy',
                        class: 'gj-siw__product-img gj-siw__product-img--hover',
                        widths: '280, 400, 560, 700',
                        sizes: '(min-width: 990px) 18vw, 42vw',
                        alt: product.title
                    }}
                  {%- endif -%}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'gj-siw__placeholder' }}
                {%- endif -%}
              </div>
              <div class="gj-siw__product-info">
                <h3 class="gj-siw__product-title">{{ product.title | escape }}</h3>
                <p class="gj-siw__product-price">{{ product.price | money_without_trailing_zeros }}</p>
              </div>
            </a>
          {%- else -%}
            <div class="gj-siw__product" {{ block.shopify_attributes }}>
              <div class="gj-siw__product-media">
                {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'gj-siw__placeholder' }}
              </div>
              <div class="gj-siw__product-info">
                <h3 class="gj-siw__product-title">Weft Earrings</h3>
                <p class="gj-siw__product-price">{{ 39200 | money_without_trailing_zeros }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="gj-siw__feature">
        <div class="gj-siw__feature-media">
          {%- if section.settings.main_image != blank -%}
            {{
              section.settings.main_image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                class: 'gj-siw__feature-img',
                widths: '600, 900, 1200, 1600',
                sizes: '(min-width: 990px) 48vw, 100vw',
                alt: section.settings.heading | default: 'Style it with'
            }}
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'gj-siw__placeholder gj-siw__placeholder--feature' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Style It With",
  "tag": "section",
  "class": "section-style-it-with",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "default": "Style it with",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "link_text",
      "default": "Explore the collection",
      "label": "Link text"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#6b8cae"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Lifestyle image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout",
      "options": [
        { "value": "text_first", "label": "Products left / Image right" },
        { "value": "image_first", "label": "Image left / Products right" }
      ],
      "default": "text_first"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 3,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Style It With",
      "blocks": [
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
