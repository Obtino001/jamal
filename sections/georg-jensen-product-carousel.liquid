{% comment %}
  Georg Jensen Product Carousel / Slider using Swiper.js - Fully Customizer Editable
{% endcomment %}

<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<div class="georg-product-carousel-section section-{{ section.id }}-padding">
  <div class="georg-container">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="georg-carousel-header">
        <div class="georg-carousel-header-text">
          {%- if section.settings.heading != blank -%}
            <h2 class="georg-section-title georg-serif">{{ section.settings.heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <p class="georg-carousel-subheading georg-sans">{{ section.settings.subheading }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.show_navigation -%}
          <div class="georg-carousel-nav-arrows">
            <button class="georg-carousel-arrow swiper-button-prev-{{ section.id }}" aria-label="Forrige">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="georg-carousel-arrow swiper-button-next-{{ section.id }}" aria-label="Næste">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Swiper Container -->
    <div class="swiper swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- assign collection = collections[section.settings.collection] -%}
        {%- if collection != blank and collection.products.size > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            <div class="swiper-slide">
              {% render 'georg-jensen-card-product', product: product %}
            </div>
          {%- endfor -%}
        {%- elsif section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              {%- if block.settings.product != blank -%}
                {% render 'georg-jensen-card-product', product: block.settings.product %}
              {%- else -%}
                <div class="georg-card-product">
                  <div class="georg-card-media-wrap">
                    <span class="georg-wishlist-toggle" aria-label="Tilføj til ønskeliste">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    </span>
                    <a href="{{ block.settings.link | default: '#' }}" class="georg-card-image-link">
                      {%- if block.settings.image != blank -%}
                        <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | escape }}" class="georg-card-main-img" loading="lazy">
                      {%- else -%}
                        <img src="{{ 'downloaded_image_10.jpg' | asset_url }}" alt="Georg Jensen" class="georg-card-main-img" loading="lazy">
                      {%- endif -%}
                    </a>
                  </div>
                  <div class="georg-card-info">
                    <div class="georg-card-title-wrap">
                      <span class="georg-card-brand-caps">{{ block.settings.brand_caps | default: 'MOONLIGHT GRAPES' }}</span>
                      <span class="georg-card-prod-type">{{ block.settings.product_type | default: 'halskæde' }}</span>
                    </div>
                    <div class="georg-card-material">{{ block.settings.material | default: 'Oxideret sterlingsølv' }}</div>
                    <div class="georg-card-variation">{{ block.settings.variation_text | default: 'Flere variationer' }}</div>
                    <div class="georg-card-price">{{ block.settings.price | default: 'DKK 9.750,00' }}</div>
                  </div>
                </div>
              {%- endif -%}
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- Default Customizer Placeholder Items -->
          {%- for i in (1..8) -%}
            {%- assign img_idx = i | plus: 9 -%}
            {%- assign img_file = 'downloaded_image_' | append: img_idx | append: '.jpg' -%}
            <div class="swiper-slide">
              <div class="georg-card-product">
                <div class="georg-card-media-wrap">
                  <span class="georg-wishlist-toggle" aria-label="Tilføj til ønskeliste">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                  </span>
                  <a href="#" class="georg-card-image-link">
                    <img src="{{ img_file | asset_url }}" alt="Georg Jensen Product" class="georg-card-main-img" loading="lazy">
                  </a>
                </div>
                <div class="georg-card-info">
                  <div class="georg-card-title-wrap">
                    <span class="georg-card-brand-caps">KOPPEL / BERNADOTTE</span>
                    <span class="georg-card-prod-type">skål / kande</span>
                  </div>
                  <div class="georg-card-material">Blankt rustfrit stål</div>
                  <div class="georg-card-variation">Flere variationer</div>
                  <div class="georg-card-price">DKK 2.450,00</div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if section.settings.show_scrollbar -%}
        <div class="swiper-scrollbar swiper-scrollbar-{{ section.id }}"></div>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  .georg-product-carousel-section {
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background-color: {{ section.settings.bg_color }};
  }

  .georg-carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
  }

  .georg-carousel-subheading {
    font-size: 13px;
    color: #666666;
    margin: 6px 0 0 0;
  }

  .georg-carousel-nav-arrows {
    display: flex;
    gap: 10px;
  }

  .georg-carousel-arrow {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid #dcdcdc;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111111;
    transition: all 0.2s ease;
  }

  .georg-carousel-arrow:hover {
    border-color: #000000;
    background: #000000;
    color: #ffffff;
  }

  .swiper-{{ section.id }} {
    width: 100%;
    padding-bottom: 20px;
  }
</style>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('.swiper-{{ section.id }}', {
      slidesPerView: 1.2,
      spaceBetween: 16,
      grabCursor: true,
      navigation: {
        nextEl: '.swiper-button-next-{{ section.id }}',
        prevEl: '.swiper-button-prev-{{ section.id }}',
      },
      breakpoints: {
        550: {
          slidesPerView: 2,
          spaceBetween: 20,
        },
        890: {
          slidesPerView: 3,
          spaceBetween: 24,
        },
        1200: {
          slidesPerView: {{ section.settings.desktop_columns | default: 4 }},
          spaceBetween: 24,
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Georg Swiper Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Populære produkter"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Opdag vores mest efterspurgte ikoner"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Shopify Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 3,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Desktop Columns"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fafafa"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 60,
      "label": "Padding Top (px)"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 80,
      "label": "Padding Bottom (px)"
    }
  ],
  "blocks": [
    {
      "type": "product_slide",
      "name": "Custom Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Product Image"
        },
        {
          "type": "text",
          "id": "brand_caps",
          "label": "Collection / Brand Caps",
          "default": "MOONLIGHT GRAPES"
        },
        {
          "type": "text",
          "id": "product_type",
          "label": "Product Subtitle / Type",
          "default": "halskæde"
        },
        {
          "type": "text",
          "id": "material",
          "label": "Material Description",
          "default": "Oxideret sterlingsølv"
        },
        {
          "type": "text",
          "id": "variation_text",
          "label": "Variation Subtitle",
          "default": "Flere variationer"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price Text",
          "default": "DKK 9.750,00"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Georg Swiper Carousel"
    }
  ]
}
{% endschema %}
