{% comment %}
  Georg Jensen Product Carousel / Grid ("Populære produkter") - 1-to-1 Replica
{% endcomment %}

<div class="georg-product-carousel-section">
  <div class="georg-container">
    <div class="georg-carousel-header">
      <h2 class="georg-section-title georg-serif">{{ section.settings.heading | default: 'Populære produkter' }}</h2>
      <div class="georg-carousel-nav-arrows">
        <button class="georg-carousel-arrow georg-arrow-prev" aria-label="Forrige" id="georgPrev-{{ section.id }}">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="georg-carousel-arrow georg-arrow-next" aria-label="Næste" id="georgNext-{{ section.id }}">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="georg-carousel-track-wrapper">
      <div class="georg-carousel-track" id="georgTrack-{{ section.id }}">
        {%- assign collection = collections[section.settings.collection] -%}
        {%- if collection != blank and collection.products.size > 0 -%}
          {%- for product in collection.products limit: section.settings.products_to_show -%}
            <div class="georg-product-card-slide">
              {% render 'georg-jensen-card-product', product: product %}
            </div>
          {%- endfor -%}
        {%- else -%}
          <!-- Demo Fallback Products using downloaded assets -->
          {%- for i in (1..8) -%}
            {%- assign img_index = i | plus: 9 -%}
            {%- assign img_filename = 'downloaded_image_' | append: img_index | append: '.jpg' -%}
            <div class="georg-product-card-slide">
              <div class="georg-card-product">
                <div class="georg-card-media-wrap">
                  <span class="georg-wishlist-toggle" aria-label="Tilføj til ønskeliste">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                  </span>
                  <a href="#" class="georg-card-image-link">
                    <img src="{{ img_filename | asset_url }}" alt="Georg Jensen Product" class="georg-card-main-img" loading="lazy">
                  </a>
                </div>
                <div class="georg-card-info">
                  <div class="georg-card-title-wrap">
                    <span class="georg-card-brand-caps">KOPPEL / BERNADOTTE</span>
                    <span class="georg-card-prod-type">skål / kande</span>
                  </div>
                  <div class="georg-card-material">Blankt rustfrit stål</div>
                  <div class="georg-card-variation">Flere variationer</div>
                  <div class="georg-card-price">DKK 2.450,00</div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

<style>
  .georg-product-carousel-section {
    padding: 60px 0 80px 0;
    background-color: #fafafa;
    border-top: 1px solid #eeeeee;
    border-bottom: 1px solid #eeeeee;
  }

  .georg-carousel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 36px;
  }

  .georg-carousel-nav-arrows {
    display: flex;
    gap: 10px;
  }

  .georg-carousel-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid #dddddd;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #222222;
    transition: all 0.2s ease;
  }

  .georg-carousel-arrow:hover {
    border-color: #000000;
    background: #000000;
    color: #ffffff;
  }

  .georg-carousel-track-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .georg-carousel-track {
    display: flex;
    gap: 24px;
    transition: transform 0.4s ease;
  }

  .georg-product-card-slide {
    flex: 0 0 calc(25% - 18px);
    min-width: 250px;
  }

  @media screen and (max-width: 989px) {
    .georg-product-card-slide {
      flex: 0 0 calc(50% - 12px);
    }
  }

  @media screen and (max-width: 550px) {
    .georg-product-card-slide {
      flex: 0 0 100%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const track = document.getElementById('georgTrack-{{ section.id }}');
    const prevBtn = document.getElementById('georgPrev-{{ section.id }}');
    const nextBtn = document.getElementById('georgNext-{{ section.id }}');
    
    if(!track || !prevBtn || !nextBtn) return;
    
    let currentIndex = 0;
    
    nextBtn.addEventListener('click', function() {
      const slideWidth = track.querySelector('.georg-product-card-slide').offsetWidth + 24;
      const maxScroll = track.children.length - 4;
      if (currentIndex < maxScroll && maxScroll > 0) {
        currentIndex++;
        track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
      }
    });

    prevBtn.addEventListener('click', function() {
      const slideWidth = track.querySelector('.georg-product-card-slide').offsetWidth + 24;
      if (currentIndex > 0) {
        currentIndex--;
        track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
      }
    });
  });
</script>

{% schema %}
{
  "name": "Georg Jensen Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Populære produkter"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Georg Jensen Carousel"
    }
  ]
}
{% endschema %}
