<style>
predictive-search .grid__item { padding-left: 0px; }
predictive-search { width: 100%; height: 100vh; position: fixed; top: 0; left: 0; z-index: 10000; background-color: #fff; display: none; opacity: 0; visibility: hidden; transition: 0.3s ease-out; }   
.predictive-searchActive { opacity: 1; visibility: visible; }
predictive-search form { max-width: 1600px; height: 100vh; margin: 0 auto; }
.WI_searchInput_main { width: 100%; height: auto; display: flex; justify-content: center; align-items: center; padding: 20px; }
.WI_searchInput_in { height: auto; position: relative; width: 100%; max-width: 800px; display: flex; align-items: center; }
.WI_searchInput_in input { width: 100%; height: 50px; border-radius: 0px; border: 1px solid #000; background-color: transparent; padding-left: 50px; }
.WI_searchInput_in input::placeholder { font-size: 14px; color: rgba(0,0,0,0.5); }
.WI_search_icon { position: absolute; left: 0; background-color: transparent; border: none; padding: 10px; opacity: 0.5; cursor: pointer; }
.WI_search_icon svg { width: 20px; height: 20px; }
.WI_searchResult { width: 100%; height: calc(100vh - 150px); padding: 40px; display: none; }
#predictive-search-results { width: 100%; height: 100%; display: flex; justify-content: center; flex-wrap: wrap; overflow: auto; }
.WI_searchUPsell { width: 100%; height: calc(100vh - 150px); padding: 40px; }
.WI_searchUPsell_con { width: 100%; max-width: 1200px; margin: 0 auto; height: 100%; display: flex; flex-wrap: wrap; overflow: auto; gap: 40px;}
.WI_searchUPsell_con::-webkit-scrollbar { width: 4px; background-color: #f2f2f2; }
.WI_searchUPsell_con::-webkit-scrollbar-thumb { background-color: #000; }
.WI_searchUpsell_menus { width: 30%; display: flex; flex-direction: column; gap: 30px; }
.WI_searchUpsell_menu h3 { font-size: 16px; margin-bottom: 15px; font-weight: bold; border-bottom: 1px solid #eee; padding-bottom: 5px; }
.WI_searchUpsell_menu ul { list-style: none; padding: 0; margin: 0; }
.WI_searchUpsell_menu ul li { margin-bottom: 10px; }
.WI_searchUpsell_menu ul li a { text-decoration: none; color: #333; font-size: 14px; display: flex; align-items: center; justify-content: space-between; }
.WI_searchUpsell_menu ul li a:hover { text-decoration: underline; }
.WI_searchUpsell_menu ul li a svg { width: 14px; height: 14px; }
.WI_searchUpsell_trending { width: calc(70% - 40px); }
.WI_searchUpsell_trending h3 { font-size: 16px; margin-bottom: 15px; font-weight: bold; border-bottom: 1px solid #eee; padding-bottom: 5px; }
.WI_searchUpsell_trending_cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
.WI_searchUpsell_card { text-align: center; text-decoration: none; color: #000; display: block; }
.WI_searchUpsell_card img { width: 100%; aspect-ratio: 3/4; object-fit: cover; display: block; margin-bottom: 10px; }
.WI_searchUpsell_card span { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; font-weight: normal;}
.WI_searchClose { width: 100%; height: auto; top: 0; left: 0; padding: 20px; display: flex; justify-content: flex-end; }
.searchCls { padding: 0; background: none; border: none; cursor: pointer; }
.searchCls svg { width: 24px; height: 24px; }
.saerchClear { padding: 0; position: absolute; right: 8px; background-color: transparent; opacity: 0.5; border: none; display: none; cursor: pointer; }

@media screen and (max-width: 800px) {
  .WI_searchUPsell_con { flex-direction: column; }
  .WI_searchUpsell_menus { width: 100%; }
  .WI_searchUpsell_trending { width: 100%; }
  .WI_searchUpsell_trending_cards { grid-template-columns: repeat(2, 1fr); }
  .WI_searchResult { padding: 20px; }
  .WI_searchUPsell { padding: 20px; }
}
</style>

<script src="{{ 'WI_predictiveSearch.js' | asset_url }}" defer="defer"></script>

<predictive-search>
  <div class="WI_searchClose">
    <button type="button" class="searchCls">
      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" viewBox="0 0 64 64"><path d="M19 19L45 45M19 45L45 19" stroke="currentColor" stroke-width="2" fill="none"/></svg>
    </button>
  </div>
  <form action="{{ routes.search_url }}" method="get" role="search">
    <div class="WI_searchInput_main">
        <div class="WI_searchInput_in">
            <input
              id="themeSearch"
              type="search"
              name="q"
              value="{{ search.terms | escape }}"
              placeholder="Søg blandt over 2.000 koreanske produkter..."
              role="combobox"
              aria-expanded="false"
              aria-owns="predictive-search-results"
              aria-controls="predictive-search-results"
              aria-haspopup="listbox"
              aria-autocomplete="list"
              autocomplete="off"
            >
            <input name="options[prefix]" type="hidden" value="last">
            <button type="button" class="WI_search_icon">
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-search" viewBox="0 0 64 64">
                <path d="M47.16 28.58A18.58 18.58 0 1 1 28.58 10a18.58 18.58 0 0 1 18.58 18.58zM54 54L41.94 42" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
            </button>
            <button type="button" class="saerchClear">
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-close" viewBox="0 0 64 64"><path d="M19 19L45 45M19 45L45 19" stroke="currentColor" stroke-width="2" fill="none"/></svg>
            </button>
        </div>
    </div>
    <div class="WI_searchUPsell">
      <div class="WI_searchUPsell_con">
        <div class="WI_searchUpsell_menus">
          {% for block in section.blocks %}
            {% if block.type == 'menu' %}
              <div class="WI_searchUpsell_menu">
                <h3>{{ block.settings.title }}</h3>
                <ul>
                  {% for link in linklists[block.settings.menu].links %}
                    <li>
                      <a href="{{ link.url }}">
                        {{ link.title }}
                        {% if block.settings.icon_type == 'arrow' %}
                          <svg viewBox="0 0 14 10" fill="none" aria-hidden="true" focusable="false" role="presentation" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path></svg>
                        {% elsif block.settings.icon_type == 'grid' %}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                        {% elsif block.settings.icon_type == 'pen' %}
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg>
                        {% endif %}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {% endif %}
          {% endfor %}
        </div>
        
        <div class="WI_searchUpsell_trending">
          <h3>{{ section.settings.trending_title }}</h3>
          <div class="WI_searchUpsell_trending_cards">
            {% for block in section.blocks %}
              {% if block.type == 'card' %}
                <a href="{{ block.settings.link }}" class="WI_searchUpsell_card">
                  {% if block.settings.image != blank %}
                    <img src="{{ block.settings.image | img_url: '400x' }}" alt="{{ block.settings.title }}" loading="lazy">
                  {% endif %}
                  <span>{{ block.settings.title }}</span>
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    <div id="predictive-search" tabindex="-1" class="WI_searchResult"></div>
  </form>
</predictive-search>

<script>
  document.addEventListener("DOMContentLoaded", function(){
    let mainSerch = document.querySelector('predictive-search');
    
    window.openCustomSearch = function() {
        mainSerch.style.display = "block";
        setTimeout(()=>{
          mainSerch.classList.add('predictive-searchActive');
          document.getElementById('themeSearch').focus();
        },10);
    };

    document.querySelector('.searchCls').addEventListener('click', ()=>{
      mainSerch.classList.remove('predictive-searchActive');
      setTimeout(() => {
        mainSerch.style.display = "none";
      },310);
    });
  });
</script>

{% schema %}
{
  "name": "Predictive Search UI",
  "settings": [
    {
      "type": "text",
      "id": "trending_title",
      "label": "Trending Section Title",
      "default": "Trending"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Link Menu",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "arrow", "label": "Arrow" },
            { "value": "grid", "label": "Grid" },
            { "value": "pen", "label": "Pen" }
          ],
          "default": "none"
        }
      ]
    },
    {
      "type": "card",
      "name": "Trending Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Predictive Search UI"
    }
  ]
}
{% endschema %}
