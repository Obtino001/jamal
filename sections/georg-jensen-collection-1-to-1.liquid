{{ 'georg-jensen-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-facets.css' | asset_url | stylesheet_tag }}
<script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'georg-jensen-collection.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign hero_image = section.settings.hero_image | default: collection.image
  assign hero_title = section.settings.hero_title
  if hero_title == blank
    assign hero_title = collection.title
  endif
  assign hero_desc = section.settings.hero_description
  if hero_desc == blank
    assign hero_desc = collection.description
  endif
-%}

<div class="gj-collection section-{{ section.id }}" data-gj-collection>
  {%- if section.settings.show_hero -%}
    <div class="gj-collection__hero">
      <div class="gj-collection__hero-inner">
        <div class="gj-collection__hero-content">
          <h1 class="gj-collection__hero-title">{{ hero_title }}</h1>
          {%- if hero_desc != blank -%}
            <div class="gj-collection__hero-desc rte">{{ hero_desc }}</div>
          {%- endif -%}
        </div>
        <div class="gj-collection__hero-media">
          {%- if hero_image != blank -%}
            {{
              hero_image
              | image_url: width: 1400
              | image_tag:
                loading: 'eager',
                fetchpriority: 'high',
                widths: '600, 900, 1200, 1400',
                sizes: '(min-width: 750px) 55vw, 100vw',
                alt: hero_title
            }}
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>
    </div>
  {%- endif -%}

  <collection-component
    view-event-payload="{{ collection | standard_event_data: 'view' | escape }}"
    data-collection-id="{{ collection.id }}"
  >
    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="gj-collection__filters">
        <div class="gj-collection__container">
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}"
              id="main-collection-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: collection,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: 'horizontal',
                paginate: paginate
              %}
            </aside>
          {%- endif -%}
        </div>
      </div>

      <div
        class="gj-collection__grid-wrap gj-collection__container"
        id="ProductGridContainer"
      >
        {%- if collection.products.size == 0 -%}
          <div class="gj-collection__empty collection collection--empty" id="product-grid" data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <p>
              {{ 'sections.collection_template.empty' | t }}
              <br>
              {{
                'sections.collection_template.use_fewer_filters_html'
                | t: link: collection.url, class: 'underlined-link link'
              }}
            </p>
          </div>
        {%- else -%}
          <div class="collection">
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="gj-collection__grid"
            >
              {%- for product in collection.products -%}
                <li>
                  {% render 'georg-jensen-collection-card',
                    product: product,
                    lazy_load: forloop.index0 > 3,
                    low_stock_threshold: section.settings.low_stock_threshold,
                    show_stock: section.settings.show_stock,
                    material_fallback: section.settings.material_fallback,
                    show_new_badge: section.settings.show_new_badge
                  %}
                </li>
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              <div class="gj-collection__pagination">
                {% render 'pagination', paginate: paginate, anchor: '' %}
              </div>
            {%- endif -%}

            <p class="gj-collection__count" role="status">
              Showing {{ collection.products.size }} of {{ collection.products_count }}
            </p>
          </div>
        {%- endif -%}
      </div>
    {%- endpaginate -%}
  </collection-component>
</div>

{% schema %}
{
  "name": "GJ Collection",
  "tag": "section",
  "class": "section-georg-jensen-collection",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "checkbox",
      "id": "show_hero",
      "label": "Show hero banner",
      "default": true
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title override",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "richtext",
      "id": "hero_description",
      "label": "Hero description override",
      "info": "Leave blank to use collection description. Underline words as links in the editor.",
      "default": "<p>Discover all of our superb jewellery designs matched by expert craftsmanship that offers countless <a href=\"/collections/all\">earrings</a>, <a href=\"/collections/all\">bracelets</a>, <a href=\"/collections/all\">pendants</a> and <a href=\"/collections/all\">rings</a> in <a href=\"/collections/all\">sterling silver</a>, <a href=\"/collections/all\">18 karat gold</a> and <a href=\"/collections/all\">diamonds</a>.</p>"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Falls back to collection image"
    },
    {
      "type": "header",
      "content": "Filters & sort (Dawn facets)"
    },
    {
      "type": "paragraph",
      "content": "Filters use Shopify Search & Discovery. Configure Price, Product type, Collection, Material in Admin → Search & Discovery → Filters."
    },
    {
      "type": "checkbox",
      "id": "enable_filtering",
      "label": "Enable filtering",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_sorting",
      "label": "Enable sorting",
      "default": true
    },
    {
      "type": "header",
      "content": "Product grid"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 36,
      "label": "Products per page"
    },
    {
      "type": "checkbox",
      "id": "show_new_badge",
      "label": "Show NEW badge",
      "default": true,
      "info": "Shows for products tagged New or created in last 60 days"
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "label": "Show low stock / sold out",
      "default": true
    },
    {
      "type": "range",
      "id": "low_stock_threshold",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 1,
      "label": "Low stock threshold"
    },
    {
      "type": "text",
      "id": "material_fallback",
      "label": "Material fallback",
      "default": "Sterling Silver",
      "info": "Uses metafield custom.material when set"
    }
  ],
  "presets": [
    {
      "name": "GJ Collection"
    }
  ]
}
{% endschema %}
