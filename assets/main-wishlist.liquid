/* ============================================================
   WISHLIST STYLES
   ============================================================ */

/* ── WishlistButton (heart on product card) ─────────────── */
wishlist-button {
  position: absolute;
  inset-block-start: 0.625rem;
  inset-inline-end: 0.625rem;
  z-index: 2;
  display: block;
  line-height: 0;
}

.wishlist-button {
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgb(var(--background) / 0.85);
  backdrop-filter: blur(4px);
  border-radius: 50%;
  border: none;
  cursor: pointer;
  transition: background 0.15s, transform 0.15s;
  color: rgb(var(--text-color));
  padding: 0;
}
/* 
.wishlist-button:hover {
  background: rgb(var(--background));
  transform: scale(1.1);
} */

.wishlist-button__icon {
  width: 20px;
  height: 20px;
  display: block;
  transition: opacity 0.15s, transform 0.2s;
  color: white;
}

/* Outline icon visible by default */
.wishlist-button__icon--outline {
  opacity: 1;
}
.wishlist-button__icon--filled {
  opacity: 0;
  position: absolute;
  color: #e2334a;
  transform: scale(0.7);
}

/* Active state */
.wishlist-button.is-active .wishlist-button__icon--outline {
  opacity: 0;
}
.wishlist-button.is-active .wishlist-button__icon--filled {
  opacity: 1;
  transform: scale(1);
}

/* ── Header wishlist icon ────────────────────────────────── */
.header__wishlist-link {
  position: relative;
  display: flex;
  align-items: center;
}

wishlist-count {
  position: absolute;
  inset-block-start: -0.4rem;
  inset-inline-end: -0.5rem;
  min-width: 1rem;
  height: 1rem;
  background: rgb(var(--text-color));
  color: #fff;
  font-size: 0.55rem;
  font-weight: 700;
  line-height: 1rem;
  text-align: center;
  border-radius: 999px;
  padding-inline: 0.2rem;
  display: block;
}

/* ── Wishlist page grid ──────────────────────────────────── */
wishlist-page {
  display: block;
}

.wishlist-page__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 2rem var(--container-gutter, 1.5rem);
}

@media screen and (min-width: 700px) {
  .wishlist-page__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2.5rem 1.5rem;
  }
}

@media screen and (min-width: 1000px) {
  .wishlist-page__grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
}

/* Empty state */
.wishlist-page__empty {
  text-align: center;
  padding-block: 4rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
}

.wishlist-page__empty-text {
  font-size: 1.125rem;
  color: rgb(var(--text-color) / 0.65);
}

/* ── Wishlist page product card ──────────────────────────── */
.wishlist-card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.wishlist-card__figure {
  position: relative;
}

.wishlist-card__media {
  display: block;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: min(var(--rounded, 0px), 4px);
  background-color: rgb(var(--border-color) / 0.15);
}

.wishlist-card__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.35s ease;
}

.wishlist-card__media:hover .wishlist-card__image {
  transform: scale(1.04);
}

.wishlist-card__image-placeholder {
  width: 100%;
  height: 100%;
  background: rgb(var(--border-color) / 0.25);
}

.wishlist-card__badge {
  position: absolute;
  inset-block-start: 0.5rem;
  inset-inline-start: 0.5rem;
  background: rgb(var(--text-color));
  color: rgb(var(--background));
  font-size: 0.625rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.2em 0.5em;
  border-radius: 2px;
}

/* Remove button (filled heart, top-right) */
.wishlist-card__remove {
  position: absolute;
  inset-block-start: 0.625rem;
  inset-inline-end: 0.625rem;
  width: 2rem;
  height: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgb(var(--background) / 0.85);
  backdrop-filter: blur(4px);
  border-radius: 50%;
  border: none;
  cursor: pointer;
  color: #e2334a;
  transition: background 0.15s, transform 0.15s;
  padding: 0;
}
/* 
.wishlist-card__remove:hover {
  background: rgb(var(--background));
  transform: scale(1.1);
} */

.wishlist-card__info {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.wishlist-card__vendor {
  font-size: 0.625rem;
  letter-spacing: 0.1em;
  color: rgb(var(--text-color) / 0.55);
  text-transform: uppercase;
}

.wishlist-card__title {
  font-size: 0.875rem;
  line-height: 1.35;
  text-decoration: none;
  color: inherit;
  transition: opacity 0.15s;
}

.wishlist-card__title:hover {
  opacity: 0.7;
}

.wishlist-card__price {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.wishlist-card__price-current {
  font-size: 0.875rem;
}

.wishlist-card__price-current.price--on-sale {
  color: #c0392b;
}

.wishlist-card__price-compare {
  font-size: 0.8125rem;
  color: rgb(var(--text-color) / 0.45);
  text-decoration: line-through;
}

.wishlist-card__add-btn {
  margin-block-start: 0.375rem;
  font-size: 0.8125rem;
  padding-block: 0.5rem;
  width: 100%;
}
