{% comment %}
  Georg Jensen collection product card
  Accepts: product, lazy_load, low_stock_threshold, show_stock, material_fallback, show_new_badge
{% endcomment %}

{%- liquid
  assign threshold = low_stock_threshold | default: 1
  assign show_stock_status = show_stock
  if show_stock_status == nil
    assign show_stock_status = true
  endif
  assign material = product.metafields.custom.material.value | default: product.metafields.custom.material
  if material == blank
    assign material = material_fallback | default: product.type
  endif
  assign inventory_qty = product.selected_or_first_available_variant.inventory_quantity
  assign manage_stock = product.selected_or_first_available_variant.inventory_management
  assign is_new = false
  if product.tags contains 'new' or product.tags contains 'New' or product.tags contains 'NEW'
    assign is_new = true
  endif
  assign img_loading = 'lazy'
  if lazy_load == false
    assign img_loading = 'eager'
  endif
-%}

<article class="gj-coll-card" data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
  <div class="gj-coll-card__media-wrap">
    <a href="{{ product.url }}" class="gj-coll-card__media">
      {%- if product.featured_media != blank -%}
        {{
          product.featured_media
          | image_url: width: 800
          | image_tag:
            loading: img_loading,
            class: 'gj-coll-card__img',
            widths: '300, 400, 600, 800',
            sizes: '(min-width: 990px) 23vw, 48vw',
            alt: product.title
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'gj-coll-card__placeholder' }}
      {%- endif -%}
    </a>

    {%- if is_new -%}
      <span class="gj-coll-card__badge">New</span>
    {%- endif -%}

    <button
      type="button"
      class="gj-coll-card__wishlist"
      aria-label="Add to wishlist"
      data-gj-wishlist-toggle
      data-product-handle="{{ product.handle }}"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    </button>
  </div>

  <div class="gj-coll-card__info">
    <a href="{{ product.url }}" class="gj-coll-card__title">{{ product.title }}</a>

    {%- if material != blank -%}
      <p class="gj-coll-card__material">{{ material }}</p>
    {%- endif -%}

    {%- unless product.has_only_default_variant -%}
      <p class="gj-coll-card__variations">More Variations</p>
    {%- endunless -%}

    <p class="gj-coll-card__price">
      {%- if product.price_varies -%}
        From {{ product.price_min | money }}
      {%- else -%}
        {{ product.price | money }}
      {%- endif -%}
    </p>

    {%- if show_stock_status -%}
      {%- if product.available == false -%}
        <p class="gj-coll-card__stock">Sold out</p>
      {%- elsif manage_stock and inventory_qty > 0 and inventory_qty <= threshold -%}
        <p class="gj-coll-card__stock">Only {{ inventory_qty }} left</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</article>
