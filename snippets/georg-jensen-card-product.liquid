{% comment %}
  Georg Jensen Product Card Snippet - 1-to-1 Replica
{% endcomment %}

<div class="georg-card-product" data-product-handle="{{ product.handle }}">
  <div class="georg-card-media-wrap">
    <button
      type="button"
      class="georg-wishlist-toggle"
      aria-label="Add to wishlist"
      data-gj-wishlist-toggle
      data-product-handle="{{ product.handle }}"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
    </button>
    
    <a href="{{ product.url }}" class="georg-card-image-link">
      {%- if product.featured_media != blank -%}
        <img src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="georg-card-main-img" loading="lazy">
        {%- if product.media[1] != blank -%}
          <img src="{{ product.media[1] | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="georg-card-hover-img" loading="lazy">
        {%- endif -%}
      {%- else -%}
        <div class="georg-card-img-placeholder">
          <svg viewBox="0 0 300 350" width="100%" height="100%">
            <rect width="100%" height="100%" fill="#fafafa"/>
            <circle cx="150" cy="160" r="60" fill="none" stroke="#e0e0e0" stroke-width="1.5"/>
          </svg>
        </div>
      {%- endif -%}
    </a>
  </div>

  <div class="georg-card-info">
    <a href="{{ product.url }}" class="georg-card-title-link">
      <div class="georg-card-title-wrap">
        {%- assign title_parts = product.title | split: ' ' -%}
        <span class="georg-card-brand-caps">{{ product.vendor | default: title_parts[0] | upcase }}</span>
        <span class="georg-card-prod-type">{{ product.title | remove: title_parts[0] | downcase }}</span>
      </div>
    </a>

    <div class="georg-card-material">
      {%- if product.metafields.custom.material != blank -%}
        {{ product.metafields.custom.material }}
      {%- else -%}
        Sterlingsølv
      {%- endif -%}
    </div>

    {%- if product.has_only_default_variant == false -%}
      <div class="georg-card-variation">Flere variationer</div>
    {%- endif -%}

    <div class="georg-card-price">
      {{ product.price | money_without_trailing_zeros }}
    </div>
  </div>
</div>

<style>
  .georg-card-product {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid #eeeeee;
    transition: box-shadow 0.3s ease;
    height: 100%;
    position: relative;
  }

  .georg-card-product:hover {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
  }

  .georg-card-media-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: #fafafa;
    overflow: hidden;
  }

  .georg-wishlist-toggle {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 3;
    width: 32px;
    height: 32px;
    border: 0;
    background: rgba(255, 255, 255, 0.85);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666666;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .georg-wishlist-toggle.is-active svg {
    fill: currentColor;
    color: #1a1a1a;
  }

  .georg-wishlist-toggle:hover {
    color: #e0245e;
    background: #ffffff;
  }

  .georg-card-image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .georg-card-main-img, .georg-card-hover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .georg-card-hover-img {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }

  .georg-card-media-wrap:hover .georg-card-hover-img {
    opacity: 1;
  }

  .georg-card-info {
    padding: 16px 18px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .georg-card-title-link {
    text-decoration: none;
    color: inherit;
  }

  .georg-card-title-wrap {
    font-size: 13px;
    line-height: 1.4;
  }

  .georg-card-brand-caps {
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #111111;
  }

  .georg-card-prod-type {
    font-weight: 400;
    color: #333333;
    margin-left: 4px;
  }

  .georg-card-material {
    font-size: 11px;
    color: #777777;
    margin-top: 2px;
  }

  .georg-card-variation {
    font-size: 11px;
    color: #888888;
    font-style: italic;
  }

  .georg-card-price {
    font-family: var(--georg-font-sans-bold, 'SourceSansPro-Bold', 'Source Sans Pro', sans-serif);
    font-size: 14px;
    font-weight: 700;
    color: #000;
    margin-top: 8px;
    letter-spacing: 0;
  }
</style>
