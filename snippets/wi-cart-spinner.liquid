{% comment %}
  WI cart drawer spinner
  Accepts: size (number, default 24)
{% endcomment %}
{%- assign spinner_size = size | default: 24 -%}
<svg
  class="wi-cart-spinner"
  width="{{ spinner_size }}"
  height="{{ spinner_size }}"
  viewBox="0 0 50 50"
  aria-hidden="true"
  focusable="false"
>
  <circle class="wi-cart-spinner__path" cx="25" cy="25" r="20" fill="none" stroke="currentColor" stroke-width="4"></circle>
</svg>
