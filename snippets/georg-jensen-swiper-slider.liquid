{% comment %}
  Reusable Georg Jensen Swiper track filled from a collection.
  Accepts:
  - slider_id: {String} unique id (required)
  - collection: {Collection}
  - limit: {Number}
  - exclude_product_id: {Number} optional
  - low_stock_threshold: {Number}
  - show_stock: {Boolean}
  - material_fallback: {String}
{% endcomment %}

{%- liquid
  assign limit_count = limit | default: 8
-%}

<div class="swiper gj-swiper" data-gj-swiper="{{ slider_id }}">
  <div class="swiper-wrapper">
    {%- if collection != blank and collection.products_count > 0 -%}
      {%- assign shown = 0 -%}
      {%- for product in collection.products -%}
        {%- liquid
          assign skip_product = false
          if exclude_product_id != blank and product.id == exclude_product_id
            assign skip_product = true
          endif
        -%}
        {%- unless skip_product -%}
          {%- if shown < limit_count -%}
            <div class="swiper-slide">
              {% render 'georg-jensen-reco-card',
                product: product,
                low_stock_threshold: low_stock_threshold,
                show_stock: show_stock,
                material_fallback: material_fallback
              %}
            </div>
            {%- assign shown = shown | plus: 1 -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endfor -%}
      {%- if shown == 0 -%}
        <div class="swiper-slide">
          <p class="gj-tabs-swiper__empty">No products in this collection.</p>
        </div>
      {%- endif -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="swiper-slide">
          <article class="gj-reco-card gj-reco-card--placeholder">
            <div class="gj-reco-card__media">
              {{ 'product-' | append: i | placeholder_svg_tag: 'gj-reco-card__placeholder' }}
            </div>
            <div class="gj-reco-card__info">
              <div class="gj-reco-card__title-row">
                <span class="gj-reco-card__title">Product title</span>
                <span class="gj-reco-card__wishlist" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                </span>
              </div>
              <p class="gj-reco-card__material">Sterling Silver</p>
              <p class="gj-reco-card__price">€ 0,00</p>
            </div>
          </article>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>
