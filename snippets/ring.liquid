{%- comment -%} WEB COMPONENT JAVASCRIPT LOGIC {%- endcomment -%}
<script>
  if (!customElements.get('ring-size-modal')) {
    class RingSizeModal extends HTMLElement {
      constructor() {
        super();
        this.dialog = this.querySelector('.rsg-dialog');
        this.overlay = this.querySelector('.rsg-overlay');
        this.closeBtns = this.querySelectorAll('[data-modal-close]');
        this.tabs = this.querySelectorAll('.rsg-tab');
        this.panels = this.querySelectorAll('.rsg-panel');
        // Because modal moves to body, we must query document for triggers
        this.triggers = document.querySelectorAll(`[data-modal-target="${this.id}"]`);
        this.video = this.querySelector('.rsg-video-el');
        this.videoBtn = this.querySelector('.rsg-video-btn');

        this.bindEvents();
      }

      connectedCallback() {
        // Move modal to body to avoid z-index clipping by transform/opacity parents
        if (this.parentElement && this.parentElement !== document.body) {
          document.body.appendChild(this);
        }
      }

      bindEvents() {
        this.triggers.forEach(trigger => {
          trigger.addEventListener('click', (e) => {
            e.preventDefault();
            this.open();
          });
        });

        this.closeBtns.forEach(btn => btn.addEventListener('click', () => this.close()));
        
        this.tabs.forEach(tab => {
          tab.addEventListener('click', (e) => this.switchTab(e.currentTarget));
        });

        if (this.videoBtn && this.video) {
          this.videoBtn.addEventListener('click', () => {
            if (this.video.paused) {
              this.video.play();
              this.videoBtn.innerHTML = '<svg viewBox="0 0 24 24"><rect x="8" y="5" width="3" height="14"/><rect x="14" y="5" width="3" height="14"/></svg>';
            } else {
              this.video.pause();
              this.videoBtn.innerHTML = '<svg viewBox="0 0 24 24"><polygon points="8,5 19,12 8,19"/></svg>';
            }
          });
        }
      }

      open() {
        this.setAttribute('open', '');
        document.body.style.overflow = 'hidden'; 
      }

      close() {
        this.removeAttribute('open');
        document.body.style.overflow = ''; 
        if(this.video) this.video.pause();
      }

      switchTab(selectedTab) {
        this.tabs.forEach(tab => tab.setAttribute('aria-selected', 'false'));
        this.panels.forEach(panel => panel.setAttribute('hidden', ''));
        
        selectedTab.setAttribute('aria-selected', 'true');
        const targetPanel = this.querySelector(`#${selectedTab.getAttribute('aria-controls')}`);
        if (targetPanel) {
          targetPanel.removeAttribute('hidden');
        }
      }
    }
    customElements.define('ring-size-modal', RingSizeModal);
  }
</script>
{%- endif -%}
